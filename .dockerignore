# .NET build artefacts — must NOT leak into the Linux container build.
# When the host is Windows and Visual Studio (or `dotnet build`) has run
# locally, project.assets.json carries Windows paths that the Linux SDK
# cannot resolve and `dotnet publish` aborts with MSB4018 inside
# Microsoft.PackageDependencyResolution.targets.
**/bin/
**/obj/

# Node sidecar build artefacts
**/node_modules/
**/dist/
**/.next/

# IDE / editor cruft
.vs/
.vscode/
.idea/
*.user
*.suo

# Git metadata / OS junk
.git/
.gitignore
**/*.DS_Store
Thumbs.db

# Local secrets and dev overrides
**/appsettings.Development.json
**/appsettings.Local.json
**/.env
**/.env.local

# Docs and large unrelated trees aren't needed in the runtime image.
# StingTools/ is the Revit plugin tree — exclude almost all of it, but
# whitelist BcfEngine.cs because Planscape.Shared.csproj links it via
# <Compile Include="..\..\..\StingTools\BIMManager\BcfEngine.cs"/>.
StingTools/*
!StingTools/BIMManager/
StingTools/BIMManager/*
!StingTools/BIMManager/BcfEngine.cs

# Mobile app source isn't needed for the API container build
Planscape/
docs/
tests/
*.md
