# Build output
bin/
obj/
*.dll
*.pdb
*.exe

# Deployment output — extract_plugin.sh regenerates CompiledPlugin/ on
# every build by copying from StingTools/Data/. Tracking it makes git
# status unusable and conflicts on every branch switch (see PR #208).
CompiledPlugin/

# Local-only environment + storage on the server side
Planscape.Server/.env.local
Planscape.Server/src/Planscape.API/storage/

# IDE / user files
.vs/
*.user
*.suo
*.csproj.user

# NuGet
packages/

# OS
.DS_Store
Thumbs.db

# Backup / editor temp files
*.bak
*.orig
*.old
*~
~$*

# Runtime logs (Revit + plugin file loggers)
*.log
build_output.txt

# Build output: extract_plugin.sh regenerates CompiledPlugin/ on every run, so
# tracking it makes git status unusable. Source data lives in StingTools/Data/
# and gets COPIED here during build — the source is what we ship.
CompiledPlugin/

# Claude Code session worktrees + local settings.
.claude/worktrees/
.claude/settings.local.json

# STING runtime sidecars at project level (written alongside .rvt)
.sting_seq.json
.sting_warnings_baseline.json
.sting_dwg_conversion.json
.sting_compliance_trend.json
.sting_deferred_elements.json
.sting_data_hash.json
.sting_layout_presets.json
STING_WORKFLOW_LOG.json

# Production secrets (Phase: secrets runbook). Never commit a populated .env.
.env
*.env
!*.env.template

# Node / JS dependencies — never commit installed packages
node_modules/
dist/
.next/
out/
build/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# IFC drop folder — runtime files, not source
IFC_DROP/

# Docker runtime logs — generated at runtime, not source controlled
Planscape.Server/docker/api-errors.txt

# PSD-format outputs from tools/converters/sting_to_psd.py are regenerated
# from shared/ifc/{enums,psets}/*.xml on every build; not committed.
shared/ifc/psd_out/

# Round-trip test fixtures generated by tools/tests/round_trip.py;
# the script + manual fixtures are committed, ifcopenshell-generated
# variants are not.
tests/fixtures/*.ifc
tests/fixtures/*.roundtrip.ifc

# PBR texture packs downloaded by users at runtime — large binary
# blobs, per-project, never source-controlled.
_BIM_COORD/textures/
**/_BIM_COORD/textures/
CompiledPlugin/
