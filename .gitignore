# Build output
bin/
obj/
*.dll
*.pdb
*.exe

# Deployment output — regenerated by extract_plugin.sh from StingTools/bin/Release.
# Source data lives in StingTools/Data/ and gets COPIED here during build —
# the source is what we ship; the copy is disposable.
CompiledPlugin/

# IDE / user files
.vs/
*.user
*.suo
*.csproj.user

# NuGet
packages/

# OS
.DS_Store
Thumbs.db

# Backup / editor temp files
*.bak
*.orig
*.old
*~
~$*

# Runtime logs (Revit + plugin file loggers)
*.log
build_output.txt

# Claude Code session worktrees + local settings.
.claude/worktrees/
.claude/settings.local.json

# STING runtime sidecars at project level (written alongside .rvt)
.sting_seq.json
.sting_warnings_baseline.json
.sting_dwg_conversion.json
.sting_compliance_trend.json
.sting_deferred_elements.json
.sting_data_hash.json
.sting_layout_presets.json
STING_WORKFLOW_LOG.json

# Production secrets (Phase: secrets runbook). Never commit a populated .env.
.env
*.env
!*.env.template
