{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/renderer",
    "paths": {
      "@api/*":   ["../Planscape/src/api/*"],
      "@stores/*":["../Planscape/src/stores/*"],
      "@types/*": ["../Planscape/src/types/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
