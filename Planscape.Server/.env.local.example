# Planscape.Server/.env.local.example
#
# Copy this file to .env.local and fill in real values:
#
#   cp .env.local.example .env.local
#   # then edit .env.local
#
# .env.local is gitignored — it carries secrets, never commit it.
#
# Source it before running migrations or `dotnet run`:
#
#   source Planscape.Server/.env.local
#   # or use the helper:
#   ./Planscape.Server/dev-up.sh migrate
#
# The double underscore (`__`) is the .NET configuration convention for
# nested keys: Jwt__Key maps to "Jwt:Key", ConnectionStrings__Default
# maps to "ConnectionStrings:Default", etc.

# ── Required ─────────────────────────────────────────────────────────

# JWT signing key. MUST be ≥ 32 characters. Generate a fresh random
# secret per environment (don't reuse across dev / staging / prod):
#
#   openssl rand -base64 48
#   # Git Bash without openssl on PATH:
#   head -c 48 /dev/urandom | base64
#
# Program.cs refuses to start without this and rejects known-bad
# placeholder values, so a real random string is required.
export Jwt__Key="REPLACE_WITH_OPENSSL_RAND_BASE64_48"

# Postgres connection string. Default targets the docker-compose
# Postgres container on localhost. The password deliberately AVOIDS
# the '!' character — Bash interactive history expansion treats '!'
# as an event reference and mangles any inline psql / curl command
# that quotes the password with double quotes. Using only [a-z0-9_]
# keeps inline commands paste-safe. If you're running Postgres
# natively or against a remote DB, edit Host / Port / Database /
# Username / Password to match.
export ConnectionStrings__Default="Host=localhost;Port=5432;Database=planscape;Username=planscape;Password=planscape_dev_2026"

# Migrations bypass the pooled connection string (PgBouncer transaction
# mode breaks DDL). When you have a separate direct-connect string,
# put it here; otherwise it falls back to ConnectionStrings__Default.
export ConnectionStrings__Migrations="$ConnectionStrings__Default"

# ── Optional ─────────────────────────────────────────────────────────

# Redis (caching + SignalR backplane). Leave commented to skip.
# export ConnectionStrings__Redis="localhost:6379"

# MinIO / S3 file storage.
# export Storage__Endpoint="http://localhost:9000"
# export Storage__AccessKey="planscape"
# export Storage__SecretKey="REPLACE_ME"
# export Storage__Bucket="planscape-models"

# SMTP for outbound email. Without these, IEmailService falls back to
# NullEmailService (logs only).
# export Smtp__Host="smtp.example.com"
# export Smtp__Port="587"
# export Smtp__Username="planscape@example.com"
# export Smtp__Password="REPLACE_ME"
# export Smtp__FromAddress="planscape@example.com"

# Firebase Cloud Messaging (push). Path to the service-account JSON.
# export Firebase__CredentialsPath="/c/Dev/STINGTOOLS/secrets/firebase-admin.json"

# ASP.NET Core environment. "Development" enables Swagger + verbose
# errors. Use "Production" only when wiring real secrets.
export ASPNETCORE_ENVIRONMENT="Development"

# Disable .NET diagnostic gestures + telemetry on dev machines.
export DOTNET_NOLOGO="1"
export DOTNET_CLI_TELEMETRY_OPTOUT="1"
