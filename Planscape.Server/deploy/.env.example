# Planscape heavy-BIM server (C0) — deployment secrets template.
#
# Copy to .env (gitignored) on the VM and fill in. docker compose picks these
# up automatically. NEVER commit a populated .env. NEVER paste these values
# into a chat / ticket / screenshot.
#
#   cp .env.example .env
#   # then edit .env

# ── Database ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 24
DB_PASSWORD=

# ── Auth (HS256) ──────────────────────────────────────────────────────────
# CRITICAL: this MUST be the SAME secret the Cloudflare Workers (B1 auth) sign
# JWTs with — otherwise tokens minted at planscape.build won't validate on the
# heavy-BIM API. Min 32 chars. Copy the Workers JWT_SECRET verbatim.
# C1 (auth bridge) consumes this as JWT_SECRET; until then the server reads it
# as Jwt__Key (see docker-compose.yml).
JWT_KEY=
# Issuer the Workers stamp into the JWT `iss` claim. C1's PlanscapeJwtHandler
# validates ValidIssuer="planscape".
JWT_ISSUER=planscape
JWT_AUDIENCE=Planscape.Client

# ── Outward URLs ──────────────────────────────────────────────────────────
# The tunnel hostname this VM is published at. Drives outward links + CORS.
PUBLIC_BASE_URL=https://api-heavy.planscape.build
# Browser origins allowed to call this API (the marketing/app front-end + the
# tunnel host itself).
CORS_ORIGIN_PRIMARY=https://planscape.build
CORS_ORIGIN_SECONDARY=https://api-heavy.planscape.build

# ── Fresh-DB schema bootstrap ─────────────────────────────────────────────
# Leave true for the FIRST boot against an empty Postgres (the EF migration set
# is intentionally incomplete; EnsureCreated builds the full schema from the
# model). Safe to leave true; the idempotent patchers run either way.
PLANSCAPE_USE_ENSURE_CREATED=true

# ── Object storage (MinIO) ────────────────────────────────────────────────
MINIO_ROOT_USER=planscape
# Generate: openssl rand -base64 24
MINIO_ROOT_PASSWORD=

# ── IFC → glTF derivatives (optional) ─────────────────────────────────────
# To enable IFC viewer derivatives, point IFCCONVERT_URL at an IfcOpenShell
# IfcConvert zip for THIS VM's architecture (Ampere A1 = arm64/aarch64), then
# set MODEL_CONVERTER_PROVIDER=ifcconvert. Leave both default to ship without it.
IFCCONVERT_URL=skip
MODEL_CONVERTER_PROVIDER=null

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────
# No secret lives in .env for the tunnel — the credentials are the
# cloudflared/credentials.json file (gitignored). See oracle-vm-setup.md.
