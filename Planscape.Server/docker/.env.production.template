# Planscape — PRODUCTION secrets template.
#
# Copy to .env (gitignored) and fill in. docker-compose picks these up
# automatically. NEVER commit a populated .env. NEVER paste these values into a
# chat / ticket / screenshot. No real keys live in this template.

# ── Domain / outward URLs ────────────────────────────────────────────────
# Your live apex/subdomain. Used by the email from-address below and as the
# public origin for every outward link (invites, resets, share/QR) + CORS.
DOMAIN=
PUBLIC_BASE_URL=https://${DOMAIN}

# ── Database ─────────────────────────────────────────────────────────────
DB_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────────────
# Min 32 chars. Generate with: openssl rand -base64 48
JWT_KEY=

# ── Email provider ───────────────────────────────────────────────────────
# Email__Provider selects the transport behind IEmailService:
#   resend ⇒ Resend HTTP API (preferred for production — see docs/EMAIL_RESEND.md)
#   smtp   ⇒ MailKit (Gmail / Mailpit, or Resend's own SMTP endpoint)
# Both share the exact same rendered HTML+text body — only the wire differs.
Email__Provider=resend

# Resend HTTP API key (https://resend.com → API Keys). Maps to Resend__ApiKey.
RESEND_API_KEY=

# From identity (used by BOTH providers).
# IMPORTANT: with Email__Provider=resend the from-address MUST be on the
# Resend-VERIFIED domain (add + verify the domain's SPF/DKIM/DMARC records in
# Resend first — docs/EMAIL_RESEND.md). An unverified from-address is rejected.
SMTP_FROM_ADDRESS=no-reply@${DOMAIN}
SMTP_FROM_NAME=Planscape

# ── SMTP (only used when Email__Provider=smtp) ───────────────────────────
# Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_SSL=false
#         SMTP_USERNAME=you@gmail.com  SMTP_PASSWORD=<16-char app password>
# Mailpit (dev capture): SMTP_HOST=mailpit  SMTP_PORT=1025  (blank user/pass)
# Resend-SMTP (zero-code Resend): SMTP_HOST=smtp.resend.com  SMTP_PORT=465
#         SMTP_USE_SSL=true  SMTP_USERNAME=resend  SMTP_PASSWORD=<RESEND_API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false

# ── Billing (optional in non-billing deployments) ────────────────────────
Billing__Stripe__SecretKey=
Billing__Stripe__WebhookSecret=
Billing__Flutterwave__SecretKey=
Billing__Flutterwave__WebhookHash=

# ── Push notifications (Firebase) ────────────────────────────────────────
Firebase__ServiceAccountJson=
Firebase__ProjectId=

# ── Storage ──────────────────────────────────────────────────────────────
Storage__Path=/var/lib/planscape/storage

# ── Live meetings A/V (LiveKit) ──────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Advertised media (ICE) IP. PRODUCTION: set to this VPS's PUBLIC IP, otherwise
# LiveKit advertises the unreachable Docker bridge IP and the PC never connects.
# (Local/dev defaults to 127.0.0.1.) Also front 50000-50019/udp with TURN/TLS on
# 443 for clients behind restrictive firewalls — see docs/DEPLOYMENT.md.
LIVEKIT_NODE_IP=
