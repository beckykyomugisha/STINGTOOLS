  // ── ArchiCAD-specific property sets (Gap 12) ──────────────────────────────
  // These must match the entries in StingTools/Data/IFC/ARCHICAD_IFC_MAPPING.json.

  // Gap 12: AC_Pset_ElementID.elementGUID → cross-tool identity registry key.
  // WriteGlobalIdRegistryAsync in IfcIngestController looks up
  // "AC_Pset_ElementID.elementGUID" from the property bag to populate
  // ElementGlobalIdRegistry.ArchiCadGuid. This mapping ensures it lands in
  // TaggedElement as well for direct query access.
  { "pset_name": "AC_Pset_ElementID",        "property_name": "elementGUID",      "sting_param": "AC_ELEMENT_GUID_TXT" },
  { "pset_name": "AC_Pset_ElementID",        "property_name": "ID",               "sting_param": "AC_ELEMENT_ID_TXT" },
  { "pset_name": "AC_Pset_ElementID",        "property_name": "Hotlink_ID",       "sting_param": "AC_HOTLINK_ID_TXT" },
  { "pset_name": "AC_Pset_ElementID",        "property_name": "Hotlink_SourceFile","sting_param": "AC_HOTLINK_FILE_TXT" },
  { "pset_name": "AC_Pset_ElementID",        "property_name": "Revision",         "sting_param": "AC_REVISION_TXT" },

  // Gap 12: AC_Pset_RenovationInfo.RenovationStatus → ASS_STATUS_TXT.
  // Both RNV_STATUS_TXT (authoritative renovation field) and ASS_STATUS_TXT
  // (standard STING phase/status field) must be populated from ArchiCAD's
  // renovation state so STING phase filters and ISO 19650 status checks work.
  { "pset_name": "AC_Pset_RenovationInfo",   "property_name": "RenovationStatus", "sting_param": "RNV_STATUS_TXT" },
  { "pset_name": "AC_Pset_RenovationInfo",   "property_name": "RenovationStatus", "sting_param": "ASS_STATUS_TXT" },
