{
  "_comment": "CFG-01 — Production config template. Copy to appsettings.Production.json and fill the marked secrets. Any value can also be overridden via environment variables using the double-underscore convention, e.g. Jwt__Key.",

  "ConnectionStrings": {
    "Default": "Host=postgres;Database=planscape;Username=planscape;Password=__REPLACE_DB_PASSWORD__"
  },

  "Jwt": {
    "_note": "Generate with: openssl rand -base64 48 — must be at least 32 bytes.",
    "Key": "__REPLACE_WITH_32PLUS_BYTE_RANDOM_SECRET__",
    "Issuer": "Planscape",
    "Audience": "Planscape.Client",
    "ExpiryHours": 8
  },

  "Redis": {
    "Connection": "redis:6379"
  },

  "Cors": {
    "_note": "Dashboard origins for the web app. Mobile uses the auto-permissive Mobile policy.",
    "Origins": [
      "https://planscape.yourco.com"
    ]
  },

  "Storage": {
    "_note": "Provider=Local uses filesystem (volume-backed). Provider=S3 uses AWS S3 / MinIO / R2 / Spaces.",
    "Provider": "S3",
    "Path": "/var/lib/planscape/storage",
    "S3": {
      "BucketName": "planscape-attachments",
      "Region": "us-east-1",
      "ServiceUrl": "http://minio:9000",
      "AccessKey": "__REPLACE_S3_ACCESS_KEY__",
      "SecretKey": "__REPLACE_S3_SECRET_KEY__",
      "ForcePathStyle": "true"
    }
  },

  "Firebase": {
    "_note": "Leave ProjectId blank to skip FCM (Expo Push still works via Expo:AccessToken below).",
    "ProjectId": "",
    "ServiceAccountJson": ""
  },

  "Expo": {
    "_note": "Optional. Fill for higher rate limits on the Expo Push API. Leave blank for anonymous mode.",
    "AccessToken": ""
  },

  "Smtp": {
    "_note": "Optional. Leave Host blank to fall back to NullEmailService (invitation emails logged, not sent).",
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "no-reply@planscape.yourco.com",
    "FromName": "Planscape"
  },

  "Licensing": {
    "Tiers": {
      "Starter":      { "MaxUsers": 5,   "MaxProjects": 1,   "StorageMB": 500,    "ApiRatePerMin": 30 },
      "Professional": { "MaxUsers": 25,  "MaxProjects": 10,  "StorageMB": 5120,   "ApiRatePerMin": 100 },
      "Premium":      { "MaxUsers": -1,  "MaxProjects": -1,  "StorageMB": 51200,  "ApiRatePerMin": 1000 },
      "Enterprise":   { "MaxUsers": -1,  "MaxProjects": -1,  "StorageMB": -1,     "ApiRatePerMin": -1 }
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.SignalR": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/planscape/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },

  "AllowedHosts": "*"
}
