# Planscape mobile app — environment variables
#
# Copy to .env (gitignored) for local dev, or supply via eas.json env block
# (preview/production profiles) so release builds point at the right API
# host out of the box. EXPO_PUBLIC_* variables are baked into the JS bundle
# at build time.
#
# WHY THIS FILE EXISTS:
# Phones cannot reach the dev machine's `localhost`. Without an explicit
# LAN IP / public hostname here, the mobile app's first launch on a phone
# falls back to http://localhost:5000 and every API call times out. The
# user can override this in Settings later, but they shouldn't have to.

# ── API host ──────────────────────────────────────────────────────────────
# Local LAN dev (phone on same WiFi as the dev machine running the API):
#   EXPO_PUBLIC_API_BASE=http://192.168.1.42:5000
# Staging:
#   EXPO_PUBLIC_API_BASE=https://api-staging.planscape.app
# Production:
#   EXPO_PUBLIC_API_BASE=https://api.planscape.app
EXPO_PUBLIC_API_BASE=

# SignalR hub URL. Defaults to <API_BASE>/hubs/notifications when unset.
EXPO_PUBLIC_HUB_URL=

# Tenant slug for white-labelled deployments (overrides the X-Tenant
# resolution middleware default).
EXPO_PUBLIC_TENANT=

# ── Sentry / crash reporting (optional) ───────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
