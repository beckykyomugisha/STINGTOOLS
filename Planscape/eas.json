{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "_comment": "EAS-01 — Build profiles for development simulator, internal QA testing, and store production.",
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_BASE": "http://planscape.local:5000",
        "EXPO_PUBLIC_HUB_URL": "http://planscape.local:5000/hubs/notifications"
      },
      "ios": { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://staging.planscape.example/api",
        "EXPO_PUBLIC_HUB_URL": "https://staging.planscape.example/hubs/notifications"
      },
      "ios": { "resourceClass": "m-medium" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://api.planscape.example",
        "EXPO_PUBLIC_HUB_URL": "https://api.planscape.example/hubs/notifications"
      },
      "ios": { "resourceClass": "m-medium" },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "__APPLE_ID__",
        "ascAppId": "__APP_STORE_CONNECT_ID__",
        "appleTeamId": "__APPLE_TEAM_ID__"
      },
      "android": {
        "serviceAccountKeyPath": "./secrets/play-service-account.json",
        "track": "internal"
      }
    }
  }
}
