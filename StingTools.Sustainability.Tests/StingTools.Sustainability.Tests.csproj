<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="xunit" Version="2.6.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.4" />
    <!-- Engines use Newtonsoft for the JSON registry loaders. -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <!-- Pure-POCO engine + registry sources linked from the main project (Revit-free).
       Mirrors StingTools.Boq.Tests: <Compile Include> the individual files that have
       no Revit dependency, so the suite runs with `dotnet test` and no Revit API. -->
  <ItemGroup>
    <Compile Include="..\StingTools\Core\Sustainability\SustainabilityResult.cs" Link="Engines\SustainabilityResult.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SustainProjectSetup.cs" Link="Engines\SustainProjectSetup.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\GreenSchemeRegistry.cs" Link="Engines\GreenSchemeRegistry.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\GreenBaselineRegistry.cs" Link="Engines\GreenBaselineRegistry.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\WaterUsageProfileRegistry.cs" Link="Engines\WaterUsageProfileRegistry.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\GreenMeasureRegistry.cs" Link="Engines\GreenMeasureRegistry.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\ClimateMonthlyRegistry.cs" Link="Engines\ClimateMonthlyRegistry.cs" />
    <!-- WS C3 — embodied-energy (MJ/kg) seed registry (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\IceEmbodiedEnergyRegistry.cs" Link="Engines\IceEmbodiedEnergyRegistry.cs" />
    <!-- WS A4 — RWH calc + BS 8515 constants + fixture aggregator (all pure). -->
    <Compile Include="..\StingTools\Core\Plumbing\RainwaterHarvestingCalc.cs" Link="Engines\RainwaterHarvestingCalc.cs" />
    <Compile Include="..\StingTools.Standards\BS8515\BS8515Standards.cs" Link="Engines\BS8515Standards.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\WaterFixtureAggregator.cs" Link="Engines\WaterFixtureAggregator.cs" />
    <!-- WS H2 — project occupancy resolver (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainOccupancy.cs" Link="Engines\SustainOccupancy.cs" />
    <!-- WS H4 — whole-life carbon roll-up (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\WholeLifeCarbon.cs" Link="Engines\WholeLifeCarbon.cs" />
    <!-- WS I1 — building-use resolver + readiness gate (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\BuildingUseResolver.cs" Link="Engines\BuildingUseResolver.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SustainReadiness.cs" Link="Engines\SustainReadiness.cs" />
    <!-- WS I3/I9 — per-country grid carbon-factor registry (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\GridCarbonRegistry.cs" Link="Engines\GridCarbonRegistry.cs" />
    <!-- WS I4 — export cell formatting that honours the Computed flag (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainExportFormat.cs" Link="Engines\SustainExportFormat.cs" />
    <!-- WS I6 — LCC integrity / health (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainLccHealth.cs" Link="Engines\SustainLccHealth.cs" />
    <!-- WS I8 — dashboard header composition (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainHeader.cs" Link="Engines\SustainHeader.cs" />
    <!-- WS I10 — LCC NPV discounting (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainNpv.cs" Link="Engines\SustainNpv.cs" />
    <!-- WS I12 — per-Design-Option comparison (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainOptionComparison.cs" Link="Engines\SustainOptionComparison.cs" />
    <!-- WS I13 — staleness state (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainStaleState.cs" Link="Engines\SustainStaleState.cs" />
    <!-- WS I14 — measure target-seeker optimiser (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\SustainMeasureOptimizer.cs" Link="Engines\SustainMeasureOptimizer.cs" />
    <!-- WS J1/J2 — country registry + cascade (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\CountryRegistry.cs" Link="Engines\CountryRegistry.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\CountryCascade.cs" Link="Engines\CountryCascade.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\AnnualEnergyEstimator.cs" Link="Engines\AnnualEnergyEstimator.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SupplyAndGenerationLayer.cs" Link="Engines\SupplyAndGenerationLayer.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\AnnualWaterEstimator.cs" Link="Engines\AnnualWaterEstimator.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\MaterialsRollup.cs" Link="Engines\MaterialsRollup.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SustainMaterialCarbon.cs" Link="Engines\SustainMaterialCarbon.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SustainEnvelopeSynth.cs" Link="Engines\SustainEnvelopeSynth.cs" />
