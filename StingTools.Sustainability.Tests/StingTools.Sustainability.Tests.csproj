    <Compile Include="..\StingTools\Core\Sustainability\BuildingUseCatalog.cs" Link="Engines\BuildingUseCatalog.cs" />
    <!-- WS K4 — building-use coverage guard (pure). -->
    <Compile Include="..\StingTools\Core\Sustainability\BuildingUseCoverage.cs" Link="Engines\BuildingUseCoverage.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SustainSavings.cs" Link="Engines\SustainSavings.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\AshraeClimateZone.cs" Link="Engines\AshraeClimateZone.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\MonthlyClimateSynthesizer.cs" Link="Engines\MonthlyClimateSynthesizer.cs" />
    <!-- WS A3 — pure BOQ waste + biogenic helpers shared with the materials carbon path. -->
    <Compile Include="..\StingTools\BOQ\WasteFactor.cs" Link="Engines\WasteFactor.cs" />
    <Compile Include="..\StingTools\BOQ\BiogenicCarbon.cs" Link="Engines\BiogenicCarbon.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\IMetricProvider.cs" Link="Engines\IMetricProvider.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SchemeEvaluator.cs" Link="Engines\SchemeEvaluator.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\EdgeKpiSnapshot.cs" Link="Engines\EdgeKpiSnapshot.cs" />
    <Compile Include="..\StingTools\Core\Sustainability\SustainUnitConverter.cs" Link="Engines\SustainUnitConverter.cs" />
    <!-- AnnualEnergyEstimator references LoadZone/EnvelopeSegment from the HVAC
         loads namespace; these POCOs are also Revit-free. -->
    <Compile Include="..\StingTools\Core\Hvac\Loads\LoadInputs.cs" Link="Engines\LoadInputs.cs" />
