    "semantics": [
      "severity=error halts spool growth at the triggering element",
      "severity=warning continues growth, records rationale",
      "severity=info is purely documentary (for QA audit)",
      "priority runs high→low; first matching break wins when combined"
    ]
  },
  "rules": [
    {"id":"PIPE_CS_TO_SS",           "scope":"Piping","priority":95,"severity":"error",  "basis":"ASME B31.3 §331",            "rationale":"Material spec change requires separate WPS, preheat and PWHT regime","break":"material_change", "material_from":["^CS","^A106","^A53"],"material_to":["^SS","^316","^304"]},
    {"id":"PIPE_SCH_CHANGE",         "scope":"Piping","priority":90,"severity":"error",  "basis":"ASME B31.3 §304",            "rationale":"Schedule change mandates WPS variance, fit-up taper","break":"schedule_change"},
    {"id":"PIPE_PRESSURE_CLASS",     "scope":"Piping","priority":92,"severity":"error",  "basis":"ASME B16.5 / B16.47",        "rationale":"Flange/pipe class change (150/300/600) — different bolt + gasket","break":"pressure_class_change"},
    {"id":"PIPE_RF_TO_RTJ",          "scope":"Piping","priority":92,"severity":"error",  "basis":"ASME B16.5 §6.4",            "rationale":"Raised-face to ring-type-joint face finish transition","break":"flange_face_change"},
    {"id":"PIPE_FLANGE_PAIR",        "scope":"Piping","priority":88,"severity":"error",  "basis":"PCF/Isogen convention",      "rationale":"Flange pair is the field-break — always terminate spool","break":"flange_pair"},
    {"id":"PIPE_PREHEAT_TIER",       "scope":"Piping","priority":70,"severity":"warning","basis":"AWS D1.1:2025 Table 5.8",    "rationale":"Weld crosses preheat tier (0/66/107/150 °C by thickness × P-1 chemistry)","break":"preheat_tier_change"},
    {"id":"PIPE_PWHT_PGROUP",        "scope":"Piping","priority":86,"severity":"error",  "basis":"ASME B31.3 §331.1.1",        "rationale":"P-No group change (P1 ↔ P3/4/5) forces PWHT break","break":"p_group_change"},
    {"id":"PIPE_HYDRO_GROUP",        "scope":"Piping","priority":78,"severity":"error",  "basis":"BS EN 13480-5 / B31.3 §345", "rationale":"Spool must fit within one hydrotest envelope (drain + vent reachable)","break":"hydrotest_envelope"},
    {"id":"PIPE_FLUID_SERVICE",      "scope":"Piping","priority":84,"severity":"error",  "basis":"ASME B31.3 §300.2",          "rationale":"Cat D ↔ Normal ↔ Cat M ↔ Severe Cyclic category transition","break":"fluid_service_change"},
    {"id":"PIPE_NDE_EXTENT",         "scope":"Piping","priority":60,"severity":"warning","basis":"ASME B31.3 §341.3.2",         "rationale":"NDE step-up (5 % → 100 % RT) triggers separate pack","break":"nde_step_up"},
    {"id":"PIPE_INSULATION_CLASS",   "scope":"Piping","priority":55,"severity":"warning","basis":"BS EN ISO 12241",            "rationale":"Insulation/jacket type change if shop-applied","break":"insulation_change"},
    {"id":"PIPE_SUPPORT_TYPE",       "scope":"Piping","priority":50,"severity":"warning","basis":"MSS SP-58",                  "rationale":"Rigid clamp ↔ variable spring ↔ guide transition","break":"support_type_change"},
    {"id":"PIPE_LB_SB_LANE",         "scope":"Piping","priority":40,"severity":"info",   "basis":"industry practice",          "rationale":"DN 50 boundary splits large-bore from small-bore shop lane","break":"dn50_boundary"},
    {"id":"PIPE_BRANCH_DN100",       "scope":"Piping","priority":58,"severity":"warning","basis":"BS EN 13480 §8.4",           "rationale":"Branch crosses DN 100 NDT threshold","break":"dn100_nde_boundary"},
    {"id":"DUCT_PRESSURE_CLASS",     "scope":"Ducting","priority":90,"severity":"error",  "basis":"DW/144 / EN 1507",         "rationale":"Pressure class step (A/B/C/D) — different gauge, seam, leakage test","break":"pressure_class_change"},
    {"id":"DUCT_LEAKAGE_CLASS",      "scope":"Ducting","priority":88,"severity":"error",  "basis":"EN 1507 / EN 12237",        "rationale":"Leakage class step (A→D) — different test regime + sealant","break":"leakage_class_change"},
    {"id":"DUCT_SEAM_VS_PRESS",      "scope":"Ducting","priority":82,"severity":"error",  "basis":"SMACNA 4e Ch 2",            "rationale":"Seam type incompatible with pressure class (e.g. Pittsburgh > 2 in.wg.)","break":"seam_pressure_conflict"},
    {"id":"DUCT_GAUGE_VS_DIM",       "scope":"Ducting","priority":80,"severity":"error",  "basis":"SMACNA 4e Table 2-3",       "rationale":"Gauge insufficient for dimension + reinforcement spacing","break":"gauge_dim_conflict"},
    {"id":"DUCT_FIRE_DAMPER",        "scope":"Ducting","priority":94,"severity":"error",  "basis":"NFPA 90A / UL 555",          "rationale":"Fire damper at every fire-rated wall/floor penetration","break":"fire_rated_penetration"},
    {"id":"DUCT_FLEX_CONNECTOR",     "scope":"Ducting","priority":72,"severity":"error",  "basis":"SMACNA 4e §2.9",            "rationale":"Break at every plant equipment connection (AHU, fan, unit)","break":"plant_connection"},
    {"id":"DUCT_ACOUSTIC_LINE",      "scope":"Ducting","priority":50,"severity":"warning","basis":"BESA TR/19 / DW/144",        "rationale":"Internally-lined section needs separate fab lane","break":"acoustic_lining_boundary"},
    {"id":"DUCT_MATERIAL_LANE",      "scope":"Ducting","priority":78,"severity":"error",  "basis":"SMACNA 4e §1.3",            "rationale":"Galvanised ↔ stainless ↔ aluminium per coil line","break":"material_change"},
    {"id":"DUCT_ELBOW_TYPE",         "scope":"Ducting","priority":35,"severity":"info",   "basis":"shop practice",             "rationale":"Radiused ↔ mitred elbow station change","break":"elbow_type_change"},
    {"id":"DUCT_FLANGE_TYPE",        "scope":"Ducting","priority":55,"severity":"warning","basis":"SMACNA 4e §1.16",           "rationale":"TDC ↔ Mez ↔ drive-slip ↔ s-cleat — different assembly jig","break":"flange_type_change"},
    {"id":"CONT_CONDUIT_IMPACT",     "scope":"Electrical","priority":60,"severity":"warning","basis":"BS EN 61386-1",           "rationale":"Impact class change (3↔4 — medium/heavy) across installation zones","break":"impact_class_change"},
    {"id":"CONT_FIRE_PENETRATION",   "scope":"Electrical","priority":94,"severity":"error",  "basis":"BS 7671 §527.2",         "rationale":"Break at every fire-rated compartment; firestop pack per rating","break":"fire_rated_penetration"},
    {"id":"CONT_IS_SEGREGATION",     "scope":"Electrical","priority":88,"severity":"error",  "basis":"BS EN 60079-14",         "rationale":"IS ↔ non-IS partition required — physical break","break":"is_segregation_boundary"},
    {"id":"CONT_DATA_SEGREGATION",   "scope":"Electrical","priority":62,"severity":"warning","basis":"BS EN 50174-2",           "rationale":"Power ↔ data transition per 200/50/30/0 mm matrix","break":"data_power_transition"},
    {"id":"CONT_FIRE_ALARM_CABLE",   "scope":"Electrical","priority":92,"severity":"error",  "basis":"BS 5839-1",              "rationale":"FP200 / MICC shares containment only with like fire-rated cables","break":"fire_alarm_only_containment"},
    {"id":"CONT_TRAY_SPAN",          "scope":"Electrical","priority":74,"severity":"error",  "basis":"BS EN 61537",            "rationale":"Tray span > SWL-derived allowable for cable mass + 20 % margin","break":"tray_span_over_swl"},
    {"id":"CONT_PULL_TENSION",       "scope":"Electrical","priority":76,"severity":"error",  "basis":"Polywater / IEEE 1185",  "rationale":"Cable pull exceeds max tension or 14.6 kN/m sidewall pressure — insert pullbox","break":"pull_tension_over_limit"},
    {"id":"X_TRANSPORT_ENVELOPE",    "scope":"Cross", "priority":98,"severity":"error",  "basis":"UK/EU highway code",        "rationale":"Spool bounding box > 2.44 × 3.0 × 12.0 m requires oversize permit","break":"transport_envelope_breach", "max_w_mm":2440,"max_h_mm":3000,"max_l_mm":12000},
    {"id":"X_HANDLING_TIER",         "scope":"Cross", "priority":66,"severity":"warning","basis":"HSE L23",                    "rationale":"Weight crosses manual/2-man/pallet/forklift/crane tier; assess handling plan","break":"handling_tier_cross",    "tiers_kg":[25,50,500,2000]},
    {"id":"X_HOLDPOINT_B313_341",    "scope":"Piping","priority":68,"severity":"error",  "basis":"ASME B31.3 §341",           "rationale":"QA hold-point sequence (visual → NDE → hydro → PWHT) must complete in order","break":"holdpoint_sequence"},
    {"id":"X_SHIP_PREP",             "scope":"Cross", "priority":20,"severity":"info",   "basis":"industry practice",         "rationale":"Cap open ends / protect RTJ grooves / plywood flange covers","break":"ship_prep_missing"},
    {"id":"X_STOCK_LENGTH_BIAS",     "scope":"Cross", "priority":25,"severity":"info",   "basis":"shop procurement",          "rationale":"Bias spool cuts toward stock-length waste minimisation (pipe 6 m / beam 12 m / strut 3 m)","break":"stock_waste_exceeds_threshold"},
    {"id":"X_LATE_BINDING_SPEC",     "scope":"Cross", "priority":15,"severity":"info",   "basis":"procurement policy",        "rationale":"Spec-change break deferred until procurement commits (late binding)","break":"late_bind_material"},
    {"id":"X_CRITICAL_PATH_PRIORITY","scope":"Cross", "priority":10,"severity":"info",   "basis":"Primavera / MSP milestones","rationale":"First-out spools = longest lead + critical path","break":"priority_bucket"}
  ]
}
