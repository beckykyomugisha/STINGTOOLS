            { "parameter": "ASS_DESIGN_OPTION_TXT", "prefix": "Option:", "suffix": "", "break": false, "style": "BOLD",   "color": "BLUE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_MODEL_REF_TXT",     "prefix": "Ref:",    "suffix": "", "break": false, "style": "BOLD",   "color": "BLUE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_KEYNOTE_TXT",       "prefix": "Key:",    "suffix": "", "break": true,  "style": "BOLD",   "color": "BLUE", "size": 2.0, "enabled": true }
          ]
