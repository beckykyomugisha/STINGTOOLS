{
  "schema_version": "1.0",
  "description": "Switchable default paragraph configurations for Tag Studio > Tokens & Depth. Two built-in presets (Handover / DesignConstruction) plus user-saved Custom presets. Each preset defines T4..T10 rows (parameter + prefix + suffix + formatting). The active preset is written to project_config.json under HANDOVER_MODE.",
  "active_preset": "Handover",
  "presets": {
    "Handover": {
      "display_name": "Handover / FM",
      "description": "Operational focus — commissioning, cost, carbon, fabrication, clash, as-built, compliance. Mirrors the XLSX reference (20260423_sting_tag_config_136_v5_3_T4_T10.xlsx).",
      "readonly": true,
      "source": "XLSX v5.3 universal default",
      "tiers": {
        "T4": {
          "label": "Commissioning & handover",
          "rows": [
            { "parameter": "COMM_STATE_TXT",     "prefix": "Comm:", "suffix": "",  "break": false, "style": "BOLD",   "color": "BLUE",   "size": 2.0, "enabled": true },
            { "parameter": "COMM_DATE_TXT",      "prefix": "on",    "suffix": "",  "break": false, "style": "BOLD",   "color": "BLUE",   "size": 2.0, "enabled": true },
            { "parameter": "COMM_OPERATIVE_TXT", "prefix": "by",    "suffix": "",  "break": true,  "style": "BOLD",   "color": "BLUE",   "size": 2.0, "enabled": true }
          ]
        },
        "T5": {
          "label": "Cost & procurement",
          "rows": [
            { "parameter": "CST_UG_PRICE_UGX",   "prefix": "",       "suffix": "UGX", "break": false, "style": "NOM",    "color": "PURPLE", "size": 2.0, "enabled": true },
            { "parameter": "CST_INTL_PRICE_USD", "prefix": "/",      "suffix": "USD", "break": false, "style": "NOM",    "color": "PURPLE", "size": 2.0, "enabled": true },
            { "parameter": "CST_QUOTE_REF_TXT",  "prefix": "Quote:", "suffix": "",    "break": true,  "style": "NOM",    "color": "PURPLE", "size": 2.0, "enabled": true }
          ]
        },
        "T6": {
          "label": "Carbon & sustainability",
          "rows": [
            { "parameter": "CBN_A1_A3_KG_CO2E",  "prefix": "A1-A3:", "suffix": "kgCO₂e",    "break": false, "style": "ITALIC", "color": "GREEN",  "size": 2.0, "enabled": true },
            { "parameter": "CBN_A4_KG_CO2E",     "prefix": "| A4:",  "suffix": "kgCO₂e",    "break": false, "style": "ITALIC", "color": "GREEN",  "size": 2.0, "enabled": true },
            { "parameter": "CBN_B6_KG_CO2E_YR",  "prefix": "| B6:",  "suffix": "kgCO₂e/yr", "break": true,  "style": "ITALIC", "color": "GREEN",  "size": 2.0, "enabled": true }
          ]
        },
        "T7": {
          "label": "Fabrication & QC",
          "rows": [
            { "parameter": "ASS_SPOOL_NR_TXT",    "prefix": "Spool:", "suffix": "", "break": false, "style": "BOLD", "color": "ORANGE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_FAB_STATUS_TXT",  "prefix": "Fab:",   "suffix": "", "break": false, "style": "BOLD", "color": "ORANGE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_QC_INSPECTOR_TXT","prefix": "QC:",    "suffix": "", "break": true,  "style": "BOLD", "color": "ORANGE", "size": 2.0, "enabled": true }
          ]
        },
        "T8": {
          "label": "Clash & coordination",
          "rows": [
            { "parameter": "CLASH_TRIAGE_SEVERITY_NR",     "prefix": "Sev:", "suffix": "/5", "break": false, "style": "BOLD", "color": "RED", "size": 2.0, "enabled": true },
            { "parameter": "CLASH_TRIAGE_CATEGORY_TXT",    "prefix": "",     "suffix": "",   "break": false, "style": "BOLD", "color": "RED", "size": 2.0, "enabled": true },
            { "parameter": "CLASH_RESOLUTION_STATUS_TXT",  "prefix": "Res:", "suffix": "",   "break": true,  "style": "BOLD", "color": "RED", "size": 2.0, "enabled": true }
          ]
        },
        "T9": {
          "label": "As-built & health",
          "rows": [
            { "parameter": "ASBUILT_DEVIATION_MM",     "prefix": "Δ:",    "suffix": "mm",   "break": false, "style": "ITALIC", "color": "GREY", "size": 2.0, "enabled": true },
            { "parameter": "ASBUILT_CAPTURE_DATE_TXT", "prefix": "on",         "suffix": "",     "break": false, "style": "ITALIC", "color": "GREY", "size": 2.0, "enabled": true },
            { "parameter": "HEALTH_SCORE_LAST_NR",     "prefix": "Health:",    "suffix": "/100", "break": true,  "style": "ITALIC", "color": "GREY", "size": 2.0, "enabled": true }
          ]
        },
        "T10": {
          "label": "Compliance / audit",
          "rows": [
            { "parameter": "IFC_PSET_OVERRIDE_TXT", "prefix": "IFC:",  "suffix": "", "break": false, "style": "NOM", "color": "GREY", "size": 2.0, "enabled": true },
            { "parameter": "ACC_ISSUE_ID_TXT",      "prefix": "ACC:",  "suffix": "", "break": false, "style": "NOM", "color": "GREY", "size": 2.0, "enabled": true },
            { "parameter": "ACC_SYNC_STATUS_TXT",   "prefix": "Sync:", "suffix": "", "break": true,  "style": "NOM", "color": "GREY", "size": 2.0, "enabled": true }
          ]
        }
      }
    },
    "DesignConstruction": {
