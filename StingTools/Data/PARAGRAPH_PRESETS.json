            { "parameter": "CST_INSTALL_HRS",         "prefix": "Hrs:",       "suffix": "h",  "break": false, "style": "BOLD", "color": "ORANGE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_CST_INSTALL_UGX_NR",  "prefix": "@",          "suffix": "UGX", "break": true,  "style": "BOLD", "color": "ORANGE", "size": 2.0, "enabled": true }
