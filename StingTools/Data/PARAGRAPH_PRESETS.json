            { "parameter": "ASS_LVL_COD_TXT",           "prefix": "Lvl:",   "suffix": "",   "break": true,  "style": "BOLD", "color": "RED", "size": 2.0, "enabled": true }
          ]
        },
        "T9": {
          "label": "Warranty & quality",
          "rows": [
            { "parameter": "ASS_WARRANTY_PARTS_TXT", "prefix": "Parts:", "suffix": "",     "break": false, "style": "ITALIC", "color": "GREY", "size": 2.0, "enabled": true },
            { "parameter": "ASS_WARRANTY_LABOR_TXT", "prefix": "Labor:", "suffix": "",     "break": false, "style": "ITALIC", "color": "GREY", "size": 2.0, "enabled": true },
            { "parameter": "ASS_WARRANTY_TXT",       "prefix": "Terms:", "suffix": "",     "break": true,  "style": "ITALIC", "color": "GREY", "size": 2.0, "enabled": true }
