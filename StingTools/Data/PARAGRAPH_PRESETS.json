            { "parameter": "ASS_CAPACITY_TXT",     "prefix": "Cap:",    "suffix": "", "break": false, "style": "NOM", "color": "PURPLE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_POWER_RATING_TXT", "prefix": "Power:",  "suffix": "", "break": false, "style": "NOM", "color": "PURPLE", "size": 2.0, "enabled": true },
            { "parameter": "ASS_FLOW_RATE_TXT",    "prefix": "Flow:",   "suffix": "", "break": true,  "style": "NOM", "color": "PURPLE", "size": 2.0, "enabled": true }
          ]
        },
        "T6": {
          "label": "Material & finish",
          "rows": [
            { "parameter": "ASS_MANUFACTURER_TXT",         "prefix": "Mfr:",    "suffix": "",   "break": false, "style": "ITALIC", "color": "GREEN", "size": 2.0, "enabled": true },
            { "parameter": "ASS_MODEL_NR_TXT",             "prefix": "Model:",  "suffix": "",   "break": false, "style": "ITALIC", "color": "GREEN", "size": 2.0, "enabled": true },
            { "parameter": "ASS_EXPECTED_LIFE_YEARS_YRS",  "prefix": "Life:",   "suffix": "yr", "break": true,  "style": "ITALIC", "color": "GREEN", "size": 2.0, "enabled": true }
