{
  "version": "v1",
  "description": "Maps a DWG MEP fixture BLOCK (and/or its layer) to a STING placement category + an optional type-variant hint, for the DWG->seed->swap bridge (DwgFixtureBridge). A captured DetectedBlock (point + blockName + layerName + coarse InferredCategory) is resolved here to a proper Revit category name; CategoryToSeedRegistry then maps that to the seed, SeedEnsurer builds it, and PlacementHostPreflight places it at the block point. The variant resolves to: this rule's variantHint, else the raw block name tried as a STING type-variant name (STING seeds name each type after its variant, e.g. block 'SOCKET_2G' -> seed type 'SOCKET_2G'), else the seed's default type.",
  "notes": [
    "Rules are evaluated top-to-bottom; first pattern (case-insensitive substring) that matches the blockName OR (when 'match' is 'layer') the layerName wins.",
    "category MUST be a standard Revit category name that CategoryToSeedRegistry maps to a seed and FixturePlacementEngine.ResolveBuiltInCategoryByName resolves to an OST_* category.",
    "anchor seeds PlacementHostPreflight's host search (wall vs ceiling) for the synthetic rule; the block's own point is always the placement location. WALL_MIDPOINT/WALL_FACE_OFFSET -> nearest wall; CEILING_CENTRE -> nearest ceiling; ROOM_CENTRE -> level-based.",
    "categoryFallback handles blocks with no rule match, keyed by the coarse CADToModelEngine InferredCategory.",
    "skipCategories are runs/structure, not fixtures (handled by the duct/pipe/conduit modeller, not this bridge).",
    "Project override: <project>/_BIM_COORD/dwg_symbol_map.json (same shape) is layered over this corporate baseline. Seed/indicative - extend per project."
  ],
  "rules": [
    { "match": "blockName", "pattern": "SOCKET",     "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "SSO",         "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "RCD",         "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "FCU_OUTLET",  "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "SWITCH",      "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "DIMMER",      "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "DOWNLIGHT",   "category": "Lighting Fixtures",      "variantHint": "DOWNLIGHT", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "RECESSED",    "category": "Lighting Fixtures",      "variantHint": "RECESSED_LED_600x600", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "BATTEN",      "category": "Lighting Fixtures",      "variantHint": "BATTEN_LED", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "LINEAR_LED",  "category": "Lighting Fixtures",      "variantHint": "LINEAR_LED", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "LUMIN",       "category": "Lighting Fixtures",      "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "LIGHT",       "category": "Lighting Fixtures",      "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "WIFI",        "category": "Communication Devices",  "variantHint": "WIFI_AP", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "WAP",         "category": "Communication Devices",  "variantHint": "WIFI_AP", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "DATA",        "category": "Data Devices",           "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "RJ45",        "category": "Data Devices",           "variantHint": "DataOutletRJ45", "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "CAT6",        "category": "Data Devices",           "variantHint": "DataOutletCat6A", "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "SMOKE",       "category": "Fire Alarm Devices",     "variantHint": "SMOKE_OPTICAL", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "HEAT_DET",    "category": "Fire Alarm Devices",     "variantHint": "HEAT_DETECTOR", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "DETECTOR",    "category": "Fire Alarm Devices",     "variantHint": "MULTI_SENSOR", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "MCP",         "category": "Fire Alarm Devices",     "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "SOUNDER",     "category": "Fire Alarm Devices",     "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "BEACON",      "category": "Fire Alarm Devices",     "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "SPRINK",      "category": "Sprinklers",             "variantHint": "PENDANT", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "SPK",         "category": "Sprinklers",             "variantHint": "PENDANT", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "DIFFUSER",    "category": "Air Terminals",          "variantHint": "SUPPLY_DIFFUSER_SQ", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "GRILLE",      "category": "Air Terminals",          "variantHint": "SUPPLY_GRILLE", "anchor": "CEILING_CENTRE" },
    { "match": "blockName", "pattern": "WC",          "category": "Plumbing Fixtures",      "variantHint": "WC", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "TOILET",      "category": "Plumbing Fixtures",      "variantHint": "WC", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "URINAL",      "category": "Plumbing Fixtures",      "variantHint": "URINAL", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "BASIN",       "category": "Plumbing Fixtures",      "variantHint": "BASIN", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "LAV",         "category": "Plumbing Fixtures",      "variantHint": "BASIN", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "SINK",        "category": "Plumbing Fixtures",      "variantHint": "SINK", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "SHOWER",      "category": "Plumbing Fixtures",      "variantHint": "SHOWER", "anchor": "WALL_FACE_OFFSET" },
    { "match": "blockName", "pattern": "JB",          "category": "Electrical Equipment",   "anchor": "WALL_MIDPOINT" },
    { "match": "blockName", "pattern": "JUNCTION",    "category": "Electrical Equipment",   "anchor": "WALL_MIDPOINT" },
    { "match": "layer",     "pattern": "lighting",    "category": "Lighting Fixtures",      "anchor": "CEILING_CENTRE" },
    { "match": "layer",     "pattern": "luminaire",   "category": "Lighting Fixtures",      "anchor": "CEILING_CENTRE" },
    { "match": "layer",     "pattern": "socket",      "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "layer",     "pattern": "small power", "category": "Electrical Fixtures",    "anchor": "WALL_MIDPOINT" },
    { "match": "layer",     "pattern": "data outlet", "category": "Data Devices",           "anchor": "WALL_MIDPOINT" },
    { "match": "layer",     "pattern": "sprinkler",   "category": "Sprinklers",             "variantHint": "PENDANT", "anchor": "CEILING_CENTRE" },
    { "match": "layer",     "pattern": "smoke",       "category": "Fire Alarm Devices",     "variantHint": "SMOKE_OPTICAL", "anchor": "CEILING_CENTRE" },
    { "match": "layer",     "pattern": "fire alarm",  "category": "Fire Alarm Devices",     "anchor": "CEILING_CENTRE" },
    { "match": "layer",     "pattern": "sanitary",    "category": "Plumbing Fixtures",      "anchor": "WALL_FACE_OFFSET" },
    { "match": "layer",     "pattern": "diffuser",    "category": "Air Terminals",          "variantHint": "SUPPLY_DIFFUSER_SQ", "anchor": "CEILING_CENTRE" }
  ],
  "categoryFallback": {
    "Electrical":      { "category": "Electrical Fixtures",  "anchor": "WALL_MIDPOINT" },
    "Plumbing":        { "category": "Plumbing Fixtures",    "anchor": "WALL_FACE_OFFSET" },
    "Fire Protection": { "category": "Sprinklers",           "variantHint": "PENDANT", "anchor": "CEILING_CENTRE" },
    "Equipment":       { "category": "Mechanical Equipment", "anchor": "WALL_MIDPOINT" }
  },
  "_fixtureCategoriesNote": "AUTHORITATIVE ALLOWLIST: the bridge ONLY places these (MEP/fixture) categories. Any rule/fallback/auto-inference that resolves to a category NOT in this list returns null (not a fixture) - so Doors/Windows/Furniture/Structural/annotation layers are never auto-mapped or placed. Every entry must resolve to a seed via STING_CATEGORY_TO_SEED_MAP.json. Projects extend (union) this via the _BIM_COORD/dwg_symbol_map.json override.",
  "fixtureCategories": [
    "Lighting Fixtures",
    "Lighting Devices",
    "Electrical Fixtures",
    "Electrical Equipment",
    "Junction Boxes",
    "Communication Devices",
    "Data Devices",
    "Telephone Devices",
    "Security Devices",
    "Nurse Call Devices",
    "Fire Alarm Devices",
    "Fire Protection",
    "Sprinklers",
    "Air Terminals",
    "Mechanical Equipment",
    "Mechanical Control Devices",
    "Duct Accessories",
    "Plumbing Fixtures",
    "Plumbing Equipment",
    "Specialty Equipment"
  ],
  "skipCategories": [ "Ducts", "Pipes", "Conduits", "Columns", "Walls", "Doors", "Windows", "Furniture", "Casework", "Stairs", "Generic Models", "Parking" ]
}
