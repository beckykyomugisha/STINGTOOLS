        { "familyNamePattern": "(?i)nullifire",               "label": "Nullifire firestop",         "priority": 20 },
        { "familyNamePattern": "(?i)rockwool.*firestop",      "label": "Rockwool firestop",          "priority": 25 },
        { "familyNamePattern": "(?i)frp.*penetration",        "label": "Generic FRP penetration",    "priority": 50 },
        { "familyNamePattern": "(?i)sleeve",                  "label": "Sleeve",                     "priority": 60 }
