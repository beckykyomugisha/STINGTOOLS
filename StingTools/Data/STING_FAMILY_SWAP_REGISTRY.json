        { "familyNamePattern": "(?i)chiller",                 "label": "Chiller",                    "priority": 30 },
        { "familyNamePattern": "(?i)boiler",                  "label": "Boiler",                     "priority": 40 },
        { "familyNamePattern": "(?i)pump",                    "label": "Pump",                       "priority": 50 }
