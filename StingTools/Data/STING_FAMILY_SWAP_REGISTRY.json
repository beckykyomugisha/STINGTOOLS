      "category": "Communication Devices",
      "candidates": [
        { "familyNamePattern": "(?i)wifi|access.*point|wap",  "label": "Wi-Fi access point",         "priority": 10 },
        { "familyNamePattern": "(?i)data.*outlet|rj45",       "label": "Data outlet (RJ45)",         "priority": 20 },
        { "familyNamePattern": "(?i)patch.*panel",            "label": "Patch panel",                "priority": 30 },
        { "familyNamePattern": "(?i)cctv|camera",             "label": "CCTV camera",                "priority": 40 }
