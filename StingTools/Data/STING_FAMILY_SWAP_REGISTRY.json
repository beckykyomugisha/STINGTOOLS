        { "familyNamePattern": "(?i)urinal",                  "label": "Urinal",                     "priority": 30 },
        { "familyNamePattern": "(?i)shower",                  "label": "Shower",                     "priority": 40 },
        { "familyNamePattern": "(?i)sink",                    "label": "Sink",                       "priority": 50 }
