    {
      "seedId": "STING_SEED_Sprinkler",
      "category": "Sprinklers",
      "candidates": [
        { "familyNamePattern": "(?i)pendant",                 "label": "Pendant sprinkler",          "priority": 10 },
        { "familyNamePattern": "(?i)upright",                 "label": "Upright sprinkler",          "priority": 20 },
        { "familyNamePattern": "(?i)sidewall",                "label": "Sidewall sprinkler",         "priority": 30 },
        { "familyNamePattern": "(?i)concealed",               "label": "Concealed sprinkler",        "priority": 40 }
