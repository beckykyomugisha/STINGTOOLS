{
  "version": "1.0",
  "_notes": [
    "Maps STING seed-family identifiers to candidate manufacturer",
    "replacements. SwapToManufacturerCommand reads STING_SEED_FAMILY_TXT",
    "from each selected instance, looks up matching candidates here, and",
    "presents them for the user to pick.",
    "",
    "MatchRules — each candidate's familyNamePattern (regex) is matched",
    "against loaded Family.Name in the project. Multiple matches are",
    "ranked by Priority (lower = preferred); ties broken by typeNamePattern.",
    "",
    "Project teams override this corporate baseline by dropping",
    "<project>/_BIM_COORD/family_swap_registry.json — entries are merged,",
    "project values win on collision."
  ],
  "seeds": [
    {
      "seedId": "STING_SEED_LightingFixture",
      "category": "Lighting Fixtures",
      "candidates": [
        { "familyNamePattern": "(?i)recessed.*led.*600",     "label": "600x600 LED panel",          "priority": 10 },
        { "familyNamePattern": "(?i)downlight",              "label": "Downlight",                  "priority": 20 },
        { "familyNamePattern": "(?i)pendant",                "label": "Pendant luminaire",          "priority": 30 },
        { "familyNamePattern": "(?i)linear.*led",            "label": "Linear LED",                 "priority": 40 },
        { "familyNamePattern": "(?i)emergency",              "label": "Emergency luminaire",        "priority": 50 }
      ]
    },
    {
      "seedId": "STING_SEED_ElectricalFixture",
      "category": "Electrical Fixtures",
      "candidates": [
        { "familyNamePattern": "(?i)socket.*(2|two|double)",  "label": "2-gang socket",              "priority": 10 },
        { "familyNamePattern": "(?i)socket.*(1|one|single)",  "label": "1-gang socket",              "priority": 20 },
        { "familyNamePattern": "(?i)switch.*(2|two)",         "label": "2-gang switch",              "priority": 30 },
        { "familyNamePattern": "(?i)data.*outlet",            "label": "Data outlet",                "priority": 40 },
        { "familyNamePattern": "(?i)floor.*box",              "label": "Floor box",                  "priority": 50 },
        { "familyNamePattern": "(?i)fcu",                     "label": "Fused connection unit",      "priority": 60 }
      ]
    },
    {
      "seedId": "STING_SEED_ElectricalEquipment",
      "category": "Electrical Equipment",
      "candidates": [
        { "familyNamePattern": "(?i)distribution.*board",     "label": "Distribution board (DB)",    "priority": 10 },
        { "familyNamePattern": "(?i)main.*switch.*board",     "label": "Main switchboard (MSB)",     "priority": 20 },
        { "familyNamePattern": "(?i)consumer.*unit",          "label": "Consumer unit",              "priority": 30 },
        { "familyNamePattern": "(?i)isolator",                "label": "Isolator",                   "priority": 40 },
        { "familyNamePattern": "(?i)junction.*box|j-?box",    "label": "Junction box",               "priority": 50 },
        { "familyNamePattern": "(?i)transformer",             "label": "Transformer",                "priority": 60 }
      ]
    },
    {
      "seedId": "STING_SEED_FireAlarmDevice",
      "category": "Fire Alarm Devices",
      "candidates": [
        { "familyNamePattern": "(?i)smoke.*(detector|optical)",  "label": "Optical smoke detector",  "priority": 10 },
        { "familyNamePattern": "(?i)heat.*detector",             "label": "Heat detector",           "priority": 20 },
        { "familyNamePattern": "(?i)multi.*sensor",              "label": "Multi-sensor",            "priority": 30 },
        { "familyNamePattern": "(?i)call.*point|mcp",            "label": "Manual call point",       "priority": 40 },
        { "familyNamePattern": "(?i)sounder.*beacon|vad",        "label": "Sounder/beacon (VAD)",    "priority": 50 },
        { "familyNamePattern": "(?i)beam.*detector",             "label": "Beam detector",           "priority": 60 }
      ]
    },
    {
      "seedId": "STING_SEED_SpecialityEquipment",
      "category": "Specialty Equipment",
      "candidates": [
        { "familyNamePattern": "(?i)hilti.*(cfs|frp)",        "label": "Hilti firestop",             "priority": 10 },
