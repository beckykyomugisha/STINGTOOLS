{
  "version": "1.0",
  "description": "STING LOD verification matrix. Corporate baseline; merged by id over a project overlay at <project>/_BIM_COORD/lod_matrix.json (project milestones/categoryRules win by id/category). Checks are a PARAMETER + NAMING + GEOMETRY-PRESENCE maturity proxy, NOT a geometric survey — STING cannot verify that geometry is dimensionally correct, only that it exists, is not a placeholder family, and carries the parameters expected at that LOD. Per-LOD check fields: requireGeometry (non-degenerate bbox), forbidPlaceholderFamilies (family/type name must not match placeholderFamilyPatterns), requiredParams (shared param present + non-empty; '+name' adds to the inherited list, a plain name replaces it), requiredDims (numeric shared param resolves > 0), requireTypeNotGeneric (type/family name must not contain 'generic'), requireManufacturerType (type+family name must not match a placeholder pattern — manufacturer-specified proxy), requireNoUnresolvedClash (NOT API-verifiable — reported as an INFO limitation, never a hard fail), inherit (LOD key to inherit checks from).",
  "milestones": [
    { "id": "deliverable-a", "name": "Deliverable A (Basis of Design)", "lod": 200 },
    { "id": "deliverable-b", "name": "Deliverable B (50% documentation)", "lod": 300 },
    { "id": "deliverable-c", "name": "Deliverable C (100% documentation)", "lod": 350 },
    { "id": "conformed-set", "name": "Conformed set", "lod": 350 },
    { "id": "deliverable-d", "name": "Deliverable D (record model)", "lod": 400 }
  ],
  "placeholderFamilyPatterns": [
    "(?i)generic",
    "(?i)placeholder",
    "(?i)^STING_SEED_",
    "(?i)\\bTBD\\b",
    "(?i)\\bdummy\\b",
    "(?i)\\bdefault\\b"
  ],
