{
  "schemaVersion": 2,
  "name": "STING — Title-block family library",
  "description": "Generator spec for STING title-block .rfa families. Phase 170 revision (two-family BIM architecture): each paper size ships TWO families — STING_TB_<SIZE>_BIM_v* and STING_TB_<SIZE>_NONBIM_v*. Both inherit from a per-size abstract `<SIZE>_common_v*` base via the `extends` field so identity-data cells, slots, common labels and parameters are authored once. The legacy hybrid (single family + BIM_MODE_BOOL toggle + reflow groups + label pairs) is removed.",
  "lastUpdated": "2026-05-01",
  "families": [

    {
