{
  "_comment": "STING_VARIATION_LIABILITY_MAP.json — Phase 184p. Per-contract liability defaults that override the hard-coded reason→liability suggestion in Variation_FromDiff. Project overrides live in <project>/_BIM_COORD/variation_liability_map.json with the same shape.",
  "version": "1.0",
  "_documentation": {
    "lookup": "key = '<ContractForm>|<Reason>'. First exact match wins; falls back to 'default|<Reason>' then to the C# SuggestLiability table.",
    "valid_contract_forms": ["JCT2016", "JCT2024", "NEC4", "FIDIC2017Red", "FIDIC2017Yellow", "FIDIC2017Silver", "GC-Works", "Bespoke", "default"],
    "valid_liabilities": ["Employer", "Contractor", "Designer", "Shared", "ForceMajeure"]
  },
  "rules": {
    "JCT2024|DesignChange": "Designer",
    "JCT2024|ErrorOmission": "Designer",
    "JCT2024|ClientRequest": "Employer",
    "JCT2024|SiteCondition": "Employer",
    "JCT2024|StatutoryChange": "Employer",
    "JCT2024|ContractorProposal": "Shared",
    "JCT2024|ScopeAddition": "Employer",
    "JCT2024|ScopeOmission": "Employer",
    "JCT2024|Specification": "Employer",
    "JCT2024|Quality": "Employer",
    "JCT2024|ProgrammeChange": "Employer",

    "NEC4|DesignChange": "Designer",
    "NEC4|ErrorOmission": "Designer",
    "NEC4|ClientRequest": "Employer",
    "NEC4|SiteCondition": "Employer",
    "NEC4|StatutoryChange": "Employer",
    "NEC4|ContractorProposal": "Shared",
    "NEC4|ScopeAddition": "Employer",
    "NEC4|ScopeOmission": "Employer",
    "NEC4|ProgrammeChange": "Employer",

    "FIDIC2017Red|DesignChange": "Designer",
    "FIDIC2017Red|ErrorOmission": "Designer",
    "FIDIC2017Red|SiteCondition": "Employer",
    "FIDIC2017Red|ClientRequest": "Employer",
    "FIDIC2017Red|StatutoryChange": "Employer",
    "FIDIC2017Red|ContractorProposal": "Shared",
    "FIDIC2017Red|ScopeAddition": "Employer",
    "FIDIC2017Red|ScopeOmission": "Employer",
    "FIDIC2017Red|ProgrammeChange": "Employer",

    "_FIDIC2017Yellow_note": "Yellow Book = contractor-design. ErrorOmission lands on Contractor by default because the contractor owns the design risk.",
    "FIDIC2017Yellow|DesignChange": "Contractor",
    "FIDIC2017Yellow|ErrorOmission": "Contractor",
    "FIDIC2017Yellow|Specification": "Contractor",
    "FIDIC2017Yellow|Quality": "Contractor",
    "FIDIC2017Yellow|SiteCondition": "Employer",
    "FIDIC2017Yellow|ClientRequest": "Employer",
    "FIDIC2017Yellow|StatutoryChange": "Employer",
    "FIDIC2017Yellow|ContractorProposal": "Contractor",
    "FIDIC2017Yellow|ScopeAddition": "Employer",
    "FIDIC2017Yellow|ScopeOmission": "Employer",
    "FIDIC2017Yellow|ProgrammeChange": "Employer",

    "_FIDIC2017Silver_note": "Silver Book = EPC. Contractor owns nearly everything except employer-instructed scope changes and a narrow set of carve-outs (war, change in law, etc.).",
    "FIDIC2017Silver|DesignChange": "Contractor",
    "FIDIC2017Silver|ErrorOmission": "Contractor",
    "FIDIC2017Silver|SiteCondition": "Contractor",
    "FIDIC2017Silver|Specification": "Contractor",
    "FIDIC2017Silver|Quality": "Contractor",
    "FIDIC2017Silver|ProgrammeChange": "Contractor",
    "FIDIC2017Silver|ClientRequest": "Employer",
    "FIDIC2017Silver|StatutoryChange": "Employer",
    "FIDIC2017Silver|ScopeAddition": "Employer",
    "FIDIC2017Silver|ScopeOmission": "Employer",

    "default|DesignChange": "Designer",
