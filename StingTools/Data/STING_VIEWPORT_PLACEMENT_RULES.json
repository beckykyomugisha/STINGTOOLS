{
  "schemaVersion": 1,
  "name": "STING — Viewport placement rules",
  "description": "Maps a (Revit ViewType, view-name pattern, optional discipline) tuple to a slot purposeTag declared in STING_TITLE_BLOCKS.json. TitleBlock_AutoPlaceViewports walks this rule list top-to-bottom for each selected view; the first matching rule wins, and the view is placed at the slot whose purposeTag matches. If no rule matches, the view falls through to the `defaultPurposeTag` slot.",
  "lastUpdated": "2026-05-01",

  "defaultPurposeTag": "main-plan",
  "noMatchBehaviour": "place-at-default-with-warning",

  "rules": [
    { "viewType": "FloorPlan",       "namePattern": "*KEY*",           "purposeTag": "key-plan" },
    { "viewType": "FloorPlan",       "namePattern": "*AERIAL*",        "purposeTag": "aerial-key" },
    { "viewType": "FloorPlan",       "namePattern": "*CONTEXT*",       "purposeTag": "aerial-key" },
    { "viewType": "FloorPlan",       "namePattern": "*MARKUP*",        "purposeTag": "markup-plan" },
    { "viewType": "FloorPlan",       "namePattern": "*-PL-*",          "purposeTag": "main-plan" },
    { "viewType": "FloorPlan",       "namePattern": "*PLAN*",          "purposeTag": "main-plan" },
    { "viewType": "FloorPlan",       "namePattern": "*",               "purposeTag": "main-plan" },

    { "viewType": "CeilingPlan",     "namePattern": "*RCP*",           "purposeTag": "main-plan" },
    { "viewType": "CeilingPlan",     "namePattern": "*",               "purposeTag": "main-plan" },

    { "viewType": "Section",         "namePattern": "*WALL*",          "purposeTag": "section" },
    { "viewType": "Section",         "namePattern": "*",               "purposeTag": "section" },

    { "viewType": "Elevation",       "namePattern": "*INTERIOR*",      "purposeTag": "elevation" },
    { "viewType": "Elevation",       "namePattern": "*",               "purposeTag": "elevation" },

    { "viewType": "ThreeD",          "namePattern": "*AXON*",          "purposeTag": "axon" },
    { "viewType": "ThreeD",          "namePattern": "*PERSP*",         "purposeTag": "presentation-perspective" },
    { "viewType": "ThreeD",          "namePattern": "*RENDER*",        "purposeTag": "presentation-render" },
    { "viewType": "ThreeD",          "namePattern": "*",               "purposeTag": "axon" },

    { "viewType": "DraftingView",    "namePattern": "*FAB*ISO*",       "purposeTag": "fabrication-isometric" },
    { "viewType": "DraftingView",    "namePattern": "*RFI*Q*",         "purposeTag": "rfi-query" },
    { "viewType": "DraftingView",    "namePattern": "*RFI*S*",         "purposeTag": "rfi-sketch" },
    { "viewType": "DraftingView",    "namePattern": "*MARKUP*",        "purposeTag": "markup-plan" },
    { "viewType": "DraftingView",    "namePattern": "*DETAIL*",        "purposeTag": "detail" },
    { "viewType": "DraftingView",    "namePattern": "*",               "purposeTag": "detail" },

    { "viewType": "Legend",          "namePattern": "*NOTES*",         "purposeTag": "notes" },
    { "viewType": "Legend",          "namePattern": "*FIRE*",          "purposeTag": "fire-legend" },
    { "viewType": "Legend",          "namePattern": "*FALLS*",         "purposeTag": "falls-legend" },
    { "viewType": "Legend",          "namePattern": "*MATERIAL*",      "purposeTag": "material-legend" },
    { "viewType": "Legend",          "namePattern": "*ACCESS*",        "purposeTag": "accessibility-legend" },
    { "viewType": "Legend",          "namePattern": "*PART*M*",        "purposeTag": "accessibility-legend" },
    { "viewType": "Legend",          "namePattern": "*LIGHT*",         "purposeTag": "lighting-legend" },
    { "viewType": "Legend",          "namePattern": "*LUMINAIRE*",     "purposeTag": "lighting-legend" },
    { "viewType": "Legend",          "namePattern": "*KEY*PLAN*",      "purposeTag": "key-plan" },
    { "viewType": "Legend",          "namePattern": "*CAPTION*",       "purposeTag": "caption" },
    { "viewType": "Legend",          "namePattern": "*",               "purposeTag": "discipline-legend" },

    { "viewType": "Schedule",        "namePattern": "*BOM*",           "purposeTag": "bom" },
    { "viewType": "Schedule",        "namePattern": "*BILL*",          "purposeTag": "bom" },
    { "viewType": "Schedule",        "namePattern": "*CUT*LIST*",      "purposeTag": "cut-list" },
    { "viewType": "Schedule",        "namePattern": "*REVISION*",      "purposeTag": "revision-history" },
    { "viewType": "Schedule",        "namePattern": "*REV*HIST*",      "purposeTag": "revision-history" },
    { "viewType": "Schedule",        "namePattern": "*REGISTER*",      "purposeTag": "schedule" },
    { "viewType": "Schedule",        "namePattern": "*SHEET*LIST*",    "purposeTag": "schedule" },
    { "viewType": "Schedule",        "namePattern": "*",               "purposeTag": "schedule" },

    { "viewType": "AreaPlan",        "namePattern": "*",               "purposeTag": "main-plan" },
    { "viewType": "EngineeringPlan", "namePattern": "*",               "purposeTag": "main-plan" }
  ],

  "purposeTagAliases": {
    "main-plan-half-left":  ["main-plan"],
    "main-plan-half-right": ["main-plan"],
    "quad-top-left":        ["main-plan", "detail"],
    "quad-top-right":       ["main-plan", "detail"],
    "quad-bottom-left":     ["main-plan", "detail"],
    "quad-bottom-right":    ["main-plan", "detail"],
    "aerial-key":           ["key-plan"],
    "fire-legend":          ["discipline-legend"],
    "falls-legend":         ["discipline-legend"],
    "material-legend":      ["discipline-legend"],
    "accessibility-legend": ["discipline-legend"],
    "lighting-legend":      ["discipline-legend"],
    "bom":                  ["schedule"],
    "cut-list":             ["schedule"],
    "spool-refs":           ["notes"],
    "presentation-perspective": ["presentation-render", "axon"],
    "rfi-query":            ["notes"],
    "rfi-sketch":           ["main-plan", "detail"],
    "markup-plan":          ["main-plan"],
    "regulator-stamp":      ["caption"],
    "recipient-to":         ["notes"],
    "recipient-from":       ["notes"],
    "discipline-band":      ["main-plan"]
  }
}
