      "origin": "corporate",
      "viewTemplate": "STING - Architectural Plan",
      "detailLevel": "Medium",
      "scaleHint": "1:100",
      "colorScheme": "Monochrome",
      "vgOverrides": {
        "Walls":                  { "visible": true, "halftone": false, "projColor": "#000000", "projWeight": 5, "cutColor": "#000000", "cutWeight": 5 },
        "Doors":                  { "visible": true, "projColor": "#000000", "projWeight": 2 },
        "Windows":                { "visible": true, "projColor": "#000000", "projWeight": 2 },
        "Floors":                 { "visible": true, "halftone": true,  "projColor": "#808080", "projWeight": 1 },
        "Ceilings":               { "visible": false },
        "Structural Columns":     { "visible": true, "projColor": "#000000", "projWeight": 5, "cutColor": "#000000", "cutWeight": 5 },
        "Structural Framing":     { "visible": true, "projColor": "#000000", "projWeight": 3 },
        "Rooms":                  { "visible": true, "projColor": "#1976D2", "projWeight": 1, "transparency": 80 },
        "Furniture":              { "visible": true, "projColor": "#666666", "projWeight": 1 },
        "Casework":               { "visible": true, "projColor": "#666666", "projWeight": 1 },
        "Stairs":                 { "visible": true, "projColor": "#000000", "projWeight": 2 },
        "Railings":               { "visible": true, "projColor": "#000000", "projWeight": 1 },
        "Curtain Panels":         { "visible": true, "projColor": "#000000", "projWeight": 2 },
        "Curtain Wall Mullions":  { "visible": true, "projColor": "#000000", "projWeight": 2 },
        "Grids":                  { "visible": true, "halftone": false, "projColor": "#808080", "projWeight": 3 },
        "Mechanical Equipment":   { "visible": true, "halftone": true,  "projColor": "#808080", "projWeight": 1 },
        "Electrical Equipment":   { "visible": true, "halftone": true,  "projColor": "#808080", "projWeight": 1 },
        "Plumbing Fixtures":      { "visible": true, "halftone": true,  "projColor": "#808080", "projWeight": 1 },
        "Pipes":                  { "visible": false },
        "Ducts":                  { "visible": false }
      }
    },
    {
