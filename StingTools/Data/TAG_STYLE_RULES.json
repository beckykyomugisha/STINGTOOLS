      { "name": "2.5ITALIC_GREEN",  "size": 2.5, "weight": "ITALIC", "color": "GREEN" },
      { "name": "2.5ITALIC_RED",    "size": 2.5, "weight": "ITALIC", "color": "RED" },
      { "name": "3.5NOM_BLACK",     "size": 3.5, "weight": "NOM",    "color": "BLACK" },
      { "name": "3.5NOM_BLUE",      "size": 3.5, "weight": "NOM",    "color": "BLUE" },
      { "name": "3.5NOM_GREEN",     "size": 3.5, "weight": "NOM",    "color": "GREEN" },
