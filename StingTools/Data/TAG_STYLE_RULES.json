  "presets": {
    "Discipline": {
      "description": "Color-code tags by discipline — M=Blue, E=Red, P=Green, A=Black, S=Orange, FP=Red, LV=Purple, G=Grey",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M" },  "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "A" },  "tag_type": "2NOM_BLACK" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "S" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "FP" }, "tag_type": "2BOLDITALIC_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "LV" }, "tag_type": "2ITALIC_PURPLE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "G" },  "tag_type": "2NOM_GREY" }
      ]
    },

    "QA Check": {
      "description": "Compliance — complete=green, partial=bold orange, missing=large bold red",
      "default_type": "3.5BOLD_RED",
      "rules": [
        { "conditions": { "_tag_complete": "true" },   "tag_type": "2NOM_GREEN" },
        { "conditions": { "_tag_complete": "partial" }, "tag_type": "2BOLD_ORANGE" }
      ]
    },

    "Presentation": {
      "description": "Clean black-on-white for client presentation — all tags uniform",
      "default_type": "2.5NOM_BLACK",
      "rules": []
    },

    "Print": {
      "description": "Monochrome for printing — all tags standard black",
      "default_type": "2NOM_BLACK",
      "rules": []
    },

    "Large Format": {
      "description": "Larger text for A0/A1 sheets — 3.5mm with discipline colors",
      "default_type": "3.5NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M" },  "tag_type": "3.5BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E" },  "tag_type": "3.5BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P" },  "tag_type": "3.5BOLD_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "S" },  "tag_type": "3.5BOLD_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "FP" }, "tag_type": "3.5BOLDITALIC_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "LV" }, "tag_type": "3.5ITALIC_PURPLE" }
      ]
    },

    "Status": {
      "description": "Color by element status — new=bold blue, existing=grey, demolished=bold italic red, temporary=italic orange",
      "default_type": "2NOM_GREY",
      "rules": [
        { "conditions": { "ASS_STATUS_TXT": "NEW" },        "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_STATUS_TXT": "EXISTING" },   "tag_type": "2NOM_GREY" },
        { "conditions": { "ASS_STATUS_TXT": "DEMOLISHED" },  "tag_type": "2BOLDITALIC_RED" },
        { "conditions": { "ASS_STATUS_TXT": "TEMPORARY" },   "tag_type": "2ITALIC_ORANGE" }
      ]
    },

    "System": {
      "description": "Color by MEP system type — unique color per system",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "HVAC" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "DCW" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "DHW" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "HWS" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "SAN" },  "tag_type": "2NOM_GREEN" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "RWD" },  "tag_type": "2NOM_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "GAS" },  "tag_type": "2BOLDITALIC_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "FP" },   "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "LV" },   "tag_type": "2ITALIC_PURPLE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "FLS" },  "tag_type": "2ITALIC_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "PWR" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "LTG" },  "tag_type": "2ITALIC_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "COM" },  "tag_type": "2NOM_PURPLE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "ICT" },  "tag_type": "2NOM_PURPLE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "SEC" },  "tag_type": "2ITALIC_ORANGE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "NCL" },  "tag_type": "2ITALIC_GREY" }
      ]
    },

    "Zone Highlight": {
      "description": "Color by zone for spatial coordination — each zone a distinct color",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_ZONE_TXT": "Z01" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_ZONE_TXT": "Z02" }, "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_ZONE_TXT": "Z03" }, "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_ZONE_TXT": "Z04" }, "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_ZONE_TXT": "ZZ" },  "tag_type": "2NOM_GREY" },
        { "conditions": { "ASS_ZONE_TXT": "XX" },  "tag_type": "2ITALIC_GREY" }
      ]
    },

    "Stale": {
      "description": "GAP-STYLE-01: Highlight stale elements — stale=italic grey, non-stale=normal black. Pair with SelectStale to quickly locate geometry-changed assets.",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "STING_STALE_BOOL": "1" }, "tag_type": "2ITALIC_GREY" }
      ]
    },

    "Revision": {
      "description": "Color by revision code — useful on issue sheets to show what changed this revision. P01=blue, P02=green, C01=orange, S-series=purple.",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_REVISION_TXT": "P01" }, "tag_type": "2NOM_BLUE" },
        { "conditions": { "ASS_REVISION_TXT": "P02" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_REVISION_TXT": "P03" }, "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_REVISION_TXT": "C01" }, "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_REVISION_TXT": "C02" }, "tag_type": "2BOLDITALIC_ORANGE" },
        { "conditions": { "ASS_REVISION_TXT": "S01" }, "tag_type": "2ITALIC_PURPLE" },
        { "conditions": { "ASS_REVISION_TXT": "S02" }, "tag_type": "2BOLD_PURPLE" }
      ]
    },

    "Level": {
      "description": "Color by level code — useful for multi-storey coordination where elements on different floors share a plan view.",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_LVL_COD_TXT": "B2" },  "tag_type": "2BOLD_PURPLE" },
        { "conditions": { "ASS_LVL_COD_TXT": "B1" },  "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_LVL_COD_TXT": "GF" },  "tag_type": "2NOM_BLACK" },
        { "conditions": { "ASS_LVL_COD_TXT": "L01" }, "tag_type": "2NOM_GREEN" },
        { "conditions": { "ASS_LVL_COD_TXT": "L02" }, "tag_type": "2NOM_BLUE" },
        { "conditions": { "ASS_LVL_COD_TXT": "L03" }, "tag_type": "2NOM_ORANGE" },
        { "conditions": { "ASS_LVL_COD_TXT": "L04" }, "tag_type": "2NOM_RED" },
        { "conditions": { "ASS_LVL_COD_TXT": "L05" }, "tag_type": "2NOM_PURPLE" },
        { "conditions": { "ASS_LVL_COD_TXT": "RF" },  "tag_type": "2ITALIC_GREY" }
      ]
    },

    "Location": {
      "description": "Color by building / location code — BLD1=blue, BLD2=green, BLD3=orange, EXT=red. Helps multi-block site coordination.",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_LOC_TXT": "BLD1" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_LOC_TXT": "BLD2" }, "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_LOC_TXT": "BLD3" }, "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_LOC_TXT": "EXT" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_LOC_TXT": "XX" },   "tag_type": "2ITALIC_GREY" }
      ]
    },

    "Completeness QA": {
      "description": "GAP-STYLE-01: Three-tier completeness — fully tagged=small green, partially tagged=medium bold orange, untagged=large bold red. Use as permanent QA overlay.",
      "default_type": "3.5BOLD_RED",
      "rules": [
        { "conditions": { "_tag_complete": "true" },    "tag_type": "1.5NOM_GREEN" },
        { "conditions": { "_tag_complete": "partial" }, "tag_type": "2BOLD_ORANGE" }
      ]
    },

    "Discipline + System": {
      "description": "Multi-condition: combine discipline and system for fine-grained differentiation. HVAC supply=bold blue, HVAC return=italic blue, DCW=green, DHW=orange, LV power=yellow-bold, LV lighting=italic orange.",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M", "ASS_SYSTEM_TYPE_TXT": "HVAC", "ASS_FUNC_TXT": "SUP" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M", "ASS_SYSTEM_TYPE_TXT": "HVAC", "ASS_FUNC_TXT": "RTN" }, "tag_type": "2ITALIC_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M", "ASS_SYSTEM_TYPE_TXT": "HVAC", "ASS_FUNC_TXT": "EXH" }, "tag_type": "2BOLDITALIC_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M", "ASS_SYSTEM_TYPE_TXT": "HWS" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P", "ASS_SYSTEM_TYPE_TXT": "DCW" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P", "ASS_SYSTEM_TYPE_TXT": "DHW" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P", "ASS_SYSTEM_TYPE_TXT": "SAN" },  "tag_type": "2ITALIC_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E", "ASS_FUNC_TXT": "PWR" },         "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E", "ASS_FUNC_TXT": "LTG" },         "tag_type": "2ITALIC_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "FP" },                                "tag_type": "2BOLDITALIC_RED" }
      ]
    },

    "Auto-Tagger Audit": {
      "description": "GAP-AT-02: Distinguish auto-tagged elements from manually tagged — [AUTO_TAGGER] modifier=italic grey, normal user=bold black, no modifier=normal black.",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_TAG_MODIFIED_BY_TXT": "[AUTO_TAGGER]*" }, "tag_type": "2ITALIC_GREY" },
        { "conditions": { "_tag_complete": "true" }, "tag_type": "2BOLD_BLACK" }
      ]
    }
  }
}
