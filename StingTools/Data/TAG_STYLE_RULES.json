  "presets": {
    "Discipline": {
      "description": "Color-code tags by discipline — M=Blue, E=Red, P=Green, A=Black, S=Orange, FP=Red, LV=Purple, G=Grey",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M" },  "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "A" },  "tag_type": "2NOM_BLACK" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "S" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "FP" }, "tag_type": "2BOLDITALIC_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "LV" }, "tag_type": "2ITALIC_PURPLE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "G" },  "tag_type": "2NOM_GREY" }
      ]
    },

    "QA Check": {
      "description": "Compliance — complete=green, partial=bold orange, missing=large bold red",
      "default_type": "3.5BOLD_RED",
      "rules": [
        { "conditions": { "_tag_complete": "true" },   "tag_type": "2NOM_GREEN" },
        { "conditions": { "_tag_complete": "partial" }, "tag_type": "2BOLD_ORANGE" }
      ]
    },

    "Presentation": {
      "description": "Clean black-on-white for client presentation — all tags uniform",
      "default_type": "2.5NOM_BLACK",
      "rules": []
    },

    "Print": {
      "description": "Monochrome for printing — all tags standard black",
      "default_type": "2NOM_BLACK",
      "rules": []
    },

    "Large Format": {
      "description": "Larger text for A0/A1 sheets — 3.5mm with discipline colors",
      "default_type": "3.5NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M" },  "tag_type": "3.5BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E" },  "tag_type": "3.5BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P" },  "tag_type": "3.5BOLD_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "S" },  "tag_type": "3.5BOLD_ORANGE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "FP" }, "tag_type": "3.5BOLDITALIC_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "LV" }, "tag_type": "3.5ITALIC_PURPLE" }
      ]
    },

    "Status": {
      "description": "Color by element status — new=bold blue, existing=grey, demolished=bold italic red, temporary=italic orange",
      "default_type": "2NOM_GREY",
      "rules": [
        { "conditions": { "ASS_STATUS_TXT": "NEW" },        "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_STATUS_TXT": "EXISTING" },   "tag_type": "2NOM_GREY" },
        { "conditions": { "ASS_STATUS_TXT": "DEMOLISHED" },  "tag_type": "2BOLDITALIC_RED" },
        { "conditions": { "ASS_STATUS_TXT": "TEMPORARY" },   "tag_type": "2ITALIC_ORANGE" }
      ]
    },

    "System": {
      "description": "Color by MEP system type — unique color per system",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "HVAC" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "DCW" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "DHW" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "HWS" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "SAN" },  "tag_type": "2NOM_GREEN" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "RWD" },  "tag_type": "2NOM_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "GAS" },  "tag_type": "2BOLDITALIC_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "FP" },   "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "LV" },   "tag_type": "2ITALIC_PURPLE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "FLS" },  "tag_type": "2ITALIC_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "PWR" },  "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "LTG" },  "tag_type": "2ITALIC_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "COM" },  "tag_type": "2NOM_PURPLE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "ICT" },  "tag_type": "2NOM_PURPLE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "SEC" },  "tag_type": "2ITALIC_ORANGE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "NCL" },  "tag_type": "2ITALIC_GREY" }
      ]
    },

    "Zone Highlight": {
      "description": "Color by zone for spatial coordination — each zone a distinct color",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_ZONE_TXT": "Z01" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_ZONE_TXT": "Z02" }, "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_ZONE_TXT": "Z03" }, "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_ZONE_TXT": "Z04" }, "tag_type": "2BOLD_ORANGE" },
        { "conditions": { "ASS_ZONE_TXT": "ZZ" },  "tag_type": "2NOM_GREY" },
        { "conditions": { "ASS_ZONE_TXT": "XX" },  "tag_type": "2ITALIC_GREY" }
      ]
    }
  }
}
