{
  "version": "1.0",
  "description": "Tag Style Engine rules — maps element conditions to tag family type names. Each rule has conditions (parameter=value pairs) and a target tag type name matching types in the Tag Label system family (e.g. 2BOLD_RED, 3.5NOM_BLACK). Rules are evaluated top-down; first match wins.",

  "tag_type_catalog": {
    "description": "All available tag family type names and their encoded properties",
    "types": [
      { "name": "2NOM_BLACK",       "size": 2.0, "weight": "NOM",    "color": "BLACK" },
      { "name": "2NOM_BLUE",        "size": 2.0, "weight": "NOM",    "color": "BLUE" },
