  "presets": {
    "Discipline": {
      "description": "Color-code tags by discipline — Mechanical=Blue, Electrical=Red, Plumbing=Green, Architectural=Black",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M" },  "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "A" },  "tag_type": "2NOM_BLACK" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "S" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "FP" }, "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "LV" }, "tag_type": "2ITALIC_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "G" },  "tag_type": "2NOM_BLACK" }
      ]
    },

    "QA Check": {
      "description": "Highlight compliance issues — complete=green, incomplete=red bold, missing=large red",
      "default_type": "3.5BOLD_RED",
      "rules": [
        { "conditions": { "_tag_complete": "true" },   "tag_type": "2NOM_GREEN" },
        { "conditions": { "_tag_complete": "partial" }, "tag_type": "2BOLD_RED" }
      ]
    },

    "Presentation": {
      "description": "Clean black-on-white for client presentation — all tags uniform",
      "default_type": "2.5NOM_BLACK",
      "rules": []
    },

    "Print": {
      "description": "Monochrome for printing — all tags standard black",
      "default_type": "2NOM_BLACK",
      "rules": []
    },

    "Large Format": {
      "description": "Larger text for A0/A1 sheets — all tags 3.5mm",
      "default_type": "3.5NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "M" },  "tag_type": "3.5BOLD_BLUE" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "E" },  "tag_type": "3.5BOLD_RED" },
        { "conditions": { "ASS_DISCIPLINE_COD_TXT": "P" },  "tag_type": "3.5BOLD_GREEN" }
      ]
    },

    "Status": {
      "description": "Color by element status — new=bold, existing=normal, demolished=italic red",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_STATUS_TXT": "NEW" },        "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_STATUS_TXT": "EXISTING" },   "tag_type": "2NOM_BLACK" },
        { "conditions": { "ASS_STATUS_TXT": "DEMOLISHED" },  "tag_type": "2ITALIC_RED" },
        { "conditions": { "ASS_STATUS_TXT": "TEMPORARY" },   "tag_type": "2ITALIC_GREEN" }
      ]
    },

    "System": {
      "description": "Color by MEP system type",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "HVAC" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "DCW" },  "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "DHW" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "HWS" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "SAN" },  "tag_type": "2NOM_GREEN" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "RWD" },  "tag_type": "2NOM_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "GAS" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "FP" },   "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "LV" },   "tag_type": "2ITALIC_BLUE" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "FLS" },  "tag_type": "2ITALIC_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "PWR" },  "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_SYSTEM_TYPE_TXT": "LTG" },  "tag_type": "2ITALIC_BLUE" }
      ]
    },

    "Zone Highlight": {
      "description": "Color by zone for spatial coordination",
      "default_type": "2NOM_BLACK",
      "rules": [
        { "conditions": { "ASS_ZONE_TXT": "Z01" }, "tag_type": "2BOLD_BLUE" },
        { "conditions": { "ASS_ZONE_TXT": "Z02" }, "tag_type": "2BOLD_GREEN" },
        { "conditions": { "ASS_ZONE_TXT": "Z03" }, "tag_type": "2BOLD_RED" },
        { "conditions": { "ASS_ZONE_TXT": "Z04" }, "tag_type": "2NOM_BLACK" }
      ]
    }
