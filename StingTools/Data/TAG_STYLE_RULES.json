      { "name": "2.5NOM_BLACK",     "size": 2.5, "weight": "NOM",    "color": "BLACK" },
      { "name": "2.5NOM_BLUE",      "size": 2.5, "weight": "NOM",    "color": "BLUE" },
      { "name": "2.5NOM_GREEN",     "size": 2.5, "weight": "NOM",    "color": "GREEN" },
      { "name": "2.5NOM_RED",       "size": 2.5, "weight": "NOM",    "color": "RED" },
      { "name": "2.5BOLD_BLACK",    "size": 2.5, "weight": "BOLD",   "color": "BLACK" },
