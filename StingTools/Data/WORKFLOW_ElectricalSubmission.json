{
  "id": "ElectricalSubmission",
  "name": "Electrical Submission Package",
  "description": "Pre-issue submission gate: locks panel schedules, computes fault levels & feeder sizes, generates SLD + arc-flash labels, then exports the full PDF / Excel / DIALux / EasyPower report bundle. Designed to run unattended overnight or before sign-off.",
