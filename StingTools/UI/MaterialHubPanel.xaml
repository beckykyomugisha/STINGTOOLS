<Page x:Class="StingTools.UI.MaterialHubPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Title="STING Material Hub"
      Background="#F5F7FA">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Phase C: shared button styling — tune the look in one file.
                     Implicit <Style TargetType="Button" BasedOn="StingButton"/>
                     from the dictionary applies to every <Button/> on the page
                     plus every dynamically-built Button in
                     MaterialHubPanel.Builders.cs / .Textures.cs. The three
                     navy chrome buttons in the header bar (Refresh / Settings /
                     Help) keep their local Background="#324A66" — locally-set
                     properties beat implicit styles, and that colour is
                     Material Hub brand chrome (parallel to LPS keeping its
                     purple primary). Likewise, material-preview / PBR-swatch
                     colours in the data grid are DATA, not chrome — left as-is. -->
                <ResourceDictionary Source="/StingTools;component/UI/Resources/StingButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Material Hub identity chrome — NOT theme-neutral by design.
                 The dark navy header / pale KPI strip / line colour are the
                 Hub's brand chrome (same role as LPS purple). Kept verbatim. -->
            <SolidColorBrush x:Key="HubHeaderBg" Color="#1F2A3A"/>
            <SolidColorBrush x:Key="HubHeaderFg" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="HubKpiBg"    Color="#EAEFF5"/>
            <SolidColorBrush x:Key="HubLineBr"   Color="#D0D7E0"/>
            <SolidColorBrush x:Key="HubAccent"   Color="#3D6FBA"/>
            <SolidColorBrush x:Key="HubMuted"    Color="#6E7A8A"/>
            <!-- Sub-header TextBlock style (NAVIGATE / INSPECTOR). Kept —
                 actively referenced in the markup below. -->
            <Style x:Key="HubGroupLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="9"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource HubMuted}"/>
                <Setter Property="Margin" Value="4,2,4,1"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <DockPanel>
        <!-- ═══ Row 1 — Header bar (search + region + global actions) ═══ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HubHeaderBg}" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="STING Material Hub" Foreground="{StaticResource HubHeaderFg}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBox Grid.Column="1" x:Name="txtGlobalSearch" Padding="6,2" FontSize="11"
                         ToolTip="Search any field — name / class / manufacturer / EPD / uniclass"
                         TextChanged="GlobalSearch_TextChanged"/>
                <ComboBox Grid.Column="2" x:Name="cmbHubRegion" Width="90" Margin="6,0,0,0" FontSize="10"
                          SelectionChanged="HubRegion_Changed">
                    <ComboBoxItem Content="UK" IsSelected="True"/>
                    <ComboBoxItem Content="EU"/>
                    <ComboBoxItem Content="US"/>
                    <ComboBoxItem Content="AU"/>
                    <ComboBoxItem Content="Africa"/>
                </ComboBox>
                <Button Grid.Column="3" Content="⟳" Tag="HUB_Refresh" Click="HubBtn_Click"
                        Margin="6,0,0,0" Padding="8,2" ToolTip="Refresh material list"
                        Background="#324A66" Foreground="{StaticResource HubHeaderFg}" BorderBrush="#324A66"/>
                <Button Grid.Column="4" Content="⚙" Tag="HUB_Settings" Click="HubBtn_Click"
                        Margin="4,0,0,0" Padding="8,2" ToolTip="Settings"
                        Background="#324A66" Foreground="{StaticResource HubHeaderFg}" BorderBrush="#324A66"/>
                <Button Grid.Column="5" Content="?" Tag="HUB_Help" Click="HubBtn_Click"
                        Margin="4,0,0,0" Padding="8,2" ToolTip="Help"
                        Background="#324A66" Foreground="{StaticResource HubHeaderFg}" BorderBrush="#324A66"/>
            </Grid>
        </Border>

        <!-- ═══ Row 2 — KPI strip ═══ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HubKpiBg}" Padding="4,4"
                BorderBrush="{StaticResource HubLineBr}" BorderThickness="0,0,0,1">
            <ItemsControl x:Name="kpiStrip">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>

        <!-- ═══ Row 4 — Status bar (bottom) ═══ -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource HubHeaderBg}" Padding="8,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtHubStatus" Foreground="{StaticResource HubHeaderFg}"
                           FontSize="10" VerticalAlignment="Center" Text="Ready"/>
                <StackPanel Grid.Column="1" x:Name="activityFeed" Orientation="Horizontal"
                            VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ Row 3 — Action bar (above status) ═══ -->
        <Border DockPanel.Dock="Bottom" Background="#FFFFFF" Padding="4,4"
                BorderBrush="{StaticResource HubLineBr}" BorderThickness="0,1,0,1">
            <ScrollViewer MaxHeight="110" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="actionBar">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══ Center — three-pane layout ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="colNav"       Width="220" MinWidth="160"/>
                <ColumnDefinition x:Name="colSplit1"    Width="3"/>
                <ColumnDefinition x:Name="colGrid"      Width="*"   MinWidth="320"/>
                <ColumnDefinition x:Name="colSplit2"    Width="3"/>
                <ColumnDefinition x:Name="colInspector" Width="340" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT — navigation tree -->
            <DockPanel Grid.Column="0" Background="#FFFFFF">
                <Border DockPanel.Dock="Top" Background="{StaticResource HubKpiBg}" Padding="6,3">
                    <TextBlock Style="{StaticResource HubGroupLabel}" Text="NAVIGATE"/>
                </Border>
                <TreeView x:Name="navTree" BorderThickness="0" FontSize="11"
                          SelectedItemChanged="NavTree_Selected"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{StaticResource HubLineBr}" Width="3"/>

            <!-- MIDDLE — filter chips + grid -->
            <DockPanel Grid.Column="2" Background="#FFFFFF">
                <Border DockPanel.Dock="Top" Background="{StaticResource HubKpiBg}" Padding="4,3"
                        BorderBrush="{StaticResource HubLineBr}" BorderThickness="0,0,0,1">
                    <ItemsControl x:Name="filterChipsBar">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
                <DataGrid x:Name="dgHubMaterials" AutoGenerateColumns="False" IsReadOnly="False"
                          SelectionMode="Extended" GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8FAFC"
                          HeadersVisibility="Column" RowHeight="24" FontSize="11"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          SelectionChanged="HubGrid_SelectionChanged"
                          MouseDoubleClick="HubGrid_DoubleClick"
                          PreviewKeyDown="HubGrid_PreviewKeyDown"
                          ContextMenuOpening="HubGrid_ContextOpening">
                    <DataGrid.Columns>
                        <!-- col 0: color swatch -->
                        <DataGridTemplateColumn Header="" Width="28" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ColorSwatch}" Width="20" Height="14"
                                            BorderBrush="#888" BorderThickness="1" CornerRadius="2" Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- col 1: lifecycle chip -->
                        <DataGridTemplateColumn Header="State" Width="60" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding LifecycleBrush}" CornerRadius="6" Padding="4,1"
                                            Margin="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding LifecycleText}" FontSize="9"
                                                   Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*" MinWidth="160" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Class"    Binding="{Binding Class}"    Width="100"/>
                        <DataGridTextColumn Header="Origin"   Binding="{Binding Origin}"   Width="56" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Uniclass" Binding="{Binding UniclassCode}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Used"     Binding="{Binding UsageCount}" Width="48" IsReadOnly="True"/>
                        <!-- Cost / Carbon use template columns with explicit TextBox so the
                             cell-revert bug from StringFormat binding can't recur (priority #3). -->
                        <DataGridTemplateColumn Header="Cost" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Cost, StringFormat=F2, Mode=OneWay}"
                                               HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox x:Name="cellEditCost" BorderThickness="1"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding Cost, StringFormat=F2, Mode=OneWay}"
                                             LostFocus="CostEdit_LostFocus"
                                             KeyDown="CostEdit_KeyDown"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="kgCO₂e" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CarbonKgCo2e, StringFormat=F1, Mode=OneWay}"
                                               HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox x:Name="cellEditCarbon" BorderThickness="1"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding CarbonKgCo2e, StringFormat=F1, Mode=OneWay}"
                                             LostFocus="CarbonEdit_LostFocus"
                                             KeyDown="CarbonEdit_KeyDown"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="EPD" Width="70" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding EpdFreshnessText}"
                                               Foreground="{Binding EpdFreshnessBrush}" Margin="3,0,0,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{StaticResource HubLineBr}" Width="3"/>

            <!-- RIGHT — inspector card stack -->
            <DockPanel Grid.Column="4" Background="#F8FAFC">
                <Border DockPanel.Dock="Top" Background="{StaticResource HubKpiBg}" Padding="6,3">
                    <TextBlock Style="{StaticResource HubGroupLabel}" Text="INSPECTOR"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="inspectorStack" Margin="6"/>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- ═══ Toast notification overlay (top-right, on top of everything) ═══ -->
    </DockPanel>
</Page>
