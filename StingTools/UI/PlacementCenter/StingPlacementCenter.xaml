<Window x:Class="StingTools.UI.PlacementCenter.StingPlacementCenter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StingTools.UI.PlacementCenter"
        Title="STING — Placement Centre"
        Width="1280" Height="780"
        MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        FocusManager.FocusedElement="{Binding ElementName=txtSearch}"
        Background="{DynamicResource PrimaryBg}"
        Foreground="{DynamicResource PrimaryFg}">

    <!-- PC-25 — Run / Preview / Validate moved off Ctrl+R/P/V (Revit-default
         conflicts: Ctrl+P print, Ctrl+V paste, Ctrl+R repeat) onto Alt+R/P/V.
         Save / New rule / UndoLast retain their conventional bindings. -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl"      Key="S" Command="{x:Static local:PlacementCentreCommands.SaveProject}"/>
        <KeyBinding Modifiers="Ctrl"      Key="N" Command="{x:Static local:PlacementCentreCommands.AddRule}"/>
        <KeyBinding Modifiers="Alt"       Key="R" Command="{x:Static local:PlacementCentreCommands.RunPlacement}"/>
        <KeyBinding Modifiers="Alt"       Key="P" Command="{x:Static local:PlacementCentreCommands.Preview}"/>
        <KeyBinding Modifiers="Alt"       Key="V" Command="{x:Static local:PlacementCentreCommands.Validate}"/>
        <KeyBinding Modifiers="Ctrl+Shift" Key="Z" Command="{x:Static local:PlacementCentreCommands.UndoLast}"/>
        <KeyBinding Key="F5"     Command="{x:Static local:PlacementCentreCommands.HistoryRefresh}"/>
        <KeyBinding Key="Esc"    Command="{x:Static local:PlacementCentreCommands.ClearPreview}"/>
        <KeyBinding Key="Delete" Command="{x:Static local:PlacementCentreCommands.DeleteSelected}"/>
    </Window.InputBindings>
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin"  Value="2,0"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ToolBtnSecondary" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="#666"/>
        </Style>
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryFg}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- body -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBg}" Padding="8,6">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="STING — Placement Centre"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource HeaderFg}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource ToolBtnSecondary}"
                        Content="Close" Click="OnClose_Click"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Reload Defaults" Click="OnReloadDefaults_Click"
                        ToolTip="Discard all rules in memory and reload the shipped baseline."/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Import…"          Click="OnImportRules_Click"
                        ToolTip="Merge rules from another JSON file (default: append, prompt to overwrite per merge key)."/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Export…"          Click="OnExportRules_Click"
                        ToolTip="Export the current rule set to a portable JSON file you can share or version-control."/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Export Excel"     Click="OnExportExcel_Click"
                        ToolTip="Phase 139 — Export every rule to an .xlsx workbook (one sheet per discipline pack)."/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Import Excel"     Click="OnImportExcel_Click"
                        ToolTip="Phase 139 — Import rules back from .xlsx; replaces the project overlay."/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Save Project"     Click="OnSaveProject_Click"
                        ToolTip="Save valid rules to &lt;project&gt;/STING_PLACEMENT_RULES.project.json (Ctrl+S)."/>
                <Separator Width="8" Visibility="Hidden"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtn}"          x:Name="btnRunPlacement" Content="Run Placement"   Click="OnRunPlacement_Click" ToolTip="Alt+R"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtn}"          Content="Preview"         Click="OnPreview_Click"      ToolTip="Alt+P"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtn}"          Content="Validate"        Click="OnValidate_Click"     ToolTip="Alt+V"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Undo last run"   Click="OnUndoLast_Click"
                        ToolTip="Delete every element placed by the most-recent provenance bucket. Confirmation prompt. Ctrl+Shift+Z."/>
                <Separator Width="8" Visibility="Hidden"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Push to Families" Click="OnPushFamilies_Click"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Heat-map"        Click="OnHeatmap_Click"/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="Save view preset" Click="OnSaveViewPreset_Click"
                        ToolTip="Stamp a Pack 125/M view preset onto the active view so its scope/template/scale travel with the model."/>
                <Button DockPanel.Dock="Left"  Style="{StaticResource ToolBtnSecondary}" Content="GD Study"        Click="OnGDStudy_Click"/>
            </DockPanel>
        </Border>

        <!-- Body: master-detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"   MinWidth="540"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: rule list + search + add/delete -->
            <Border Grid.Column="0" Background="{DynamicResource SecondaryBg}" Padding="6">
                <DockPanel>
                    <!-- Search + filter chips -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Style="{StaticResource ToolBtnSecondary}"
                                Content="−" Width="32" Click="OnDelete_Click" ToolTip="Delete selected rule"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource ToolBtnSecondary}"
                                Content="+" Width="32" Click="OnAdd_Click" ToolTip="Add a new rule"/>
                        <TextBox x:Name="txtSearch" Padding="3"
                                 TextChanged="OnSearch_TextChanged"
                                 ToolTip="Phase 139 — search RuleId / category / variant / room / notes / standard / pack"/>
                    </DockPanel>
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,6">
                        <ToggleButton x:Name="chipDirty"   DockPanel.Dock="Left" Margin="0,0,4,0"
                                      Padding="6,2" Content="● Dirty"
                                      Checked="OnFilterChanged" Unchecked="OnFilterChanged"
                                      ToolTip="Show only rules with unsaved edits."/>
                        <ToggleButton x:Name="chipInvalid" DockPanel.Dock="Left" Margin="0,0,4,0"
                                      Padding="6,2" Content="✗ Invalid"
                                      Checked="OnFilterChanged" Unchecked="OnFilterChanged"
                                      ToolTip="Show only rules failing validation (missing CategoryFilter, bad Priority, …)."/>
                        <ComboBox x:Name="cmbSourcePack" DockPanel.Dock="Left" Margin="6,0,0,0"
                                  Width="130" SelectionChanged="OnSourcePack_SelectionChanged"
                                  ToolTip="Phase 139 — filter by discipline pack."/>
                    </DockPanel>

                    <!-- Rule grid -->
                    <DataGrid x:Name="gridRules"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              SelectionChanged="OnGrid_SelectionChanged"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserResizeRows="False"
                              CanUserAddRows="False"
                              CanUserReorderColumns="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              Background="{DynamicResource PrimaryBg}"
                              Foreground="{DynamicResource PrimaryFg}"
                              RowBackground="{DynamicResource PrimaryBg}"
                              AlternatingRowBackground="{DynamicResource SecondaryBg}"
                              ToolTip="Ctrl+click / Shift+click to multi-select. Right-click for bulk actions.">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <!-- Phase 139 I1 — RAG status colour from VM -->
                                <Setter Property="Background"
                                        Value="{Binding StatusColorHex, Converter={StaticResource HexToBrushConverter}, FallbackValue=#FFFFFF}"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Clone selected" Click="OnCloneSelected_Click"/>
                                <MenuItem Header="Delete selected" Click="OnDeleteSelected_Click"/>
                                <Separator/>
                                <MenuItem Header="Select invalid"  Click="OnSelectInvalid_Click"/>
                                <MenuItem Header="Select dirty"    Click="OnSelectDirty_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="●"
                                                Binding="{Binding IsDirty, Converter={StaticResource DirtyDotConverter}}"
                                                Width="22"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryFilter}"      Width="*"/>
                            <DataGridTextColumn Header="Variant"  Binding="{Binding VariantHint}"        Width="80"/>
                            <DataGridTextColumn Header="Room"     Binding="{Binding RoomFilter}"         Width="90"/>
                            <DataGridTextColumn Header="Anchor"   Binding="{Binding AnchorType}"         Width="100"/>
                            <DataGridTextColumn Header="Pri"      Binding="{Binding Priority}"           Width="40"/>
                            <!-- Phase 139 I1 — new columns -->
                            <DataGridTextColumn Header="Pack"     Binding="{Binding SourcePack}"         Width="80"/>
                            <DataGridTextColumn Header="Cov %"    Binding="{Binding LastCoverageDisplay}" Width="60"/>
                            <DataGridTextColumn Header="Placed/Tgt" Binding="{Binding PlacedTargetDisplay}" Width="70"/>
                            <DataGridTextColumn Header="Standard" Binding="{Binding PrimaryStandard}"   Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="#999"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          ShowsPreview="True"/>

            <!-- RIGHT: detail GroupBoxes -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel x:Name="pnlDetail">
                    <!-- pnlRuleDetail wraps the rule-bound editors so they
                         disable when no rule is selected; Run Options and
                         History stay enabled (they don't depend on a row). -->
                    <StackPanel x:Name="pnlRuleDetail" IsEnabled="False">

                    <GroupBox Header="Rule Core" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Category Filter"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbCategory" IsEditable="True" Margin="0,2"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Variant Hint"/>
                            <ComboBox  Grid.Row="0" Grid.Column="3" x:Name="cmbVariant" IsEditable="True" Margin="0,2"
                                       ToolTip="Family-type variant filter. Suggested: FLUSH / SURFACE / RECESSED / IP65 / IP66 / EM / DALI."/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Room Filter (regex)"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtRoom"     Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Anchor"/>
                            <ComboBox  Grid.Row="1" Grid.Column="3" x:Name="cmbAnchor"   Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Side"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbSide"     Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Priority (0–100)"/>
                            <TextBox   Grid.Row="2" Grid.Column="3" x:Name="txtPriority" Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Geometry" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Offset X (mm)"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtOffsetX" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Offset Y (mm)"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtOffsetY" Margin="0,2"
                                       ToolTip="PC-06 — signed Y offset from the anchor's +Y axis."/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Offset Z (mm)"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtOffsetZ" Margin="0,2"
                                       ToolTip="PC-06 — signed Z offset, separate from MountingHeight."/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Mount Height (mm)"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtMountH"  Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Mount Reference"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbMountRef" Margin="0,2"
                                       ToolTip="PC-06 — FFL / SOFFIT / SLAB / CEILING. Default FFL preserves legacy behaviour."/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Rotation (°)"/>
                            <TextBox   Grid.Row="2" Grid.Column="3" x:Name="txtRotation" Margin="0,2"
                                       ToolTip="PC-06 — rotation about Z in degrees."/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Min Spacing (mm)"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtSpacing" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Max per Room (0 = ∞)"/>
                            <TextBox   Grid.Row="3" Grid.Column="3" x:Name="txtMaxRoom" Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Room Scoping (PC-07)" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Exclude room (regex)"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtRoomExclude" Margin="0,2"
                                       ToolTip="Skip rooms whose name matches this regex even if RoomFilter passed."/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Department (regex)"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtDepartment"   Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Level (regex)"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtLevelFilter"  Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Phase (regex)"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtPhaseFilter"  Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Workset (regex)"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtWorksetFilter" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Min/Max Area (m²)"/>
                            <DockPanel Grid.Row="2" Grid.Column="3" Margin="0,2">
                                <TextBox x:Name="txtMinArea" Width="60" Margin="0,0,4,0"
                                         ToolTip="Skip rooms whose Area &lt; MinAreaM2 (0 = no minimum)."/>
                                <TextBox x:Name="txtMaxArea"
                                         ToolTip="Skip rooms whose Area &gt; MaxAreaM2 (0 = no maximum)."/>
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Rule Kind / Density / Linear (PC-12)" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Kind"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbRuleKind" Margin="0,2"
                                       ToolTip="Point: one placement at the anchor. Density: count from area / occupant. Linear: count from perimeter."/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Per area (m²)"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtPerArea" Margin="0,2"
                                       ToolTip="Density: 1 fixture per N m² of floor area."/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Per occupant"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtPerOcc" Margin="0,2"
                                       ToolTip="Density: 1 fixture per N occupants (read from STING_OCC_COUNT_INT)."/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Per linear m"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtPerLin" Margin="0,2"
                                       ToolTip="Linear: 1 fixture per N metres of room perimeter."/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Rule Dependencies (PC-13)" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Rule Id"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtRuleId"  Margin="0,2"
                                       ToolTip="Stable id used by DependsOn / CoPlaceWith / ConflictsWith. Defaults to MergeKey when empty."/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Depends on"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtDependsOn" Margin="0,2"
                                       ToolTip="RuleId of predecessor — this rule fires only after that rule placed ≥1 instance."/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Relative to"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbRelativeTo" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Co-place / Conflicts"/>
                            <DockPanel Grid.Row="1" Grid.Column="3" Margin="0,2">
                                <TextBox x:Name="txtCoPlace"  Width="120" Margin="0,0,4,0"
                                         ToolTip="Comma-separated RuleIds to fire alongside this rule."/>
                                <TextBox x:Name="txtConflict"
                                         ToolTip="Comma-separated RuleIds whose placement in the same room suppresses this rule."/>
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Standards &amp; Classification" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Standard ref"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtStandardRef" Margin="0,2"
                                       ToolTip="Citation surfaced in result panels (e.g. 'BS 7671 §701')."/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Uniclass Pr"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtUniclassPr"  Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Notes" Style="{StaticResource GroupBoxStyle}">
                        <TextBox x:Name="txtNotes" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="48" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                 ToolTip="Free-text note attached to this rule. Surfaced in placement reports and pushed to STING_PLACEMENT_NOTES_TXT on family types when Push to Families runs."/>
                    </GroupBox>

                    <GroupBox Header="Clearance / Envelope / Weight (PC-11, push to family types)" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Clearance (mm)"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtClr"      Margin="0,2"
                                       ToolTip="Omnidirectional clearance — written to STING_CLEARANCE_MM."/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Front / Back (mm)"/>
                            <DockPanel Grid.Row="0" Grid.Column="3" Margin="0,2">
                                <TextBox x:Name="txtClrFront" Width="60" Margin="0,0,4,0"/>
                                <TextBox x:Name="txtClrBack"/>
                            </DockPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Side / Top (mm)"/>
                            <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,2">
                                <TextBox x:Name="txtClrSide" Width="60" Margin="0,0,4,0"/>
                                <TextBox x:Name="txtClrTop"/>
                            </DockPanel>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Weight (kg)"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtWeightKg" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="W × D × H (mm)"/>
                            <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,2">
                                <TextBox x:Name="txtEnvW" Width="60" Margin="0,0,4,0"/>
                                <TextBox x:Name="txtEnvD" Width="60" Margin="0,0,4,0"/>
                                <TextBox x:Name="txtEnvH"/>
                            </DockPanel>
                            <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Fire separation (mm)"/>
                            <TextBox   Grid.Row="2" Grid.Column="3" x:Name="txtFireSep" Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Family Defaults &amp; Clearance (read-only)" Style="{StaticResource GroupBoxStyle}">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                           Foreground="#666" FontStyle="Italic" FontWeight="Normal"
                                           Text="Reads from the first sample family in this category. 'type' source wins over 'instance'."/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ToolBtnSecondary}"
                                        Content="Inspect" Click="OnInspectFamily_Click" Margin="4,0"/>
                            </DockPanel>
                            <DataGrid x:Name="gridFamilyHints"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      MaxHeight="220"
                                      ItemsSource="{Binding VM.FamilyHints, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Background="{DynamicResource PrimaryBg}"
                                      Foreground="{DynamicResource PrimaryFg}"
                                      RowBackground="{DynamicResource PrimaryBg}"
                                      AlternatingRowBackground="{DynamicResource SecondaryBg}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Parameter" Binding="{Binding Name}"  Width="*"/>
                                    <DataGridTextColumn Header="Value"     Binding="{Binding Value}" Width="*"/>
                                    <DataGridTextColumn Header="Unit"      Binding="{Binding Unit}"  Width="60"/>
                                    <DataGridTextColumn Header="Source"    Binding="{Binding Source}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                    <!-- Phase 139 I2 — new rule detail cards -->
                    <GroupBox Header="Coverage &amp; Spacing (Standards)" Style="{StaticResource GroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#666" FontStyle="Italic" FontWeight="Normal" Margin="0,0,0,4"
                                       TextWrapping="Wrap"
                                       Text="Set CoverageRadiusMm for detector / speaker rules and tick GuaranteeCoverage to fail when the engine cannot fully cover a room."/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Coverage radius (mm)"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtCoverageRadius" Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Max spacing (mm)"/>
                                <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtMaxSpacing"     Margin="0,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Wall clearance (mm)"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtWallClearance"  Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Obstr. clearance (mm)"/>
                                <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtObstructionClearance" Margin="0,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Guarantee coverage"/>
                                <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="chkGuaranteeCoverage" Margin="0,4"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Routing (Conduit / Pipe / Duct)" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Routing mode"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbRoutingMode" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Route face"/>
                            <ComboBox  Grid.Row="0" Grid.Column="3" x:Name="cmbRouteFace"   Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Route offset (mm)"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtRouteOffset" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Min bend radius (mm)"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtRouteMinBendRadius" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Segment category"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbRouteSegmentCategory" Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Window / Glazing" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Sill height (mm)"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtSillHeight"  Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Head height (mm)"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtHeadHeight"  Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Cill to floor (mm)"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtCillToFloor" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Toughened glazing"/>
                            <CheckBox  Grid.Row="1" Grid.Column="3" x:Name="chkToughenedGlazing" Margin="0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Glazing spec"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbGlazingSpec" Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Standards &amp; Accessibility" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Building type"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbBuildingType"   Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="IP rating min"/>
                            <TextBox   Grid.Row="0" Grid.Column="3" x:Name="txtIpRatingMin"    Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Standards (csv)"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtStandardsCsv"   Margin="0,2"
                                       ToolTip="Comma-separated list, e.g. BS7671,BS5839,NFPA13,PartM,ASHRAE621."/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Wet zone exclusion"/>
                            <ComboBox  Grid.Row="1" Grid.Column="3" x:Name="cmbWetZone"        Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Accessibility check"/>
                            <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="chkAccessibilityCheck" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Height standard"/>
                            <ComboBox  Grid.Row="2" Grid.Column="3" x:Name="cmbHeightStandard" Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Post-Placement" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Requires COBie fields"/>
                            <CheckBox  Grid.Row="0" Grid.Column="1" x:Name="chkRequiresCOBieFields" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Requires IFC mapping"/>
                            <CheckBox  Grid.Row="0" Grid.Column="3" x:Name="chkRequiresIfcMapping"  Margin="0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Maintenance clearance"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbMaintenanceClearance" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="Post audit tag"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="txtPostAuditTag"          Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    </StackPanel> <!-- /pnlRuleDetail -->

                    <!-- Phase 139 I3 — Building Profile header -->
                    <GroupBox Header="Building Profile (Phase 139)" Style="{StaticResource GroupBoxStyle}">
                        <StackPanel>
                            <Border BorderBrush="#E2A04A" BorderThickness="1" Padding="6"
                                    Background="#FFF7E6" Margin="0,0,0,8"
                                    Visibility="{Binding VM.Profile.BuildingType, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EmptyStringToVisibility}, FallbackValue=Visible}">
                                <TextBlock Foreground="#A33" FontSize="11" TextWrapping="Wrap"
                                           Text="No building profile loaded — every rule is active. Set a Building Type below to gate by sector."/>
                            </Border>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Building type"/>
                                <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbProfileBuildingType" Margin="0,2"/>
                                <Button    Grid.Row="0" Grid.Column="2" Style="{StaticResource ToolBtnSecondary}"
                                           Content="Load" Click="OnLoadProfile_Click" Margin="2,0"
                                           ToolTip="Load profile from &lt;project&gt;/_BIM_COORD/placement_profile.json"/>
                                <Button    Grid.Row="0" Grid.Column="3" Style="{StaticResource ToolBtnSecondary}"
                                           Content="Save" Click="OnSaveProfile_Click" Margin="2,0"
                                           ToolTip="Persist current profile to _BIM_COORD/placement_profile.json"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Active standards (csv)"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                           x:Name="txtProfileStandards" Margin="0,2"
                                           ToolTip="Comma-separated list (e.g. BS7671,BS5839,NFPA13,PartM,ASHRAE621,BS6465,HTM0201,BB103)."/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Toggles"/>
                                <WrapPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3">
                                    <CheckBox x:Name="chkEnableWetZone"       Content="Wet-zone checks"      Margin="0,0,8,0"/>
                                    <CheckBox x:Name="chkEnableAccessibility" Content="Accessibility checks" Margin="0,0,8,0"/>
                                    <CheckBox x:Name="chkEnableCoverage"      Content="Coverage guarantee"   Margin="0,0,8,0"/>
                                </WrapPanel>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Run Options" Style="{StaticResource GroupBoxStyle}">
                        <StackPanel>
                            <CheckBox x:Name="chkProvenance"   Content="Stamp provenance on each placement (Pack 123/E)" Margin="0,3"
                                      ToolTip="When ON, every placed instance carries a StingProvenance entity so 'Undo last run' and provenance-scoped validation can find them. OFF skips the stamp — useful for one-off non-tracked placements."/>
                            <CheckBox x:Name="chkLearned"      Content="Honour learned offsets per category (Pack 10 / PC-14)" Margin="0,3"
                                      ToolTip="When ON and a STING_PLACEMENT_RULES.learned.json sits next to the .rvt, learned overrides win over the shipped baseline. PC-14 LearnPlacementV4Command writes that file."/>
                            <CheckBox x:Name="chkValidators"   Content="Run validators after placement"                  Margin="0,3"
                                      ToolTip="Run ClearanceValidator + MaintenanceClashValidator immediately after the placement commits, scoped to elements just placed."/>
                            <CheckBox x:Name="chkAutoHeatmap"  Content="Auto-paint AVF compliance heat-map on commit"    Margin="0,3"
                                      ToolTip="When ON and at least one fixture was placed, paint the AVF compliance heat-map on the active view immediately after the run commits."/>
                            <CheckBox x:Name="chkRunTags"      Content="Run data-tag pipeline on each placement (PC-17)" Margin="0,3"
                                      ToolTip="Invoke TagPipelineHelper.RunFullPipeline on every placed instance so the placement lands ISO-19650 tagged."/>
                            <CheckBox x:Name="chkSeedCobie"    Content="Seed COBie component fields from the rule (PC-17)" Margin="0,3"
                                      ToolTip="Copy StandardRef / Notes / UniclassPr onto the placed instance's COBIE_COMPONENT_* parameters."/>
                            <CheckBox x:Name="chkAssignMep"    Content="Probe MEP connectors after placement (PC-17)" Margin="0,3"
                                      ToolTip="Log any unconnected connectors so MEPSystemBuilder can pick them up."/>
                            <CheckBox x:Name="chkLivePreview"  Content="Live preview while editing rules (PC-21)" Margin="0,3"
                                      ToolTip="Auto-refresh the on-canvas preview 500 ms after each rule edit."/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Scope"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton x:Name="rbScopeView"  GroupName="Scope" Content="Active view" IsChecked="True" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="rbScopeSel"   GroupName="Scope" Content="Selection"  Margin="0,0,12,0"/>
                                    <RadioButton x:Name="rbScopeProj"  GroupName="Scope" Content="Project"/>
                                </StackPanel>
                            </Grid>

                            <!-- PC-23 — Validator picker. -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Validators"/>
                                <WrapPanel Grid.Column="1">
                                    <CheckBox x:Name="vClearance"   Content="Clearance"   IsChecked="True"  Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vMaintenance" Content="Maintenance" IsChecked="True"  Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vConnectivity" Content="Connectivity" Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vFill"        Content="Fill"        Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vSpec"        Content="Spec"        Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vTermination" Content="Termination" Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vSlope"       Content="Slope"       Margin="0,0,8,0"/>
                                    <CheckBox x:Name="vSeparation"  Content="Separation"  Margin="0,0,8,0"/>
                                </WrapPanel>
                            </Grid>

                            <!-- Phase 139.8 — explicit category checklist for what to auto-place.
                                 When ALL boxes are off, every category in the active rule pack is allowed.
                                 When ANY box is ticked, only those categories are placed. -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Auto-place"
                                           ToolTip="Tick the categories the run should auto-place. Empty = every category."/>
                                <WrapPanel Grid.Column="1">
                                    <CheckBox x:Name="cbCatElec"   Content="Electrical Fixtures"  Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatLtgDev" Content="Lighting Devices"     Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatLtgFix" Content="Lighting Fixtures"    Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatComm"   Content="Communication Devices" Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatData"   Content="Data Devices"         Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatSec"    Content="Security Devices"     Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatFire"   Content="Fire Alarm Devices"   Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatPlm"    Content="Plumbing Fixtures"    Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatHvac"   Content="Air Terminals"        Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatSpr"    Content="Sprinklers"           Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatMech"   Content="Mechanical Equipment" Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatCond"   Content="Conduits"             Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatJBox"   Content="Junction Boxes"       Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatPipe"   Content="Pipes"                Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatTray"   Content="Cable Trays"          Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatSpec"   Content="Specialty Equipment"  Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatFurn"   Content="Furniture"            Margin="0,0,8,2"/>
                                    <CheckBox x:Name="cbCatNurse"  Content="Nurse Call Devices"   Margin="0,0,8,2"/>
                                    <Button x:Name="btnCatAll"  Content="All"  Padding="8,2" Margin="6,0,4,2"/>
                                    <Button x:Name="btnCatNone" Content="None" Padding="8,2" Margin="0,0,4,2"/>
                                </WrapPanel>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="History &amp; Provenance" Style="{StaticResource GroupBoxStyle}">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                           Foreground="#666" FontStyle="Italic" FontWeight="Normal"
                                           Text="StingProvenanceSchema — last 30 hourly buckets, newest first. Double-click a row to select in Revit."/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ToolBtnSecondary}"
                                        Content="Refresh" Click="OnHistoryRefresh_Click" Margin="4,0"
                                        ToolTip="Re-scan provenance and refresh the table (F5)."/>
                            </DockPanel>
                            <DataGrid x:Name="gridHistory"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      MaxHeight="220"
                                      ItemsSource="{Binding VM.History, RelativeSource={RelativeSource AncestorType=Window}}"
                                      MouseDoubleClick="OnHistory_DoubleClick"
                                      ToolTip="Double-click a row to select its placed instances in Revit."
                                      Background="{DynamicResource PrimaryBg}"
                                      Foreground="{DynamicResource PrimaryFg}"
                                      RowBackground="{DynamicResource PrimaryBg}"
                                      AlternatingRowBackground="{DynamicResource SecondaryBg}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="When (UTC)" Binding="{Binding CreatedUtc}"        Width="160"/>
                                    <DataGridTextColumn Header="Engine"     Binding="{Binding Engine}"            Width="*"/>
                                    <DataGridTextColumn Header="Rule"       Binding="{Binding RuleId}"            Width="*"/>
                                    <DataGridTextColumn Header="Operator"   Binding="{Binding Operator}"          Width="100"/>
                                    <DataGridTextColumn Header="Count"      Binding="{Binding Count}"             Width="60"/>
                                    <!-- Phase 139 I4 — extra history columns -->
                                    <DataGridTextColumn Header="Cov %"      Binding="{Binding CoverageDisplay}"   Width="60"/>
                                    <DataGridTextColumn Header="Skipped"    Binding="{Binding SkippedDisplay}"    Width="60"/>
                                    <DataGridTextColumn Header="Warnings"   Binding="{Binding WarningDisplay}"    Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>

                    <Border BorderBrush="#E2A04A" BorderThickness="1" Padding="6"
                            Background="#FFF7E6" Margin="0,4,0,0">
                        <TextBlock x:Name="txtRuleError"
                                   Foreground="#A33"
                                   TextWrapping="Wrap"
                                   FontSize="11"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource HeaderBg}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtStatus"
                           Foreground="{DynamicResource HeaderFg}" Text="Ready"/>
                <TextBlock Grid.Column="1" x:Name="txtMeta"
                           Foreground="{DynamicResource HeaderFg}" Opacity="0.7"
                           Text=""/>
            </Grid>
        </Border>
    </Grid>
</Window>
