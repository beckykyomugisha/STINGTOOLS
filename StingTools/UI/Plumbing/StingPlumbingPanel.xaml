                                   FontSize="10" Foreground="{DynamicResource PanelFg}" Opacity="0.7"
                                   FontStyle="Italic" TextWrapping="Wrap" Margin="2,4"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============== TAB 6: AUDIT ============== -->
            <TabItem Header="AUDIT">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="FULL AUDIT (RAG DASHBOARD)" Style="{StaticResource PlumbSectionHeader}"/>
