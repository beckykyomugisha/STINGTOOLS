                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Climate uplift (%)" Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtClimateUplift" Text="20" Margin="2" FontSize="10"/>
                            </Grid>
                        </Expander>
                        <Button Content="▶ Roof Drainage (BS EN 12056-3)" Style="{StaticResource PlumbPrimaryBtn}"
                                Tag="Plumb_RoofDrainage" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Q_r = A · C_r · r · f. Computes outlet DN + count."/>

                        <TextBlock Text="SURFACE WATER &amp; SuDS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="SuDS Attenuation (CIRIA C753)" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumb_SuDS" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Post-dev minus pre-dev runoff over storm duration with climate uplift."/>

                        <TextBlock Text="RAINWATER HARVESTING" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <Button Content="RWH Yield (BS 8515)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_RWH" Click="Cmd_Click"
                                    ToolTip="Annual yield + recommended storage volume from roof area + rainfall."/>
                            <Button Content="RWH / SuDS / Soakaway / Septic (legacy)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumbing_RainwaterCalc" Click="Cmd_Click"
                                    ToolTip="Pre-existing combined calculator — retained."/>
                        </WrapPanel>

                        <TextBlock Text="SOAKAWAY / SEPTIC" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <Button Content="Soakaway (BRE Digest 365)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_Soakaway" Click="Cmd_Click"
                                    ToolTip="Catchment + infiltration → soakaway volume."/>
                            <Button Content="Septic Tank (BS EN 12566-1)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_SepticTank" Click="Cmd_Click"
                                    ToolTip="Primary chamber sizing from population equivalent."/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
