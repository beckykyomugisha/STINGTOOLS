                                Tag="Plumb_FullAudit" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Single dashboard with Supply / Drainage / Vents / Backflow / HTM 04-01 RAG tiles."/>

                        <Expander Header="DOMAIN RAG SUMMARY" Style="{StaticResource PlumbExpander}" IsExpanded="True">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
