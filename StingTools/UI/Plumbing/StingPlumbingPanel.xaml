                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Service band (mm AFFL)"  Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtRtServiceBand" Text="2700" Margin="2" FontSize="10"/>
                                <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="chkRtSnap"     Content="Snap to corridor service band" IsChecked="True" Margin="2"/>
                                <CheckBox  Grid.Row="4" Grid.Column="1" x:Name="chkRtPreview"  Content="Preview before commit"          IsChecked="True" Margin="2"/>
                                <CheckBox  Grid.Row="5" Grid.Column="1" x:Name="chkRtAutoSize" Content="Auto-size new pipes after route" IsChecked="True" Margin="2"
                                           ToolTip="Runs WaterSupplySizer / DrainageSizer on newly created pipes."/>
                            </Grid>
                        </Expander>
                        <WrapPanel Margin="0,2">
                            <Button Content="▶ Auto-Route Selected" Style="{StaticResource PlumbPrimaryBtn}"
                                    Tag="Plumb_AutoRoute" Click="Cmd_Click"
                                    ToolTip="Wraps AutoPipeDrop on the current selection — drops pipework to nearest host within radius."/>
                            <Button Content="Route All Fixtures" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_AutoRoute" Click="Cmd_Click"
                                    ToolTip="Same as Auto-Route Selected but iterates every OST_PlumbingFixtures in the active view."/>
