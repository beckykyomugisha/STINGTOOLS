                            <Button Content="Design Vents" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_VentDesign" Click="Cmd_Click"
                                    ToolTip="BS EN 12056-2 Annex B vent sizing per drain DU (design report only — does NOT create pipework)."/>
                            <Button Content="▶ Create Vents" Style="{StaticResource PlumbPrimaryBtn}"
                                    Tag="Plumb_CreateVents" Click="Cmd_Click"
                                    ToolTip="Close the design → model loop: take the VentDesigner output and actually create vent pipe + AAV instances. Preview shown before commit."/>
                            <Button Content="Trap &amp; Vent Audit" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumbing_TrapVentAudit" Click="Cmd_Click"
                                    ToolTip="Audit trap type + seal depth + max branch length + vent DN."/>
                        </WrapPanel>

                        <TextBlock Text="STACK CAPACITY" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="Stack Capacity (BS EN 12056-2 §6.5)" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumbing_StackCapacity" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Cumulative DU vs Table 11 capacity — flags >70% induced-siphonage risk."/>
                        <Expander Header="STACK CAPACITY RESULTS" Style="{StaticResource PlumbExpander}">
                            <DataGrid x:Name="StackGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      FontSize="10" RowHeight="22" Height="120" Margin="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Stack" Binding="{Binding StackId}"   Width="*"/>
                                    <DataGridTextColumn Header="DN"    Binding="{Binding DnDisplay}" Width="48"/>
                                    <DataGridTextColumn Header="DU"    Binding="{Binding DuDisplay}" Width="60"/>
                                    <DataGridTextColumn Header="Cap"   Binding="{Binding CapacityDisplay}" Width="64"/>
                                    <DataGridTextColumn Header="Util%" Binding="{Binding UtilDisplay}" Width="56"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}"   Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <TextBlock Text="INVERT LEVELS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="Calculate Invert Levels" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumb_InvertLevels" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="InvertLevelEngine — US/DS invert + cover depth, optional writeback to PLM_DRN_INV_*."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============== TAB 3: ROUTE ============== -->
            <TabItem Header="ROUTE">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="AUTO-DROP CONNECTIONS" Style="{StaticResource PlumbSectionHeader}"/>
                        <Expander Header="ROUTING OPTIONS" Style="{StaticResource PlumbExpander}" IsExpanded="True">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Max search radius (mm)" Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtRtRadius"   Text="3000" Margin="2" FontSize="10"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Drop angle (°)"          Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtRtDropAngle" Text="90"  Margin="2" FontSize="10"
