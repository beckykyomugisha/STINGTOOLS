                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtDrnVMin"      Text="0.7" Margin="2" FontSize="10"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Roughness (mm)"       Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtDrnRoughness"  Text="0.6" Margin="2" FontSize="10"/>
                            </Grid>
                        </Expander>
                        <WrapPanel Margin="0,4">
                            <Button Content="Size Drainage (preview)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_SizeDrainage" Click="Cmd_Click"
                                    ToolTip="DU accumulation → branch / stack DN → slope / self-cleansing audit."/>
                            <Button Content="▶ Auto-Size Drainage" Style="{StaticResource PlumbPrimaryBtn}"
                                    Tag="Plumbing_AutoSizeDrainage" Click="Cmd_Click"
                                    ToolTip="DU → DN → slope correct → vent design → stack capacity (preview / apply)."/>
                        </WrapPanel>

                        <TextBlock Text="DRAINAGE PIPE GRID" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <DataGrid x:Name="DrainagePipeGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  FontSize="10" RowHeight="22" Height="160" Margin="0,2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Pipe"    Binding="{Binding PipeId}"     Width="*"/>
                                <DataGridTextColumn Header="DU"      Binding="{Binding DuDisplay}"  Width="48"/>
                                <DataGridTextColumn Header="DN"      Binding="{Binding DnDisplay}"  Width="48"/>
                                <DataGridTextColumn Header="Slope %" Binding="{Binding SlopeDisplay}" Width="64"/>
                                <DataGridTextColumn Header="v (m/s)" Binding="{Binding VelocityDisplay}" Width="64"/>
                                <DataGridTextColumn Header="Status"  Binding="{Binding Status}"     Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="SLOPE CORRECTION" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="Fix Slopes (auto-correct)" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumb_FixSlopes" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Wraps SlopeAutoCorrector with TransactionGroup rollback and preview dialog."/>

                        <TextBlock Text="TRAP &amp; VENT" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
