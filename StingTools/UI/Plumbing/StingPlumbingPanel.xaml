                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max slope (%)"        Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtDrnMaxSlope"  Text="6.0" Margin="2" FontSize="10"/>
