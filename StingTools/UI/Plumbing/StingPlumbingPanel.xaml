                                    Tag="Plumb_AutoRoute" Click="Cmd_Click"
                                    ToolTip="Routes branch drains to the nearest classified Stack node (uses PipeNetworkBuilder)."/>
                            <Button Content="Validate Connectors" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_FullAudit" Click="Cmd_Click"
                                    ToolTip="Quick read-only check: every fixture should have a connected drainage end and a supply end."/>
                        </WrapPanel>

                        <TextBlock Text="SIZING (LIVE)" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel Margin="0,2">
                            <Button Content="Size Supply Now" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_SizeSupply" Click="Cmd_Click"
                                    ToolTip="Runs WaterSupplySizer on the current model. Uses the head-loss method + sizing strategy from SYSTEM tab."/>
                            <Button Content="Size Drainage Now" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_SizeDrainage" Click="Cmd_Click"
                                    ToolTip="Runs DrainageSizer (DFU + Manning self-cleansing)."/>
                            <Button Content="Pressure Walk" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_PressureCheck" Click="Cmd_Click"
                                    ToolTip="Index-leg static + friction pressure walk including PRV / meter."/>
                        </WrapPanel>

                        <TextBlock Text="SLOPE &amp; INVERTS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel Margin="0,2">
                            <Button Content="Fix Slopes (project)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_FixSlopes" Click="Cmd_Click"
                                    ToolTip="BS EN 12056-2 minimum slopes via SubTransaction per pipe (preview-first)."/>
                            <Button Content="Compute Invert Levels" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_InvertLevels" Click="Cmd_Click"
                                    ToolTip="Walks the drainage tree from the outfall, computes invert + cover at each node."/>
                        </WrapPanel>

                        <TextBlock Text="P-TRAPS / VENTS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel Margin="0,2">
                            <Button Content="Insert P-Traps" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_InsertPTraps" Click="Cmd_Click"
                                    ToolTip="Walks fixtures lacking a trap and inserts a P-trap family at the drainage connector."/>
                            <Button Content="Design Vents" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_VentDesign" Click="Cmd_Click"
                                    ToolTip="VentDesigner — sizes secondary vents + AAVs per BS EN 12056-2 §6."/>
                            <Button Content="Create Vent Pipes" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_CreateVents" Click="Cmd_Click"
                                    ToolTip="Closes the design → model loop: emits pipes + AAVs from VentDesigner output."/>
                        </WrapPanel>

                        <TextBlock Text="PENETRATIONS / SLEEVES &amp; HANGERS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel Margin="0,2">
                            <Button Content="Place Sleeves" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_PlaceSleeves" Click="Cmd_Click"
                                    ToolTip="Wraps SleeveEngine — places STING_SLEEVE_ROUND/RECT, inherits fire rating, writes IFC PfV."/>
                            <Button Content="Plan Hangers" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_PlaceHangers" Click="Cmd_Click"
                                    ToolTip="BS 5572 / MSS SP-58 hanger spacing + trapeze grouping (planning pass)."/>
                            <Button Content="Roof Drainage" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_RoofDrainage" Click="Cmd_Click"
                                    ToolTip="Places roof gullies + downpipes from BS EN 12056-3 / ASPE storm sizing."/>
                        </WrapPanel>

                        <Expander Header="SYMBOL PLACEMENT — SANITARY FIXTURES" Style="{StaticResource PlumbExpander}">
                            <WrapPanel Margin="4">
                                <Button Content="WC"               Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_WC"          Click="Cmd_Click"/>
                                <Button Content="Urinal"           Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_Urinal"      Click="Cmd_Click"/>
                                <Button Content="Bidet"            Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_Bidet"       Click="Cmd_Click"/>
                                <Button Content="Wash-hand basin"  Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_WHB"         Click="Cmd_Click"/>
                                <Button Content="Vanity basin"     Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_VanityBasin" Click="Cmd_Click"/>
                                <Button Content="Bath"             Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_Bath"        Click="Cmd_Click"/>
                                <Button Content="Shower tray"      Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_Shower"      Click="Cmd_Click"/>
                            </WrapPanel>
                        </Expander>
                        <Expander Header="SYMBOL PLACEMENT — SINKS" Style="{StaticResource PlumbExpander}">
                            <WrapPanel Margin="4">
                                <Button Content="Single sink"     Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_SingleSink"   Click="Cmd_Click"/>
                                <Button Content="Double sink"     Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_DoubleSink"   Click="Cmd_Click"/>
                                <Button Content="Cleaner's sink"  Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_CleanersSink" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Expander>
                        <Expander Header="SYMBOL PLACEMENT — DRAINAGE POINTS" Style="{StaticResource PlumbExpander}">
                            <WrapPanel Margin="4">
                                <Button Content="Floor drain (round)"  Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_FloorDrainRound"  Click="Cmd_Click"/>
                                <Button Content="Floor drain (square)" Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_FloorDrainSquare" Click="Cmd_Click"/>
                                <Button Content="Yard gulley"          Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_Gulley"           Click="Cmd_Click"/>
                            </WrapPanel>
                        </Expander>
                        <Expander Header="SYMBOL PLACEMENT — VALVES &amp; ACCESSORIES" Style="{StaticResource PlumbExpander}">
                            <WrapPanel Margin="4">
                                <Button Content="Gate valve"      Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_GateValve"      Click="Cmd_Click"/>
                                <Button Content="Globe valve"     Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_GlobeValve"     Click="Cmd_Click"/>
                                <Button Content="Ball valve"      Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_BallValve"      Click="Cmd_Click"/>
                                <Button Content="Butterfly valve" Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_ButterflyValve" Click="Cmd_Click"/>
                                <Button Content="Check valve"     Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_CheckValve"     Click="Cmd_Click"/>
                                <Button Content="PRV"             Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_PRV"            Click="Cmd_Click"/>
                                <Button Content="Y-strainer"      Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_Strainer"       Click="Cmd_Click"/>
                                <Button Content="Flex connector"  Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_FlexConn"       Click="Cmd_Click"/>
                            </WrapPanel>
                        </Expander>
                        <Expander Header="SYMBOL PLACEMENT — EQUIPMENT" Style="{StaticResource PlumbExpander}">
                            <WrapPanel Margin="4">
                                <Button Content="HWC (direct)"   Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_HWCDirect"   Click="Cmd_Click"/>
                                <Button Content="HWC (indirect)" Style="{StaticResource PlumbSymBtn}" Tag="PlumbSym_HWCIndirect" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Expander>

                        <TextBlock Text="BROWSE ALL PLUMBING SYMBOLS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="🔍 Browse &amp; Place…" Style="{StaticResource PlumbPrimaryBtn}"
                                Tag="PlumbSym_BrowseAll" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Full searchable picker across all 24 plumbing symbols — search by name, subcategory, or BS EN standard."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============== TAB 4: STORM ============== -->
            <TabItem Header="STORM">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="ROOF DRAINAGE" Style="{StaticResource PlumbSectionHeader}"/>
                        <Expander Header="ROOF DRAINAGE INPUTS" Style="{StaticResource PlumbExpander}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Roof area (m²)" Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtRoofArea"  Text="1000" Margin="2" FontSize="10"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Runoff coeff." Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtRunoff"     Text="1.0"  Margin="2" FontSize="10"/>
