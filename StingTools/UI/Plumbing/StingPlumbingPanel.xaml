            <!-- ============== TAB 5: SPECIALTY ============== -->
            <TabItem Header="SPECIALTY">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="BACKFLOW / CROSS-CONNECTION (BS EN 1717)" Style="{StaticResource PlumbSectionHeader}"/>
                        <WrapPanel>
                            <Button Content="Fluid Category Audit" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumbing_BackflowAudit" Click="Cmd_Click"
                                    ToolTip="Classify pipes Cat 1-5 and recommend SCV/DCV/RPZ/Air-gap."/>
                            <Button Content="Cross-Connection Scan" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumbing_CrossConnection" Click="Cmd_Click"
                                    ToolTip="Graph walk potable → non-potable."/>
