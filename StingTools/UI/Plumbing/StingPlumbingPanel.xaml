<Page x:Class="StingTools.UI.Plumbing.StingPlumbingPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="STING Plumbing"
      Background="{DynamicResource PrimaryBg}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Phase C: shared button/section styling — single source of
                     truth. Plumbing carries no service-coded brand colours of
                     its own (BS 1710 DCW / DHW / HWS / SAN / RWD / GAS service
                     tints are applied via Revit view filters, not panel chrome).
                     Every button on this panel is neutral / Primary / muted, so
                     the shared dictionary covers 100% of the surface. -->
                <ResourceDictionary Source="/StingTools;component/UI/Resources/StingButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PlumbSectionHeader" TargetType="TextBlock" BasedOn="{StaticResource StingSectionHeader}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>
            <Style x:Key="PlumbLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Margin" Value="0,2,4,2"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelFg}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <!-- PlumbActionBtn now inherits the shared StingButton look
                 (rounded corners + hover lift + theme-driven surface).
                 Density tuned to the original Plumbing metrics
                 (Height 24, MinWidth 64). -->
            <Style x:Key="PlumbActionBtn" TargetType="Button" BasedOn="{StaticResource StingButton}">
                <Setter Property="MinWidth" Value="64"/>
                <Setter Property="Height" Value="24"/>
            </Style>
            <Style x:Key="PlumbToolBtn" TargetType="Button" BasedOn="{StaticResource PlumbActionBtn}">
                <Setter Property="MinWidth" Value="30"/>
                <Setter Property="Width" Value="30"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>
            <!-- PlumbPrimaryBtn now routes to the shared outline Primary
                 (teal border + text on transparent fill — matches the rest
                 of STING). Size override keeps the Plumbing density. -->
            <Style x:Key="PlumbPrimaryBtn" TargetType="Button" BasedOn="{StaticResource StingPrimaryButton}">
                <Setter Property="MinWidth" Value="100"/>
                <Setter Property="Height" Value="26"/>
            </Style>
            <Style x:Key="PlumbSymBtn" TargetType="Button" BasedOn="{StaticResource PlumbActionBtn}">
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style x:Key="PlumbExpander" TargetType="Expander">
                <Setter Property="Margin" Value="0,3"/>
                <Setter Property="Padding" Value="2"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelFg}"/>
                <Setter Property="Background" Value="{DynamicResource SecondaryBg}"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title strip -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBg}" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💧 STING PLUMBING" FontWeight="Bold" FontSize="13"
                           Foreground="{DynamicResource HeaderFg}"/>
                <TextBlock x:Name="txtPlumbStatus" Text="Ready" FontSize="9" Margin="14,0,0,0"
                           Foreground="{DynamicResource HeaderFg}" Opacity="0.7"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Project context strip: Standard + Building type + Temperature regime -->
        <Border Grid.Row="1" Background="{DynamicResource SecondaryBg}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Standard:" Style="{StaticResource PlumbLabel}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbStandard" Margin="0,1" FontSize="10"
                          SelectionChanged="cmbStandard_SelectionChanged">
                    <ComboBoxItem Content="BS EN 12056 (UK / EU)" IsSelected="True" Tag="BS_EN_12056"/>
                    <ComboBoxItem Content="IPC 2021 (US)"             Tag="IPC_2021"/>
                    <ComboBoxItem Content="UPC 2021 (US)"             Tag="UPC_2021"/>
                    <ComboBoxItem Content="NCC AU"                    Tag="NCC_AU"/>
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Building:" Style="{StaticResource PlumbLabel}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbBuilding" Margin="0,1" FontSize="10"
                          SelectionChanged="cmbBuilding_SelectionChanged">
                    <ComboBoxItem Content="Office"            IsSelected="True" Tag="Office"/>
                    <ComboBoxItem Content="Residential"                          Tag="Residential"/>
                    <ComboBoxItem Content="Healthcare (HTM 04-01)"               Tag="Healthcare"/>
                    <ComboBoxItem Content="Hospitality / Hotel"                  Tag="Hospitality"/>
                    <ComboBoxItem Content="Industrial"                           Tag="Industrial"/>
                    <ComboBoxItem Content="Education"                            Tag="Education"/>
                </ComboBox>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Regime:" Style="{StaticResource PlumbLabel}"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbRegime" Margin="0,1" FontSize="10"
                          SelectionChanged="cmbRegime_SelectionChanged">
                    <ComboBoxItem Content="DCW + DHW + Recirc" IsSelected="True" Tag="DCW_DHW_Recirc"/>
                    <ComboBoxItem Content="DCW + DHW (no recirc)"                Tag="DCW_DHW"/>
                    <ComboBoxItem Content="DCW only"                             Tag="DCW"/>
                    <ComboBoxItem Content="Blended / TMV-led"                    Tag="Blended"/>
                </ComboBox>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" x:Name="tabPlumb" Background="{DynamicResource PrimaryBg}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Padding" Value="6,3"/>
                    <Setter Property="Foreground" Value="{DynamicResource TabFg}"/>
                    <Setter Property="Background" Value="{DynamicResource TabBg}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TabSelectedFg}"/>
                            <Setter Property="Background" Value="{DynamicResource TabSelectedBg}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ============== TAB 0: SYSTEM ============== -->
            <TabItem Header="SYSTEM">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="PROJECT &amp; STANDARDS" Style="{StaticResource PlumbSectionHeader}"/>
                        <Grid Margin="2,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Building type"          Style="{StaticResource PlumbLabel}"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbCfgBldgType" Margin="0,2"
                                       SelectionChanged="cmbCfgBldgType_SelectionChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Drainage standard"      Style="{StaticResource PlumbLabel}"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbCfgDrainStd" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Supply standard"        Style="{StaticResource PlumbLabel}"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbCfgSupplyStd" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="K factor (frequency)"   Style="{StaticResource PlumbLabel}"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtCfgKFactor" Margin="0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Flush-valve majority"   Style="{StaticResource PlumbLabel}"/>
                            <CheckBox  Grid.Row="4" Grid.Column="1" x:Name="chkCfgFlushValve" Margin="0,4"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Occupancy"              Style="{StaticResource PlumbLabel}"/>
                            <TextBox   Grid.Row="5" Grid.Column="1" x:Name="txtCfgOccupancy" Margin="0,2"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Beds / Workstations"    Style="{StaticResource PlumbLabel}"/>
                            <TextBox   Grid.Row="6" Grid.Column="1" x:Name="txtCfgBeds" Margin="0,2"/>
                        </Grid>

                        <Expander Header="PIPE MATERIALS" Style="{StaticResource PlumbExpander}" IsExpanded="True">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DCW"      Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbCfgMatDCW"      Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="DHW"      Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbCfgMatDHW"      Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Drainage" Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbCfgMatDrainage" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Storm"    Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="cmbCfgMatStorm"    Margin="0,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Vent"     Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="4" Grid.Column="1" x:Name="cmbCfgMatVent"     Margin="0,2"/>
                            </Grid>
                        </Expander>

                        <Expander Header="VELOCITY LIMITS (m/s)" Style="{StaticResource PlumbExpander}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DCW Max"            Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtCfgVelDCWMax"  Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="DHW Max"            Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtCfgVelDHWMax"  Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Drain SelfCleansing" Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtCfgVelDrnSelf" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Drain Max"          Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtCfgVelDrnMax"  Margin="0,2"/>
                            </Grid>
                        </Expander>

                        <Expander Header="SLOPE (%)" Style="{StaticResource PlumbExpander}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DN32–50"  Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtCfgSlopeDn3250" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="DN75–100" Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtCfgSlopeDn75100" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="DN150"    Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtCfgSlopeDn150" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Target"   Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtCfgSlopeTarget" Margin="0,2"/>
                            </Grid>
                        </Expander>

                        <Expander Header="SUPPLY PRESSURE &amp; HYDRAULICS" Style="{StaticResource PlumbExpander}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Entry pressure (bar)"    Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtCfgSupplyPres"      Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Δp (Pa/m)"           Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtCfgMaxDpPaPerM"     Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Head-loss method"        Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbCfgHeadLossMethod"  Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sizing strategy"         Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="cmbCfgSizingStrategy"  Margin="0,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="DXF AutoCAD version"     Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="4" Grid.Column="1" x:Name="cmbCfgDxfAcad"         Margin="0,2"/>
                            </Grid>
                        </Expander>

                        <WrapPanel Margin="0,8,0,2">
                            <Button Content="💾 Save System Config" Style="{StaticResource PlumbPrimaryBtn}"
                                    Tag="Plumb_SaveSystemConfig" Click="Cmd_Click"
                                    ToolTip="Persists the inline form values to &lt;project&gt;/_BIM_COORD/plumbing_system_config.json and stamps ProjectInformation."/>
                            <Button Content="↻ Reload From Disk" Style="{StaticResource PlumbActionBtn}"
                                    Click="btnCfgReload_Click"
                                    ToolTip="Discard pending edits and reload the saved config from disk."/>
                        </WrapPanel>

                        <TextBlock Text="WORKFLOWS" Style="{StaticResource PlumbSectionHeader}" Margin="0,12,0,2"/>
                        <Button Content="▶ Run Full Plumbing Audit (RAG)" Style="{StaticResource PlumbPrimaryBtn}"
                                Tag="Plumb_FullAudit" Click="Cmd_Click"
                                ToolTip="Runs all five compliance domains (Supply / Drainage / Vents / Backflow / HTM 04-01) and produces the RAG dashboard."/>

                        <TextBlock Text="ACTIVITY LOG" Style="{StaticResource PlumbSectionHeader}" Margin="0,12,0,2"/>
                        <TextBox x:Name="txtPlumbResultLog" Height="120" Margin="0,2"
                                 FontSize="10" FontFamily="Consolas"
                                 IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" AcceptsReturn="True"
                                 ToolTip="Inline summary of every command result (no modal popups). Newest at top."/>
                        <WrapPanel Margin="0,2">
                            <Button Content="Clear log" Style="{StaticResource PlumbActionBtn}"
                                    Click="btnClearResultLog_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============== TAB 1: SUPPLY ============== -->
            <TabItem Header="SUPPLY">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="FIXTURE UNIT SCAN" Style="{StaticResource PlumbSectionHeader}"/>
                        <WrapPanel Margin="0,2">
                            <Button Content="🔍" Style="{StaticResource PlumbToolBtn}"
                                    Tag="Plumb_ScanFixtures" Click="Cmd_Click"
                                    ToolTip="Walk OST_PlumbingFixtures and write PLM_DRN_DU / PLM_SUP_LU_CW / PLM_SUP_LU_HW / PLM_SUP_WSFU."/>
                            <Button Content="Scan Fixtures (DU / LU / WSFU)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_ScanFixtures" Click="Cmd_Click"/>
                        </WrapPanel>
                        <TextBox x:Name="txtFixtureFilter" Margin="0,4" FontSize="10"
                                 ToolTip="Filter fixtures by type / room" TextChanged="txtFixtureFilter_TextChanged"/>
                        <DataGrid x:Name="FixtureGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  FontSize="10" RowHeight="22" Height="160" Margin="0,2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type"     Binding="{Binding TypeName}" Width="*"/>
                                <DataGridTextColumn Header="Qty"      Binding="{Binding Qty}"      Width="40"/>
                                <DataGridTextColumn Header="DU"       Binding="{Binding DuDisplay}"  Width="44"/>
                                <DataGridTextColumn Header="LU cw"    Binding="{Binding LuCwDisplay}" Width="48"/>
                                <DataGridTextColumn Header="LU hw"    Binding="{Binding LuHwDisplay}" Width="48"/>
                                <DataGridTextColumn Header="WSFU"     Binding="{Binding WsfuDisplay}" Width="48"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="txtFixtureSummary" Margin="0,2" FontSize="10"
                                   Text="0 fixture types · 0 fixtures · 0 DU total · 0 LU total"
                                   Foreground="{DynamicResource PanelFg}" Opacity="0.8"/>

                        <TextBlock Text="COLD + HOT WATER SIZING" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Expander Header="SIZING OPTIONS" Style="{StaticResource PlumbExpander}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Velocity limit (m/s)" Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtSupVelocity" Text="2.0" Margin="2" FontSize="10"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Sizing method"        Style="{StaticResource PlumbLabel}"/>
                                <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbSupMethod"      Margin="2" FontSize="10">
                                    <ComboBoxItem Content="Hunter (WSFU)"           IsSelected="True" Tag="Hunter"/>
                                    <ComboBoxItem Content="BS EN 806-3 (LU)"                          Tag="BSEN806"/>
                                    <ComboBoxItem Content="DIN 1988 (LU)"                             Tag="DIN1988"/>
                                </ComboBox>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Min pressure (kPa)"    Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtSupMinPressure" Text="100" Margin="2" FontSize="10"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Max pressure (kPa)"    Style="{StaticResource PlumbLabel}"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtSupMaxPressure" Text="500" Margin="2" FontSize="10"/>
                            </Grid>
                        </Expander>
                        <WrapPanel Margin="0,4">
                            <Button Content="▶ Size DCW / DHW pipes" Style="{StaticResource PlumbPrimaryBtn}"
                                    Tag="Plumb_SizeSupply" Click="Cmd_Click"
                                    ToolTip="Hazen-Williams + Swamee-Jain. Uses BS EN 806-3 LU table or Hunter WSFU per SYSTEM config."/>
                        </WrapPanel>

                        <TextBlock Text="DHW RECIRCULATION" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="Recirc loop + DRV pre-set" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumbing_RecircBalance" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Pipe heat-loss → pump duty + DRV kV pre-sets per branch."/>

                        <TextBlock Text="PRESSURE ANALYSIS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <Button Content="Pressure Check (per level)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_PressureCheck" Click="Cmd_Click"
                                    ToolTip="Static pressure per level against BS 8558 minimums; flags PRV requirements."/>
                            <Button Content="PRV Schedule (legacy)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumbing_PRVSchedule" Click="Cmd_Click"
                                    ToolTip="Pre-existing static PRV scheduler — retained."/>
                        </WrapPanel>
                        <Expander Header="PRV REGISTER" Style="{StaticResource PlumbExpander}">
                            <DataGrid x:Name="PrvGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      FontSize="10" RowHeight="22" Height="120" Margin="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag"     Binding="{Binding Tag}"      Width="80"/>
                                    <DataGridTextColumn Header="Loc"     Binding="{Binding Location}" Width="*"/>
                                    <DataGridTextColumn Header="Set kPa" Binding="{Binding SetKpa}"   Width="64"/>
                                    <DataGridTextColumn Header="Inlet"   Binding="{Binding InletKpa}" Width="64"/>
                                    <DataGridTextColumn Header="Status"  Binding="{Binding Status}"   Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <TextBlock Text="EXPANSION VESSEL + TMV REGISTER" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <Button Content="Size Expansion Vessel (BS 7074-1)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_ExpVessel" Click="Cmd_Click"
                                    ToolTip="DHW expansion vessel sizing with default 200 L / ΔT 50 °C."/>
                            <Button Content="Build TMV Register" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_TMVRegister" Click="Cmd_Click"
                                    ToolTip="Scans elements with PLM_TMV_CLASS_TXT set and reports the register."/>
                        </WrapPanel>
                        <Expander Header="TMV REGISTER" Style="{StaticResource PlumbExpander}">
                            <DataGrid x:Name="TmvGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      FontSize="10" RowHeight="22" Height="120" Margin="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag"      Binding="{Binding Tag}"        Width="80"/>
                                    <DataGridTextColumn Header="Class"    Binding="{Binding Class}"      Width="60"/>
                                    <DataGridTextColumn Header="Set °C"   Binding="{Binding SetC}"       Width="60"/>
                                    <DataGridTextColumn Header="Loc"      Binding="{Binding Location}"   Width="*"/>
                                    <DataGridTextColumn Header="Status"   Binding="{Binding Status}"     Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <TextBlock Text="LEGIONELLA" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="Dead-Leg Scan (HSG 274)" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumbing_DeadLegScan" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Flag legs > 5×D or > 5 m on DCW/DHW/blended."/>
                        <Expander Header="DEAD-LEG RESULTS" Style="{StaticResource PlumbExpander}">
                            <DataGrid x:Name="DeadLegGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      FontSize="10" RowHeight="22" Height="120" Margin="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pipe"    Binding="{Binding PipeId}"     Width="*"/>
                                    <DataGridTextColumn Header="Service" Binding="{Binding Service}"    Width="68"/>
                                    <DataGridTextColumn Header="L (m)"   Binding="{Binding LengthDisplay}" Width="60"/>
                                    <DataGridTextColumn Header="L/D"     Binding="{Binding LdDisplay}"  Width="48"/>
                                    <DataGridTextColumn Header="Verdict" Binding="{Binding Verdict}"    Width="64"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============== TAB 2: DRAINAGE ============== -->
            <TabItem Header="DRAINAGE">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="FIXTURE UNIT AGGREGATION" Style="{StaticResource PlumbSectionHeader}"/>
                        <Button Content="🔍 Scan Fixtures (DU)" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumb_ScanFixtures" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Same scanner as SUPPLY tab — reports the DU column for drainage."/>

                        <TextBlock Text="PIPE SIZING" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Expander Header="DRAINAGE SIZING OPTIONS" Style="{StaticResource PlumbExpander}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
