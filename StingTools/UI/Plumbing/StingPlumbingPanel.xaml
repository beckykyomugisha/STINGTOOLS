                                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="txtRagDrainA" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="txtRagDrainG" Style="{StaticResource PlumbLabel}" Text="0"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Vents"      Style="{StaticResource PlumbLabel}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtRagVentsR" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" x:Name="txtRagVentsA" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" x:Name="txtRagVentsG" Style="{StaticResource PlumbLabel}" Text="0"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Backflow"   Style="{StaticResource PlumbLabel}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtRagBfR" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" x:Name="txtRagBfA" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="4" Grid.Column="3" x:Name="txtRagBfG" Style="{StaticResource PlumbLabel}" Text="0"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="HTM 04-01"  Style="{StaticResource PlumbLabel}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtRagHtmR" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="5" Grid.Column="2" x:Name="txtRagHtmA" Style="{StaticResource PlumbLabel}" Text="0"/>
                                <TextBlock Grid.Row="5" Grid.Column="3" x:Name="txtRagHtmG" Style="{StaticResource PlumbLabel}" Text="0"/>
                            </Grid>
                        </Expander>

                        <TextBlock Text="PER-DOMAIN AUDITS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <StackPanel>
                            <Button Content="Trap &amp; Vent Audit"      Style="{StaticResource PlumbActionBtn}" Tag="Plumbing_TrapVentAudit"   Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                            <Button Content="Stack Capacity"             Style="{StaticResource PlumbActionBtn}" Tag="Plumbing_StackCapacity"   Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                            <Button Content="Fluid Category Audit"       Style="{StaticResource PlumbActionBtn}" Tag="Plumbing_BackflowAudit"   Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                            <Button Content="Cross-Connection Scan"      Style="{StaticResource PlumbActionBtn}" Tag="Plumbing_CrossConnection" Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                            <Button Content="Dead-Leg Scan"              Style="{StaticResource PlumbActionBtn}" Tag="Plumbing_DeadLegScan"     Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                            <Button Content="Material Audit"             Style="{StaticResource PlumbActionBtn}" Tag="Plumbing_MaterialAudit"   Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <TextBlock Text="AUDIT FINDINGS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <DataGrid x:Name="AuditFindingsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  FontSize="10" RowHeight="22" Height="160" Margin="0,2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Sev"      Binding="{Binding Severity}" Width="50"/>
                                <DataGridTextColumn Header="Domain"   Binding="{Binding Domain}"   Width="80"/>
                                <DataGridTextColumn Header="Message"  Binding="{Binding Message}"  Width="*"/>
                                <DataGridTextColumn Header="Element"  Binding="{Binding ElementRef}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============== TAB 7: DOCS ============== -->
            <TabItem Header="DOCS">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>
                        <TextBlock Text="SCHEDULES" Style="{StaticResource PlumbSectionHeader}"/>
                        <StackPanel>
                            <Button Content="Pipe Schedule" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_PipeSchedule" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                    ToolTip="Group pipes by system + DN + material with totals."/>
                            <Button Content="Manhole / Access Chamber Schedule" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_ManholeSchedule" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                    ToolTip="Reads PLM_DRN_INV_* params from manholes / inspection chambers."/>
                            <Button Content="TMV Register" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_TMVRegister" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                    ToolTip="Cross-listed with the SUPPLY tab."/>
                        </StackPanel>

                        <Expander Header="MANHOLE / ACCESS CHAMBER GRID" Style="{StaticResource PlumbExpander}">
                            <DataGrid x:Name="ManholeGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      FontSize="10" RowHeight="22" Height="120" Margin="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag"      Binding="{Binding Tag}"          Width="80"/>
                                    <DataGridTextColumn Header="US inv"   Binding="{Binding UsInvDisplay}" Width="64"/>
                                    <DataGridTextColumn Header="DS inv"   Binding="{Binding DsInvDisplay}" Width="64"/>
                                    <DataGridTextColumn Header="Cover"    Binding="{Binding CoverDisplay}" Width="64"/>
                                    <DataGridTextColumn Header="Depth"    Binding="{Binding DepthDisplay}" Width="64"/>
                                    <DataGridTextColumn Header="Loc"      Binding="{Binding Location}"     Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <TextBlock Text="BOQ + ISOMETRICS" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <Button Content="Plumbing BOQ" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_BOQ" Click="Cmd_Click"
                                    ToolTip="Pipes (m) + fittings (nr) + accessories (nr) — full BoQ row dump."/>
                            <Button Content="Plumbing Isometric (drawing-type)" Style="{StaticResource PlumbActionBtn}"
                                    Tag="Plumb_Isometric" Click="Cmd_Click"
                                    ToolTip="Routes through DrawingTypeRegistry — plumb-drainage-A1-1to100 / plumb-supply-A1-1to100."/>
                        </WrapPanel>
                        <Expander Header="BOQ ROWS" Style="{StaticResource PlumbExpander}">
                            <DataGrid x:Name="BoqGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      FontSize="10" RowHeight="22" Height="160" Margin="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Item"     Binding="{Binding Item}"      Width="*"/>
                                    <DataGridTextColumn Header="Material" Binding="{Binding Material}"  Width="80"/>
                                    <DataGridTextColumn Header="DN"       Binding="{Binding Dn}"        Width="48"/>
                                    <DataGridTextColumn Header="Qty"      Binding="{Binding QtyDisplay}" Width="56"/>
                                    <DataGridTextColumn Header="Unit"     Binding="{Binding Unit}"      Width="44"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <TextBlock Text="COMMISSIONING SHELL" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <Button Content="Stage Commissioning Pack" Style="{StaticResource PlumbActionBtn}"
                                Tag="Plumb_CommPack" Click="Cmd_Click" HorizontalAlignment="Stretch"
                                ToolTip="Plans the commissioning artefact folder under _BIM_COORD/plumbing/commissioning."/>

                        <!-- Group 5: advanced plumbing engines surfaced (were complete but had no button) -->
                        <TextBlock Text="ADVANCED ENGINES (network · spools · water safety)" Style="{StaticResource PlumbSectionHeader}" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <Button Content="Pump Select" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_PumpSelect" Click="Cmd_Click" ToolTip="Derive duty point and size the pump from the catalogue."/>
                            <Button Content="Booster Set" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_BoosterSet" Click="Cmd_Click" ToolTip="Break-tank volume + booster-set duty sizing."/>
                            <Button Content="Build Network" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_BuildNetwork" Click="Cmd_Click" ToolTip="Build the pipe network graph; accumulate DFU/pressure; report the critical path."/>
                            <Button Content="Network Pressure" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_NetworkPressure" Click="Cmd_Click" ToolTip="Colour pipes by pressure zone and write kPa params."/>
                            <Button Content="Network Stats" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_NetworkStats" Click="Cmd_Click" ToolTip="Report network stats by system / DFU / fixtures."/>
                            <Button Content="Pressure Zones" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_PressureZone" Click="Cmd_Click" ToolTip="Colour supply pipes by pressure zone."/>
                            <Button Content="Slope Automation" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_SlopeAutomation" Click="Cmd_Click" ToolTip="Apply BS EN 12056-2 minimum slopes to drainage."/>
                            <Button Content="Generate Spools" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_GenerateSpools" Click="Cmd_Click" ToolTip="Group pipes into spools, stamp numbers, build assemblies."/>
                            <Button Content="Spool Schedule" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_SpoolSchedule" Click="Cmd_Click" ToolTip="Create/refresh the pipe-spool schedule view."/>
                            <Button Content="Drainage Schematic" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_DrainageSchematic" Click="Cmd_Click" ToolTip="Generate the drainage riser schematic drafting view."/>
                            <Button Content="TMV Engine" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_TMVEngine" Click="Cmd_Click" ToolTip="Scan TMVs and export the CSV register."/>
                            <Button Content="Legionella Report" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_LegionellaReport" Click="Cmd_Click" ToolTip="ACOP L8 Legionella risk report (docx/text)."/>
                            <Button Content="Water Safety Plan" Style="{StaticResource PlumbActionBtn}" Tag="Plumb_WaterSafetyPlan" Click="Cmd_Click" ToolTip="RAG dashboard: dead legs / TMV / backflow."/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status strip at the very bottom — mirrors the Electrical panel pattern.
             Phase C: hardcoded navy → theme-driven HeaderBg so the footer cycles
             with ThemeManager.CycleTheme() like every other chrome surface. -->
        <Border Grid.Row="3" Background="{DynamicResource HeaderBg}" Padding="10,4">
            <TextBlock x:Name="txtPlumbFooter"
                       Text="STING Plumbing — configure SYSTEM tab first · BS EN 12056 default"
                       Foreground="{DynamicResource HeaderFg}" FontSize="11"/>
        </Border>
    </Grid>
</Page>
