                            <Border Style="{StaticResource WizGroupBox}" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource WizSubHeader}" Text="Low Voltage Systems" FontWeight="Normal"/>
                                    <CheckBox x:Name="chkLVComms" Style="{StaticResource WizCheck}" Content="COM — Communications (telephone, intercom)" IsChecked="True"/>
                                    <CheckBox x:Name="chkLVData" Style="{StaticResource WizCheck}" Content="ICT — Data / Network (CAT6, fibre, WiFi)" IsChecked="True"/>
                                    <CheckBox x:Name="chkLVSecurity" Style="{StaticResource WizCheck}" Content="SEC — Security / Access Control (CCTV, card readers)"/>
                                    <CheckBox x:Name="chkLVNurse" Style="{StaticResource WizCheck}" Content="NCL — Nurse Call (clinical environments)"/>

                                    <TextBlock Style="{StaticResource WizSubHeader}" Text="Design Parameters" FontWeight="Normal" Margin="0,6,0,3"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Cable standard:"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbLVCable" Style="{StaticResource WizCombo}" Width="180" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="CAT6A" IsSelected="True"/>
                                            <ComboBoxItem Content="CAT6"/>
                                            <ComboBoxItem Content="CAT7"/>
                                            <ComboBoxItem Content="Fibre Optic (OM3/OM4)"/>
                                            <ComboBoxItem Content="Mixed (CAT6A + Fibre)"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <!-- ─── Generic [G] ─── -->
                        <Expander x:Name="expGen" Header="[G] Generic / Specialty" IsExpanded="False" Margin="0,2"
                                  FontWeight="SemiBold" FontSize="11" Foreground="#795548">
                            <Border Style="{StaticResource WizGroupBox}" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource WizSubHeader}" Text="Generic Equipment Scope" FontWeight="Normal"/>
                                    <CheckBox x:Name="chkGenSpecialty" Style="{StaticResource WizCheck}" Content="Specialty equipment (kitchen, laundry, lab)"/>
                                    <CheckBox x:Name="chkGenMedical" Style="{StaticResource WizCheck}" Content="Medical equipment (clinical, imaging, therapy)"/>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ PAGE 6: AUTOMATION OPTIONS ═══ -->
            <TabItem Header="Automation">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource WizSectionHeader}"
                                   Text="6. Automation Options"/>
                        <TextBlock Text="Choose what to automate. Uncheck items you want to do manually later."
                                   FontSize="10" Foreground="#777" Margin="0,0,0,8"/>

                        <Border Style="{StaticResource WizGroupBox}" Background="#F3E5F5">
                            <StackPanel>
                                <TextBlock Style="{StaticResource WizSubHeader}" Text="Performance"/>
                                <CheckBox x:Name="chkFastMode" Style="{StaticResource WizCheck}"
                                          Content="Fast setup (skip bulk steps when project already populated — recommended)" IsChecked="True"
                                          ToolTip="Scans document first; if materials/schedules/templates already exist at ≥80% of target, the step is skipped. Can reduce 30+ min runs to under 5 min on re-runs."/>
                                <CheckBox x:Name="chkSuspendUIUpdates" Style="{StaticResource WizCheck}"
                                          Content="Suspend view refresh during setup (recommended for models &gt; 100 MB)" IsChecked="True"
                                          ToolTip="Switches to a blank drafting view while setup runs so Revit doesn't regenerate the active view on every transaction."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizGroupBox}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource WizSubHeader}" Text="Parameters &amp; Data"/>
                                <CheckBox x:Name="chkLoadParams" Style="{StaticResource WizCheck}"
                                          Content="Load shared parameters (200+ STING parameters)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateMaterials" Style="{StaticResource WizCheck}"
                                          Content="Create materials (815 BLE + 464 MEP from CSV)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateFamilyTypes" Style="{StaticResource WizCheck}"
                                          Content="Create family types (walls, floors, ceilings, roofs, ducts, pipes, cable trays, conduits)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateSchedules" Style="{StaticResource WizCheck}"
                                          Content="Create schedules (168 definitions from CSV)" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizGroupBox}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource WizSubHeader}" Text="Styles &amp; Templates"/>
                                <CheckBox x:Name="chkUseLatestTemplateSetup" Style="{StaticResource WizCheck}"
                                          Content="Use latest Template Setup pipeline (15-step: fill/line/object/text/dim styles + filters + 23 templates + VG + family params + schedules)"
                                          IsChecked="True"
                                          ToolTip="Runs the full TemplateSetupWizard ordering. Overrides the individual steps below when checked."/>
                                <CheckBox x:Name="chkCreateStyles" Style="{StaticResource WizCheck}"
                                          Content="Create styles (fill/line patterns, line/text/dimension/object styles)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateFilters" Style="{StaticResource WizCheck}"
                                          Content="Create view filters (28+ discipline/status filters)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateTemplates" Style="{StaticResource WizCheck}"
                                          Content="Create view templates (23 with VG overrides)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreatePhases" Style="{StaticResource WizCheck}"
                                          Content="Audit project phases (Revit API cannot create phases — reports missing ones)" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizGroupBox}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource WizSubHeader}" Text="Documentation"/>
                                <CheckBox x:Name="chkCreateViews" Style="{StaticResource WizCheck}"
                                          Content="Create views (plans + RCPs per level per discipline)" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateDependents" Style="{StaticResource WizCheck}"
                                          Content="Create dependent views from scope boxes (if any exist)"/>
                                <CheckBox x:Name="chkCreateSheets" Style="{StaticResource WizCheck}"
                                          Content="Create sheets with auto-numbering and viewport placement" IsChecked="True"/>
                                <CheckBox x:Name="chkCreateSections" Style="{StaticResource WizCheck}"
                                          Content="Create building sections from grids"/>
                                <CheckBox x:Name="chkCreateElevations" Style="{StaticResource WizCheck}"
                                          Content="Create 4 exterior elevations (N/S/E/W)" IsChecked="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ PAGE 7: STANDARDS REGION ═══ -->
            <TabItem Header="Region">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource WizSectionHeader}"
                                   Text="7. Standards &amp; Region"/>
                        <TextBlock Text="Pick the regional preset that drives every Standards-aware command (cable size, sprinkler design, EUI benchmark, …). The Run step writes PROJECT_REGION onto Project Information so the choice travels with the .rvt."
                                   FontSize="10" Foreground="#777" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Preset list -->
                            <Border Grid.Column="0" Style="{StaticResource WizGroupBox}" Padding="0">
                                <ListBox x:Name="lstRegionPresets"
                                         SelectionChanged="LstRegionPresets_SelectionChanged"
                                         BorderThickness="0" Height="320"/>
                            </Border>

                            <!-- Resolved bindings preview -->
                            <Border Grid.Column="1" Style="{StaticResource WizGroupBox}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource WizSubHeader}" Text="Resolved standards"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Electrical"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtRegElec"   FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource WizLabel}" Text="HVAC"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtRegHvac"   FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Plumbing"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtRegPlumb"  FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Structural"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtRegStruct" FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Fire"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtRegFire"   FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Lighting"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtRegLight"  FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Energy"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtRegEnergy" FontSize="11" Margin="0,4"/>
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource WizLabel}" Text="Units"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="txtRegUnits"  FontSize="11" Margin="0,4"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="Tip: regions cover UK / USA / Europe / East Africa (KEBS, UNBS, TBS, RSB, SSBS, BBN, EAS) / South Africa (SANS) / Australia / International. The Run step persists PROJECT_REGION; subsequent document opens auto-sync."
                                   FontSize="10" Foreground="#777" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ PAGE 8: REVIEW + RUN ═══ -->
            <TabItem Header="Review">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource WizSectionHeader}"
                                   Text="7. Review &amp; Execute"/>
                        <TextBlock Text="Review your selections, then click Run to automate the entire project setup."
                                   FontSize="10" Foreground="#777" Margin="0,0,0,8"/>

                        <Border Style="{StaticResource WizGroupBox}">
                            <TextBox x:Name="txtReviewSummary" IsReadOnly="True"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="380" FontSize="11" FontFamily="Consolas"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#FAFAFA" BorderBrush="#CCC"
                                     Padding="8"/>
                        </Border>

                        <TextBlock Text="Each step runs independently. Use Ctrl+Z to undo if needed."
                                   FontSize="10" Foreground="#777" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- FOOTER: Navigation buttons -->
        <Border Grid.Row="2" Background="#EEE" Padding="12,8" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="txtPageInfo" FontSize="11" Foreground="#777"
                               VerticalAlignment="Center" Text="Step 1 of 8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnBack" Style="{StaticResource NavBtn}" Content="Back"
                            Click="BtnBack_Click" IsEnabled="False"/>
                    <Button x:Name="btnNext" Style="{StaticResource NavBtn}" Content="Next"
                            Click="BtnNext_Click"/>
                    <Button x:Name="btnRun" Style="{StaticResource RunBtn}" Content="Run Setup"
                            Click="BtnRun_Click" Visibility="Collapsed"/>
                    <Button Style="{StaticResource NavBtn}" Content="Cancel"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
