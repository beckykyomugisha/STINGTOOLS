<!--
  StingButtonStyles.xaml — shared button / section styling for the STING dock panel.

  ONE place to tune the look. Adjust the named brushes/sizes below and rebuild;
  every button that inherits these styles updates. Inspired by the dedicated
  STING panels (HVAC / Electrical / Plumbing / LPS) — restrained palette, no
  gradients, hover = subtle brightness lift (a translucent white overlay), never
  a colour swap.

  BRUSH ROLES (tune these):
    ActionBtnBrush     default action buttons (neutral, theme-light grey)
    PrimaryBtnBrush    key actions — Run / Apply / Build / Issue (mild accent)
    MutedBtnBrush      audits / diagnostics (subdued)
    DangerBtnBrush     delete / reset (red)
    SectionHeaderBrush function-group header text accent
    BtnFgBrush         default (dark) button text
    BtnHoverBrush      translucent overlay applied on hover (brightness lift)

  SIZES (tune these):
    BtnHeight  BtnMinWidth  BtnFontSize  SectionHeaderHeight
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══ Named brushes (single tuning point) ═══ -->
    <SolidColorBrush x:Key="ActionBtnBrush"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="PrimaryBtnBrush"    Color="#00897B"/>
    <SolidColorBrush x:Key="MutedBtnBrush"      Color="#DDE3E6"/>
    <SolidColorBrush x:Key="DangerBtnBrush"     Color="#C62828"/>
    <SolidColorBrush x:Key="SectionHeaderBrush" Color="#E8912D"/>
    <SolidColorBrush x:Key="BtnFgBrush"         Color="#333333"/>
    <SolidColorBrush x:Key="BtnBorderBrush"     Color="#CFD8DC"/>
    <!-- translucent white → lifts brightness over ANY base colour on hover -->
    <SolidColorBrush x:Key="BtnHoverBrush"      Color="#26FFFFFF"/>
    <!-- translucent black → subtle press feedback -->
    <SolidColorBrush x:Key="BtnPressBrush"      Color="#1A000000"/>

    <!-- ═══ Named sizes (single tuning point) ═══ -->
    <sys:Double x:Key="BtnHeight">24</sys:Double>
    <sys:Double x:Key="BtnMinWidth">64</sys:Double>
    <sys:Double x:Key="BtnFontSize">10</sys:Double>
    <sys:Double x:Key="SectionHeaderHeight">18</sys:Double>

    <!-- ═══ StingButton — default look (rounded, theme-neutral, hover lift) ═══ -->
    <Style x:Key="StingButton" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource ActionBtnBrush}"/>
        <Setter Property="Foreground"   Value="{StaticResource BtnFgBrush}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource BtnBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinWidth"     Value="{StaticResource BtnMinWidth}"/>
        <Setter Property="Height"       Value="{StaticResource BtnHeight}"/>
        <Setter Property="FontSize"     Value="{StaticResource BtnFontSize}"/>
        <Setter Property="Margin"       Value="2,1"/>
        <Setter Property="Padding"      Value="6,2"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                        <!-- hover/press overlays sit on top so the base colour is unchanged -->
                        <Border x:Name="overlay" CornerRadius="4" Background="{StaticResource BtnHoverBrush}"
                                Visibility="Collapsed"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="overlay" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="overlay" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="overlay" Property="Background" Value="{StaticResource BtnPressBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- implicit default: every <Button/> with no explicit Style gets StingButton -->
    <Style TargetType="Button" BasedOn="{StaticResource StingButton}"/>

    <!-- ═══ StingPrimaryButton — key actions (Run / Apply / Build / Issue) ═══ -->
    <Style x:Key="StingPrimaryButton" TargetType="Button" BasedOn="{StaticResource StingButton}">
        <Setter Property="Background" Value="{StaticResource PrimaryBtnBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBtnBrush}"/>
    </Style>

    <!-- ═══ StingMutedButton — audits / diagnostics ═══ -->
    <Style x:Key="StingMutedButton" TargetType="Button" BasedOn="{StaticResource StingButton}">
        <Setter Property="Background" Value="{StaticResource MutedBtnBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BtnFgBrush}"/>
    </Style>

    <!-- ═══ StingDangerButton — delete / reset ═══ -->
    <Style x:Key="StingDangerButton" TargetType="Button" BasedOn="{StaticResource StingButton}">
        <Setter Property="Background" Value="{StaticResource DangerBtnBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource DangerBtnBrush}"/>
    </Style>

    <!-- ═══ StingSectionHeader — function-group label ═══ -->
    <Style x:Key="StingSectionHeader" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="Foreground" Value="{StaticResource SectionHeaderBrush}"/>
        <Setter Property="Margin" Value="2,7,0,3"/>
        <Setter Property="MinHeight" Value="{StaticResource SectionHeaderHeight}"/>
    </Style>

    <!-- ═══ StingDivider — thin separator between groups ═══ -->
    <Style x:Key="StingDivider" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource BtnBorderBrush}"/>
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

</ResourceDictionary>
