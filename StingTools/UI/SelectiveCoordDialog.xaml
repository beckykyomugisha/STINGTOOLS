<Window x:Class="StingTools.UI.SelectiveCoordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="STING — Selective Coordination Viewer"
        Width="900" Height="660" MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E" Foreground="#FFEEEEEE">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="#FF4FC3F7" BorderThickness="1" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Background="#FF252525" Margin="4">
                    <TextBlock Text="Panel Hierarchy" Foreground="#FF4FC3F7"
                               FontSize="11" FontWeight="Bold" Margin="2,4"/>
                    <TreeView x:Name="HierarchyTree" Background="#FF252525"
                              Foreground="#FFEEEEEE" Height="320" BorderThickness="0"
                              SelectedItemChanged="Tree_SelectedItemChanged"/>
                    <TextBlock Text="Selected pair:" Foreground="#FF888888"
                               FontSize="10" Margin="2,8,2,2"/>
                    <TextBlock x:Name="SelectedPairLabel" Text="—" Foreground="#FFEEEEEE"
                               FontSize="11" TextWrapping="Wrap" Margin="2"/>
                </StackPanel>
                <Canvas x:Name="TccCanvas" Grid.Column="1"
                        Background="#FF1A1A1A" ClipToBounds="True"/>
            </Grid>
        </Border>
        <GroupBox Grid.Row="1" Header="Coordination Violations"
                  Foreground="#FFEEEEEE" BorderBrush="#FF4FC3F7" Margin="0,0,0,4">
            <DataGrid x:Name="ViolationsGrid"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="#FF252525" Foreground="#FFEEEEEE" RowBackground="#FF252525"
                      AlternatingRowBackground="#FF2A2A2A" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Upstream" Binding="{Binding UpstreamDevice}" Width="160"/>
                    <DataGridTextColumn Header="Downstream" Binding="{Binding DownstreamDevice}" Width="160"/>
                    <DataGridTextColumn Header="Fault (kA)" Binding="{Binding FaultKa, StringFormat='{}{0:0.00}'}" Width="80"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="#FF888888"/>
            <Button Content="Export CSV" Width="90" Height="28" Margin="0,0,6,0"
                    Click="ExportCsv_Click"
                    Background="#FF333333" Foreground="#FFEEEEEE"/>
            <Button Content="Close" Width="70" Height="28"
                    Click="Close_Click"
                    Background="#FF333333" Foreground="#FFEEEEEE"/>
        </StackPanel>
    </Grid>
</Window>
