<!--
    Themes/StingButtonStyles.xaml — shared button styles.

    Phase 184r. Extracted from StingDockPanel.xaml so dialogs that
    aren't children of the dock panel (BOQCostManagerWindow, the
    Variation editor, the future Payment Cert editor) can reference
    the same visual language via MergedDictionaries rather than
    re-declaring inline colour literals.

    Usage from a Window or UserControl:

        <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/Themes/StingButtonStyles.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </UserControl.Resources>

    The styles use DynamicResource for the neutral ButtonBg / ButtonFg
    / BorderColor brushes so theme switching (Light / Warm / Cool /
    Corporate) flows through automatically when ThemeManager applies
    the active palette.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ActionBtn — neutral baseline. Theme-aware via DynamicResource;
        ThemeManager flips ButtonBg / ButtonFg / BorderColor to repaint
        every styled button at once.
    -->
    <Style x:Key="ActionBtn" TargetType="Button">
        <Setter Property="MinWidth" Value="46"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Padding" Value="5,2"/>
        <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource ButtonFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
        <Setter Property="Background" Value="#4CAF50"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderBrush" Value="#388E3C"/>
    </Style>

    <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
        <Setter Property="Background" Value="#FF9800"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderBrush" Value="#F57C00"/>
    </Style>

    <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
        <Setter Property="Background" Value="#F44336"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderBrush" Value="#D32F2F"/>
    </Style>

    <Style x:Key="BlueBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
        <Setter Property="Background" Value="#2196F3"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderBrush" Value="#1976D2"/>
    </Style>

</ResourceDictionary>
