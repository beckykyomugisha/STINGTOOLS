                                                <Button Style="{StaticResource ActionBtn}" Content="Export positions" Tag="ExportCSV" Click="Cmd_Click" Width="96" Height="26"/>
                                                <Button Style="{StaticResource ActionBtn}" Content="Export schedules" Tag="ExportSchedule4D" Click="Cmd_Click" Width="98" Height="26"/>
