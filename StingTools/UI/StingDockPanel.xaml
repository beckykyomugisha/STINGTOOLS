<Page x:Class="StingTools.UI.StingDockPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="STING Tools"
      Background="{DynamicResource PrimaryBg}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Phase 3a: shared button/section styling — tune the look in this one file -->
                <ResourceDictionary Source="/StingTools;component/UI/Resources/StingButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <!-- FIX-3.3: DynamicResource bindings — ThemeManager.CycleTheme() now works -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,6,0,3"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style x:Key="GroupBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBg}"/>
        </Style>
        <!-- Phase 3a: local button styles now inherit the shared StingButton look
             (rounded corners + subtle hover lift + consistent metrics). Colours are
             preserved; the two SEMANTIC styles route to the shared accents so they
             retune from StingButtonStyles.xaml: GreenBtn→Primary, RedBtn→Danger. -->
        <Style x:Key="CatBtn" TargetType="Button" BasedOn="{StaticResource StingButton}">
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource StingButton}">
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <!-- GreenBtn = key actions (Run / Apply / Build / Issue) → shared Primary -->
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource StingPrimaryButton}">
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
        </Style>
        <!-- Phase A: emphasis buttons converted to outline (transparent fill,
             coloured border + text). Hover gets a faint tint of the brand colour. -->
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E65100"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#F57C00"/>
            <Setter Property="BorderThickness" Value="1.2"/>
        </Style>
        <!-- RedBtn = delete / reset → shared Danger -->
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource StingDangerButton}">
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
        </Style>
        <Style x:Key="BlueBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="1.2"/>
        </Style>
        <Style x:Key="PurpleBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6A1B9A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#7B1FA2"/>
            <Setter Property="BorderThickness" Value="1.2"/>
        </Style>
        <Style x:Key="TealBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00796B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#00796B"/>
            <Setter Property="BorderThickness" Value="1.2"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock" BasedOn="{StaticResource StingSectionHeader}">
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="{DynamicResource PanelFg}"/>
            <Setter Property="Margin" Value="0,3,0,1"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <!-- HEALTHCARE tab + ad-hoc button rows use this WrapPanel style. Missing
             this definition was throwing a 'Provide value on StaticResourceExtension'
             at XAML parse time, which killed the whole panel during construction. -->
        <Style x:Key="ButtonWrap" TargetType="WrapPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBg}" Padding="8,5,8,4">
            <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="STINGTOOLS V2.1" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource HeaderFg}"/>
                    <TextBlock x:Name="txtStatus" Text="Ready" FontSize="9" Foreground="{DynamicResource HeaderFg}" Opacity="0.7"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="txtSelCount" Text="sel 0" FontSize="9" Foreground="{DynamicResource HeaderFg}" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <!-- Pack 0 online/offline mode indicator. Click toggles the project mode and persists to sting_config.json. -->
                <Border Grid.Column="2" x:Name="bdrOffline" Background="#33000000" CornerRadius="3" Padding="4,1"
                        VerticalAlignment="Center" Margin="0,0,6,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="OfflineIndicator_Click"
                        ToolTip="STING online / offline project mode. Click to toggle and persist to &lt;project&gt;/_BIM_COORD/sting_config.json. Offline disables only the four network-touching commands (ACC Publish, SharePoint Export, Platform Sync, Planscape Connect); everything else runs normally in both modes.">
                    <TextBlock x:Name="txtOffline" Text="Online" FontSize="9" Foreground="{DynamicResource HeaderFg}" Opacity="0.85"/>
                </Border>
                <!-- INT-07 sync status indicator -->
                <Border Grid.Column="3" x:Name="bdrSync" Background="#33000000" CornerRadius="3" Padding="4,1"
                        VerticalAlignment="Center" Margin="0,0,6,0"
                        ToolTip="Click to force sync now"
                        MouseLeftButtonUp="SyncIndicator_Click" Cursor="Hand">
                    <TextBlock x:Name="txtSync" Text="Sync: off" FontSize="9" Foreground="{DynamicResource HeaderFg}" Opacity="0.85"/>
                </Border>
                <!-- Standards regional preset indicator. Click opens the region picker (StdExt_SetRegion). -->
                <Border Grid.Column="4" x:Name="bdrRegion" Background="#33000000" CornerRadius="3" Padding="4,1"
                        VerticalAlignment="Center" Margin="0,0,6,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="RegionIndicator_Click"
                        ToolTip="Active Standards region — click to switch (BS 7671 / NEC / IEC 60364, ASHRAE / CIBSE, NFPA / BS 9999, Eurocode / AISC, KEBS / UNBS / SANS, …). Persisted to PROJECT_REGION on the document.">
                    <TextBlock x:Name="txtRegion" Text="Region: —" FontSize="9" Foreground="{DynamicResource HeaderFg}" Opacity="0.85"/>
                </Border>
                <Button x:Name="btnPin" Grid.Column="5" Content="Pin" Width="30" Height="20"
                        FontSize="9" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"
                        ToolTip="Pin panel" Click="BtnPin_Click" Margin="0,0,2,0"/>
                <Button Grid.Column="6" Content="&#x2600;" Width="26" Height="20"
                        FontSize="13" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"
                        ToolTip="Cycle theme: Light / Warm / Cool / Corporate" Tag="CycleTheme" Click="Cmd_Click"/>
            </Grid>

            <!-- ═══ COMMAND BAR — NLP / AI entry point ═══ -->
            <Grid x:Name="cmdBarRow" Margin="0,5,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Grid>
                    <TextBox x:Name="txtCommandBar"
                             Height="23" FontSize="10"
                             Background="#22FFFFFF"
                             Foreground="{DynamicResource HeaderFg}"
                             BorderBrush="#7E57C2" BorderThickness="1"
                             Padding="7,2" VerticalContentAlignment="Center"
                             TextChanged="CommandBar_TextChanged"
                             KeyDown="CommandBar_KeyDown"
                             GotFocus="CommandBar_GotFocus"
                             LostFocus="CommandBar_LostFocus"/>
                    <TextBlock x:Name="txtCmdPlaceholder"
                               Text="Type a command, question, or design brief…"
                               FontSize="10" Foreground="{DynamicResource HeaderFg}"
                               Opacity="0.4" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="9,0,0,0"/>
                    <Popup x:Name="popSuggestions"
                           PlacementTarget="{Binding ElementName=txtCommandBar}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" Width="360">
                        <Border Background="#1A1A2E"
                                BorderBrush="#7E57C2"
                                BorderThickness="1,0,1,1" CornerRadius="0,0,4,4">
                            <ListBox x:Name="lstSuggestions"
                                     MaxHeight="230"
                                     Background="Transparent"
                                     Foreground="#E0E0E0"
                                     BorderThickness="0"
                                     SelectionMode="Single"
                                     MouseLeftButtonUp="Suggestion_MouseUp"
                                     KeyDown="Suggestions_KeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,5"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33AB47BC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#557E57C2"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,1">
                                            <TextBlock Text="{Binding CommandName}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="#E8E8FF"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9" Foreground="#9090B8"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
                <Button x:Name="btnAskAI" Grid.Column="1"
                        Content="AI" Width="26" Height="23"
                        Margin="2,0,0,0" FontSize="9" FontWeight="Bold"
                        Background="#7E57C2" Foreground="White"
                        BorderBrush="#5E35B1" BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Ask AI — design briefs, BIM knowledge, draft documents"
                        Click="AskAI_Click"/>
            </Grid>
            </StackPanel>
        </Border>

        <!-- Tab control —
             ━━ HVAC FENCE ━━
             Do NOT add a top-level <TabItem Header="HVAC"> here. HVAC has its own
             dedicated dockable panel (StingHvacPanel — see UI/StingHvacPanel.xaml,
             registered by Core/StingToolsApp.cs Phase 180), toggled from the
             "❄ HVAC" ribbon panel via ToggleHvacPanelCommand. Mixing the two
             surfaces is what created the original duplicate-Categories loop —
             keep HVAC ON its own pane.
             If you need HVAC actions reachable from this panel, raise a button
             tagged "ToggleHvacPanel" or "Hvac_*" that the StingCommandHandler
             switch forwards to the dockable HVAC panel; do NOT embed HVAC
             content here.
             ━━━━━━━━━━━━━━━━━ -->
        <TabControl Grid.Row="1" x:Name="tabMain" SelectionChanged="TabMain_SelectionChanged" Background="{DynamicResource PrimaryBg}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Padding" Value="5,3"/>
                    <Setter Property="Foreground" Value="{DynamicResource TabFg}"/>
                    <Setter Property="Background" Value="{DynamicResource TabBg}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TabSelectedFg}"/>
                            <Setter Property="Background" Value="{DynamicResource TabSelectedBg}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- =============== SELECT TAB =============== -->
            <TabItem Header="SELECT">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>

                        <!-- AI SMART SELECT -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="⚡ AI SMART SELECT"/>
                        <Border Style="{StaticResource GroupBorder}" BorderBrush="#FF9800">
                            <WrapPanel>
                                <Button Style="{StaticResource OrangeBtn}" Content="[AI] Predict" Tag="AIPredictSelect" Click="Cmd_Click" ToolTip="AI predict selection"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Similar" Tag="AISimilarSelect" Click="Cmd_Click" ToolTip="Select similar elements"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Chain" Tag="AIChainSelect" Click="Cmd_Click" ToolTip="Select connected chain"/>
                                <Button Style="{StaticResource BlueBtn}" Content="Cluster" Tag="AIClusterSelect" Click="Cmd_Click" ToolTip="Select spatial clusters"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Pattern" Tag="AIPatternSelect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Boundary" Tag="AIBoundarySelect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Outliers" Tag="AIOutliersSelect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Dense" Tag="AIDenseSelect" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- CATEGORY -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CATEGORY"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Lgt" Tag="SelectLighting" Click="Cmd_Click" ToolTip="Lighting Fixtures"/>
                                <Button Style="{StaticResource CatBtn}" Content="Elc" Tag="SelectElectrical" Click="Cmd_Click" ToolTip="Electrical Equipment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Mch" Tag="SelectMechanical" Click="Cmd_Click" ToolTip="Mechanical Equipment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Plb" Tag="SelectPlumbing" Click="Cmd_Click" ToolTip="Plumbing Fixtures"/>
                                <Button Style="{StaticResource CatBtn}" Content="Air" Tag="SelectAirTerminals" Click="Cmd_Click" ToolTip="Air Terminals"/>
                                <Button Style="{StaticResource CatBtn}" Content="Fur" Tag="SelectFurniture" Click="Cmd_Click" ToolTip="Furniture"/>
                                <Button Style="{StaticResource CatBtn}" Content="Dr" Tag="SelectDoors" Click="Cmd_Click" ToolTip="Doors"/>
                                <Button Style="{StaticResource CatBtn}" Content="Win" Tag="SelectWindows" Click="Cmd_Click" ToolTip="Windows"/>
                                <Button Style="{StaticResource CatBtn}" Content="Rm" Tag="SelectRooms" Click="Cmd_Click" ToolTip="Rooms"/>
                                <Button Style="{StaticResource CatBtn}" Content="Spr" Tag="SelectSprinklers" Click="Cmd_Click" ToolTip="Sprinklers"/>
                                <Button Style="{StaticResource CatBtn}" Content="Pipe" Tag="SelectPipes" Click="Cmd_Click" ToolTip="Pipes"/>
                                <Button Style="{StaticResource CatBtn}" Content="Duct" Tag="SelectDucts" Click="Cmd_Click" ToolTip="Ducts"/>
                                <Button Style="{StaticResource CatBtn}" Content="Cnd" Tag="SelectConduits" Click="Cmd_Click" ToolTip="Conduits"/>
                                <Button Style="{StaticResource CatBtn}" Content="Cbl" Tag="SelectCableTrays" Click="Cmd_Click" ToolTip="Cable Trays"/>
                                <Button Style="{StaticResource GreenBtn}" Content="ALL..." Tag="SelectAllTaggable" Click="Cmd_Click" ToolTip="ALL Taggable"/>
                                <Button Style="{StaticResource BlueBtn}"  Content="Pick..." Tag="SelectCustomCategory" Click="Cmd_Click" ToolTip="Choose from ALL categories in view"/>
                                <Button Style="{StaticResource CatBtn}" Content="View" Tag="SelectView" Click="Cmd_Click" ToolTip="Select view elements"/>
                            </WrapPanel>
                        </Border>

                        <!-- SPATIAL -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SPATIAL"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Near" Tag="SelectNear" Click="Cmd_Click" ToolTip="Select nearby elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Room" Tag="SelectByRoom" Click="Cmd_Click" ToolTip="Select by room"/>
                                <Button Style="{StaticResource CatBtn}" Content="Level" Tag="SelectByLevel" Click="Cmd_Click" ToolTip="Select by level"/>
                                <Button Style="{StaticResource CatBtn}" Content="Quad" Tag="SelectQuad" Click="Cmd_Click" ToolTip="Select by quadrant"/>
                                <Button Style="{StaticResource CatBtn}" Content="Edge" Tag="SelectEdge" Click="Cmd_Click" ToolTip="Select edge elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Grid" Tag="SelectGrid" Click="Cmd_Click" ToolTip="Select by grid"/>
                                <Button Style="{StaticResource CatBtn}" Content="BBox" Tag="SelectBBox" Click="Cmd_Click" ToolTip="Select by bounding box"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION SCOPE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION SCOPE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource BlueBtn}"   Content="View" Tag="SetScopeView" Click="Cmd_Click" ToolTip="Select from active view only (default)"/>
                                <Button Style="{StaticResource OrangeBtn}" Content="Project" Tag="SetScopeProject" Click="Cmd_Click" ToolTip="Select from entire project"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION SETS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION SETS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource GreenBtn}" Content="Save Set" Tag="SaveSelectionSet" Click="Cmd_Click" ToolTip="Save current selection as named set"/>
                                <Button Style="{StaticResource BlueBtn}" Content="Recall Set" Tag="RecallSelectionSet" Click="Cmd_Click" ToolTip="Recall a saved selection set"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Manage" Tag="ManageSelectionSets" Click="Cmd_Click" ToolTip="List, delete, export selection sets"/>
                            </WrapPanel>
                        </Border>

                        <!-- STATE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="STATE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource GreenBtn}"  Content="Untagged" Tag="SelectUntagged" Click="Cmd_Click"/>
                                <Button Style="{StaticResource GreenBtn}"  Content="Tagged" Tag="SelectTagged" Click="Cmd_Click"/>
                                <Button Style="{StaticResource OrangeBtn}" Content="EmptyMark" Tag="SelectEmptyMark" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Visible" Tag="SelectVisible" Click="Cmd_Click"/>
                                <Button Style="{StaticResource BlueBtn}" Content="[Pin]Pinned" Tag="SelectPinned" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Unpinned" Tag="SelectUnpinned" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- VIEW - ISOLATE and HIDE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="VIEW — ISOLATE &amp; HIDE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionBtn}" Content="[Find] Isolate" Tag="ViewIsolate" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Hide] Hide" Tag="ViewHide" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Look] Reveal" Tag="ViewReveal" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="↻ Reset" Tag="ViewReset" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION OPS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION OPS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="All" Tag="SelectAll" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="⊕Clr" Tag="SelectClear" Click="Cmd_Click" ToolTip="Clear selection"/>
                                <Button Style="{StaticResource CatBtn}" Content="Deselect" Tag="Deselect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="✕Del" Tag="DeleteSelected" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Invert" Tag="InvertSelection" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="+M1" Tag="AddToM1" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="-M1" Tag="RemoveFromM1" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="∩M1" Tag="IntersectM1" Click="Cmd_Click" ToolTip="Intersect with M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="→Tags" Tag="SelectTags" Click="Cmd_Click" ToolTip="Select tags of selection"/>
                                <Button Style="{StaticResource CatBtn}" Content="→Elem" Tag="SelectHostElements" Click="Cmd_Click" ToolTip="Select host elements"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION MEMORY -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION MEMORY"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="M1▼" Tag="SaveM1" Click="Cmd_Click" ToolTip="Save to M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="M1▲" Tag="LoadM1" Click="Cmd_Click" ToolTip="Load M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="M2▼" Tag="SaveM2" Click="Cmd_Click" ToolTip="Save to M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="M2▲" Tag="LoadM2" Click="Cmd_Click" ToolTip="Load M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="M3▼" Tag="SaveM3" Click="Cmd_Click" ToolTip="Save to M3"/>
                                <Button Style="{StaticResource CatBtn}" Content="M3▲" Tag="LoadM3" Click="Cmd_Click" ToolTip="Load M3"/>
                                <Button Style="{StaticResource CatBtn}" Content="1↔2" Tag="SwapM1M2" Click="Cmd_Click" ToolTip="Swap M1/M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="Info" Tag="SelectionInfo" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- TAG SELECTOR (multi-criteria) -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="TAG SELECTOR"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionBtn}" Content="★ Tag Selector" Tag="TagSelector" Click="Cmd_Click" ToolTip="Multi-criteria annotation tag selector" HorizontalAlignment="Stretch"/>
                                <Button Style="{StaticResource CatBtn}" Content="By Text" Tag="SelectTagsByText" Click="Cmd_Click" ToolTip="Select tags by displayed text"/>
                                <Button Style="{StaticResource CatBtn}" Content="By Size" Tag="SelectTagsByTextSize" Click="Cmd_Click" ToolTip="Select tags by text size (mm)"/>
                                <Button Style="{StaticResource CatBtn}" Content="Arrow" Tag="SelectTagsByArrowhead" Click="Cmd_Click" ToolTip="Select tags by arrowhead style"/>
                                <Button Style="{StaticResource CatBtn}" Content="Wt" Tag="SelectTagsByLineWeight" Click="Cmd_Click" ToolTip="Select tags by leader line weight"/>
                                <Button Style="{StaticResource CatBtn}" Content="Elbow" Tag="SelectTagsByElbowAngle" Click="Cmd_Click" ToolTip="Select tags by leader elbow angle"/>
                                <Button Style="{StaticResource CatBtn}" Content="Family" Tag="SelectTagsByFamily" Click="Cmd_Click" ToolTip="Select tags by tag family/type"/>
                                <Button Style="{StaticResource CatBtn}" Content="Host" Tag="SelectTagsByHostCategory" Click="Cmd_Click" ToolTip="Select tags by host element category"/>
                                <Button Style="{StaticResource CatBtn}" Content="Leader" Tag="SelectTagsByLeaderState" Click="Cmd_Click" ToolTip="Select tags by leader state"/>
                                <Button Style="{StaticResource CatBtn}" Content="Orient" Tag="SelectTagsByOrientation" Click="Cmd_Click" ToolTip="Select horizontal or vertical tags"/>
                                <Button Style="{StaticResource CatBtn}" Content="DISC" Tag="SelectTagsByDiscipline" Click="Cmd_Click" ToolTip="Select tags by discipline code"/>
                                <Button Style="{StaticResource CatBtn}" Content="Token" Tag="SelectTagsByToken" Click="Cmd_Click" ToolTip="Select tags by any tag token segment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Overlap" Tag="SelectOverlappingTags" Click="Cmd_Click" ToolTip="Select overlapping tags"/>
                            </WrapPanel>
                        </Border>

                        <!-- PROJECT FILTER -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="PROJECT FILTER"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Workset..." Tag="FilterWorkset" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Phase..." Tag="FilterPhase" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="D.Option..." Tag="FilterDesignOption" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Group..." Tag="FilterGroup" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Assembly..." Tag="FilterAssembly" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Connected" Tag="FilterConnected" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- QUICK PARAM -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="QUICK PARAM"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Mark" Tag="QuickMark" Click="Cmd_Click"/>
