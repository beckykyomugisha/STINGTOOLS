                                                    <TextBlock Text="1:200 – 1:500" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale500" Minimum="5" Maximum="30" Value="12" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale500, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="1:500+" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale1000" Minimum="10" Maximum="50" Value="20" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale1000, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Offset cap (ft)" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldOffsetCap" Minimum="5" Maximum="50" Value="30" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldOffsetCap, StringFormat={}{0:F0} ft}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- PER-CATEGORY SCALE MULTIPLIERS -->
                                        <TextBlock Text="PER-CATEGORY SCALE MULTIPLIERS" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Ducts" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" Value="1.0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="1.0x" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Pipes" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" Value="1.0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="1.0x" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Equipment" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" Value="1.2" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="1.2x" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Fixtures" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" Value="0.8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="0.8x" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- VIEW SCALE INFO -->
                                        <TextBlock Text="CURRENT VIEW" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <TextBlock x:Name="txtViewScale" Text="Scale: —" FontSize="9"/>
                                                <TextBlock x:Name="txtViewTier" Text="Tier: —" FontSize="9"/>
                                                <TextBlock x:Name="txtViewOffset" Text="Offset: — mm (— ft)" FontSize="9"/>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                        </TabControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="4,3" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ft:" FontSize="9" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <ComboBox Grid.Column="1" x:Name="cmbNudgeDist" Width="50" FontSize="9" Height="20">
                    <ComboBoxItem Content="0.25" IsSelected="True"/>
                    <ComboBoxItem Content="0.125"/>
                    <ComboBoxItem Content="0.5"/>
                    <ComboBoxItem Content="1.0"/>
                    <ComboBoxItem Content="2.0"/>
                </ComboBox>
                <Slider Grid.Column="2" x:Name="sldNudgeDist" Minimum="0.01" Maximum="2.0" Value="0.25" Width="60" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="3" Text="Always on top: ON" FontSize="9" Foreground="#888" VerticalAlignment="Center" Margin="4,0"/>
                <Ellipse Grid.Column="4" Width="10" Height="10" Fill="#F44336" Margin="4,0" VerticalAlignment="Center"/>
                <Button Grid.Column="5" Content="[Del]" FontSize="9" Width="30" Height="20" Margin="2,0" Tag="DeleteSelected" Click="Cmd_Click"/>
                <Button Grid.Column="6" Content="?" FontSize="9" Width="20" Height="20" Margin="2,0" Tag="ShowHelp" Click="Cmd_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
