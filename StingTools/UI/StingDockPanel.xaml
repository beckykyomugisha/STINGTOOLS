                            <!-- ─── Tokens & Depth Tab ─── -->
                            <TabItem Header="Tokens &amp; Depth">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4">

                                        <!-- TOKEN SEGMENT VISIBILITY -->
                                        <TextBlock Text="TOKEN SEGMENT VISIBILITY" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,2,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <WrapPanel>
                                                    <CheckBox Content="DISC" x:Name="chkMaskDISC" IsChecked="True" Margin="3,1" FontSize="9"/>
                                                    <CheckBox Content="LOC" x:Name="chkMaskLOC" IsChecked="True" Margin="3,1" FontSize="9"/>
                                                    <CheckBox Content="ZONE" x:Name="chkMaskZONE" IsChecked="True" Margin="3,1" FontSize="9"/>
                                                    <CheckBox Content="LVL" x:Name="chkMaskLVL" IsChecked="True" Margin="3,1" FontSize="9"/>
                                                </WrapPanel>
                                                <WrapPanel>
