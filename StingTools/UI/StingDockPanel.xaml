                                            </StackPanel>
                                        </Border>

                                        <!-- PARAGRAPH DEPTH -->
                                        <TextBlock Text="PARAGRAPH DEPTH (INFORMATION DENSITY)" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Depth tier" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldParaDepth" Minimum="1" Maximum="10" Value="10" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldParaDepth, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <!-- Phase 165 — Issue #14. Mode-aware tier labels rendered as a 10-cell ruler under the slider.
                                                     The code-behind (StingDockPanel.xaml.cs OnTagModeChanged) updates these labels when the user
                                                     flips DC ↔ Handover ↔ Custom via the Pattern Mode buttons in the SELECT tab. -->
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="lblParaTier1"  Grid.Column="0" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T1 Identity"/>
                                                    <TextBlock x:Name="lblParaTier2"  Grid.Column="1" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T2 System"/>
                                                    <TextBlock x:Name="lblParaTier3"  Grid.Column="2" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T3 Spatial"/>
                                                    <TextBlock x:Name="lblParaTier4"  Grid.Column="3" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T4 Lifecycle"/>
                                                    <TextBlock x:Name="lblParaTier5"  Grid.Column="4" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T5 Technical"/>
                                                    <TextBlock x:Name="lblParaTier6"  Grid.Column="5" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T6 Class."/>
                                                    <TextBlock x:Name="lblParaTier7"  Grid.Column="6" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T7 —"/>
                                                    <TextBlock x:Name="lblParaTier8"  Grid.Column="7" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T8 —"/>
                                                    <TextBlock x:Name="lblParaTier9"  Grid.Column="8" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T9 —"/>
                                                    <TextBlock x:Name="lblParaTier10" Grid.Column="9" FontSize="7" Foreground="#666" TextWrapping="Wrap" Text="T10 —"/>
                                                </Grid>
                                                <TextBlock x:Name="lblParaDepthHint" Text="Full — all 10 data tiers. Each tier activates TAG_PARA_STATE_N_BOOL" FontSize="8" Foreground="#999" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- HANDOVER MODE TOGGLE + PARAGRAPH BUILDER -->
                                        <TextBlock Text="HANDOVER MODE (T4–T10 DEFAULT CONTENT)" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Mode" FontSize="9" VerticalAlignment="Center"/>
                                                    <WrapPanel Grid.Column="1">
                                                        <RadioButton x:Name="rbModeHandover"  Content="Handover / FM"         GroupName="HandoverMode" IsChecked="True" Margin="2" FontSize="9"
                                                                     ToolTip="Commissioning · Cost · Carbon · Fab · Clash · As-built · Compliance"/>
                                                        <RadioButton x:Name="rbModeDesign"    Content="Design &amp; Construction" GroupName="HandoverMode" Margin="2" FontSize="9"
                                                                     ToolTip="Design intent · Performance · Material · Installation · Coordination · Warranty · Classification"/>
                                                        <RadioButton x:Name="rbModeCustom"    Content="Custom"                 GroupName="HandoverMode" Margin="2" FontSize="9"
                                                                     ToolTip="User-edited preset from PARAGRAPH_PRESETS.json"/>
                                                    </WrapPanel>
                                                </Grid>
                                                <WrapPanel Margin="0,6,0,0">
                                                    <Button Style="{StaticResource BlueBtn}"   Content="Paragraph Builder…"  Tag="ParagraphBuilder"        Click="Cmd_Click" Width="132" Height="26"
                                                            ToolTip="Edit T4–T10 rows (parameter + prefix + suffix), save as preset"/>
                                                    <Button Style="{StaticResource GreenBtn}"  Content="Apply preset"        Tag="ApplyParagraphPreset"    Click="Cmd_Click" Width="90"  Height="26"
                                                            ToolTip="Write composed paragraphs into ASS_TAG_7_TXT on elements in scope"/>
                                                    <Button Style="{StaticResource ActionBtn}" Content="Run full workflow"   Tag="RunWorkflow_TierConversionHandover" Click="Cmd_Click" Width="110" Height="26"
                                                            ToolTip="Apply preset → Set depth → Validate → COBie/Handover export"/>
                                                    <Button Style="{StaticResource ActionBtn}" Content="Live refresh"        Tag="Tag7NarrativeUpdaterToggle" Click="Cmd_Click" Width="90"  Height="26"
                                                            ToolTip="Toggle IUpdater that keeps ASS_TAG_7_TXT in sync with parameter changes"/>
                                                </WrapPanel>
                                                <TextBlock Text="Switches T4–T10 default content between Handover (FM) and Design &amp; Construction. Custom lets you save your own." FontSize="8" Foreground="#999" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- COBIE FIELD PRE-SEEDING -->
