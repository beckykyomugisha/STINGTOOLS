                                        <Border Style="{StaticResource GroupBorder}">
                                            <WrapPanel>
                                                <Button Style="{StaticResource ActionBtn}" Content="Validate tags" Tag="ValidateTags" Click="Cmd_Click" Width="78" Height="26"/>
                                                <Button Style="{StaticResource ActionBtn}" Content="Check data" Tag="CheckData" Click="Cmd_Click" Width="72" Height="26"/>
                                                <Button Style="{StaticResource ActionBtn}" Content="Compliance scan" Tag="ComplianceScan" Click="Cmd_Click" Width="100" Height="26"/>
                                                <Button Style="{StaticResource ActionBtn}" Content="Resolve issues" Tag="ResolveAllIssues" Click="Cmd_Click" Width="88" Height="26"/>
                                            </WrapPanel>
                                        </Border>

                                        <!-- STYLE PIPELINE -->
                                        <TextBlock Text="STYLE PIPELINE" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
