                                <WrapPanel Margin="0,4,0,0">
                                    <TextBlock Text="Fill:" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                    <Border x:Name="brdFillColorView" Width="18" Height="18" Background="#2196F3" BorderThickness="1" BorderBrush="#CCC"/>
                                    <TextBlock Text="Outline:" FontSize="10" VerticalAlignment="Center" Margin="8,0,2,0"/>
                                    <Border x:Name="brdOutlineColorView" Width="18" Height="18" Background="Black" BorderThickness="1" BorderBrush="#CCC"/>
                                    <TextBlock Text="Wt:" FontSize="10" VerticalAlignment="Center" Margin="8,0,2,0"/>
                                    <ComboBox x:Name="cmbLineWeightView" Width="55" FontSize="10" Height="22">
                                        <ComboBoxItem Content="Default" IsSelected="True"/>
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                        <ComboBoxItem Content="5"/>
                                        <ComboBoxItem Content="8"/>
                                    </ComboBox>
                                    <Button Style="{StaticResource CatBtn}" Content="Wt" Tag="ApplyLineWeight" Click="Cmd_Click"/>
                                    <RadioButton x:Name="rbFill" Content="● Fill" FontSize="10" IsChecked="True" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </WrapPanel>
                                <!-- Clear ALL -->
                                <Button Style="{StaticResource RedBtn}" Content="[Clean] Clear ALL Colour Overrides in View" Tag="ClearOverrides" Click="Cmd_Click"
                                        HorizontalAlignment="Stretch" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- VIEW CONTROLS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="[Eye] VIEW CONTROLS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubLabel}" Text="TEMP HIDE / ISOLATE"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource ActionBtn}" Content="[Find] Isolate" Tag="ViewIsolate" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="[Hide] Hide" Tag="ViewHide" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="[Look] Reveal" Tag="ViewReveal" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="↻ Reset" Tag="ViewReset" Click="Cmd_Click"/>
                                </WrapPanel>
                                <TextBlock Style="{StaticResource SubLabel}" Text="PERMANENT HIDE"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource ActionBtn}" Content="Perm Hide" Tag="PermHide" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="Perm Unhide" Tag="PermUnhide" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="Unhide Cat" Tag="UnhideCategory" Click="Cmd_Click"/>
                                </WrapPanel>
                                <TextBlock Style="{StaticResource SubLabel}" Text="GRAPHIC OVERRIDES"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource ActionBtn}" Content="Halftone ON" Tag="HalftoneOn" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="Halftone OFF" Tag="HalftoneOff" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="Reset Override" Tag="ClearOverrides" Click="Cmd_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Always on top -->
                        <TextBlock Text="Always on top: ON" FontSize="10" Foreground="#888" Margin="0,4,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="4,3" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ft:" FontSize="9" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <ComboBox Grid.Column="1" x:Name="cmbNudgeDist" Width="50" FontSize="9" Height="20">
                    <ComboBoxItem Content="0.25" IsSelected="True"/>
                    <ComboBoxItem Content="0.125"/>
                    <ComboBoxItem Content="0.5"/>
                    <ComboBoxItem Content="1.0"/>
                    <ComboBoxItem Content="2.0"/>
                </ComboBox>
                <Slider Grid.Column="2" x:Name="sldNudgeDist" Minimum="0.01" Maximum="2.0" Value="0.25" Width="60" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="3" Text="Always on top: ON" FontSize="9" Foreground="#888" VerticalAlignment="Center" Margin="4,0"/>
                <Ellipse Grid.Column="4" Width="10" Height="10" Fill="#F44336" Margin="4,0" VerticalAlignment="Center"/>
                <Button Grid.Column="5" Content="[Del]" FontSize="9" Width="30" Height="20" Margin="2,0" Tag="DeleteSelected" Click="Cmd_Click"/>
                <Button Grid.Column="6" Content="?" FontSize="9" Width="20" Height="20" Margin="2,0" Tag="ShowHelp" Click="Cmd_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
