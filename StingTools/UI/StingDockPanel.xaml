                                                <WrapPanel>
                                                    <CheckBox x:Name="chkCntTAG5" Content="TAG5" Margin="2,1" FontSize="9"/>
                                                    <CheckBox x:Name="chkCntTAG6" Content="TAG6" Margin="2,1" FontSize="9"/>
