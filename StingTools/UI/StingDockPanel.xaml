                                                    <RadioButton Content="P13 NE+" GroupName="TagPos" x:Name="rbPos13" Margin="1" FontSize="9"/>
                                                    <RadioButton Content="P14 SE+" GroupName="TagPos" x:Name="rbPos14" Margin="1" FontSize="9"/>
                                                    <RadioButton Content="P15 SW+" GroupName="TagPos" x:Name="rbPos15" Margin="1" FontSize="9"/>
                                                    <RadioButton Content="P16 NW+" GroupName="TagPos" x:Name="rbPos16" Margin="1" FontSize="9"/>
                                                </UniformGrid>
                                                <TextBlock Text="Ring 1 = cardinal/diagonal 1x · Ring 2 = far 1.5x" FontSize="8" Foreground="#999" Margin="2,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- DIRECTIONAL OFFSET OVERRIDE -->
                                        <TextBlock Text="DIRECTIONAL OFFSET OVERRIDE" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <UniformGrid Rows="2" Columns="4" Margin="2">
                                                <RadioButton Content="NW" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                                <RadioButton Content="N" GroupName="DirOverride" IsChecked="True" Margin="1" FontSize="9" FontWeight="Bold"/>
                                                <RadioButton Content="NE" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                                <RadioButton Content="W" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                                <RadioButton Content="E" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                                <RadioButton Content="SW" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                                <RadioButton Content="S" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                                <RadioButton Content="SE" GroupName="DirOverride" Margin="1" FontSize="9"/>
                                            </UniformGrid>
                                        </Border>

                                        <!-- OFFSET CONTROLS -->
                                        <TextBlock Text="OFFSET CONTROLS" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Base offset" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldBaseOffset" Minimum="1" Maximum="30" Value="8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldBaseOffset, StringFormat={}{0:F0} mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="N offset" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldNOffset" Minimum="-20" Maximum="20" Value="8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldNOffset, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="E offset" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldEOffset" Minimum="-20" Maximum="20" Value="8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldEOffset, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="S offset" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldSOffset" Minimum="-20" Maximum="20" Value="-8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldSOffset, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="W offset" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldWOffset" Minimum="-20" Maximum="20" Value="-8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldWOffset, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Ring 2 mult." FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldRing2" Minimum="1.0" Maximum="3.0" Value="1.5" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldRing2, StringFormat={}{0:F2}x}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Tag width est." FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldTagWidth" Minimum="10" Maximum="80" Value="30" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldTagWidth, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Tag height est." FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldTagHeight" Minimum="3" Maximum="30" Value="10" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldTagHeight, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- COLLISION SCORING WEIGHTS -->
                                        <TextBlock Text="COLLISION SCORING WEIGHTS" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Overlap penalty" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldOverlapPenalty" Minimum="100" Maximum="1000" Value="500" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldOverlapPenalty, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Proximity weight" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldProximity" Minimum="1" Maximum="20" Value="8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldProximity, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Preferred bonus" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldPreferred" Minimum="10" Maximum="100" Value="40" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldPreferred, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Align bonus" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldAlign" Minimum="5" Maximum="50" Value="15" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldAlign, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Crop edge penalty" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldCropPenalty" Minimum="10" Maximum="200" Value="50" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldCropPenalty, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Expand search" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldExpand" Minimum="1.5" Maximum="5.0" Value="2.5" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldExpand, StringFormat={}{0:F1}x}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- SCOPE -->
                                        <TextBlock Text="SCOPE" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <ComboBox x:Name="cmbPlaceScope" FontSize="9" Height="22">
                                                    <ComboBoxItem Content="Active view — all elements" IsSelected="True"/>
                                                    <ComboBoxItem Content="Active view — untagged only"/>
                                                    <ComboBoxItem Content="Selected elements"/>
                                                    <ComboBoxItem Content="Entire project"/>
                                                </ComboBox>
                                                <ComboBox x:Name="cmbPlaceCatFilter" FontSize="9" Height="22" Margin="0,3,0,0">
                                                    <ComboBoxItem Content="All categories" IsSelected="True"/>
                                                    <ComboBoxItem Content="Mechanical only"/>
                                                    <ComboBoxItem Content="Electrical only"/>
                                                    <ComboBoxItem Content="Plumbing only"/>
                                                    <ComboBoxItem Content="Fire Protection only"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <!-- ACTION BUTTONS -->
                                        <WrapPanel Margin="0,6,0,0">
                                            <Button Style="{StaticResource GreenBtn}" Content="Smart place" Tag="TagStudio_SmartPlace" Click="Cmd_Click" Width="80" Height="30"/>
                                            <Button Style="{StaticResource ActionBtn}" Content="Arrange" Tag="TagStudio_Arrange" Click="Cmd_Click" Width="80" Height="30"/>
                                            <Button Style="{StaticResource ActionBtn}" Content="Align bands" Tag="TagStudio_AlignBands" Click="Cmd_Click" Width="80" Height="30"/>
                                        </WrapPanel>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ─── Leader & Elbow Tab ─── -->
                            <TabItem Header="Leader &amp; Elbow">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4">

                                        <!-- LEADER MODE -->
                                        <TextBlock Text="LEADER MODE" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,2,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <WrapPanel>
                                                    <RadioButton Content="Auto" GroupName="LeaderMode" x:Name="rbLeaderAuto" IsChecked="True" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Always" GroupName="LeaderMode" x:Name="rbLeaderAlways" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Never" GroupName="LeaderMode" x:Name="rbLeaderNever" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Smart (dist)" GroupName="LeaderMode" x:Name="rbLeaderSmart" Margin="2" FontSize="9"/>
                                                </WrapPanel>
                                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Leader length" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldLeaderLen" Minimum="1" Maximum="60" Value="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldLeaderLen, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Min length" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldLeaderMin" Minimum="1" Maximum="20" Value="5" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldLeaderMin, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Max length" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldLeaderMax" Minimum="10" Maximum="100" Value="43" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldLeaderMax, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Threshold" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldLeaderThreshold" Minimum="5" Maximum="50" Value="20" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldLeaderThreshold, StringFormat={}{0:F0} mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <TextBlock Text="Auto: leader fires when best score &lt; 0. Smart: fires when offset &gt; threshold." FontSize="8" Foreground="#999" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- ELBOW GEOMETRY -->
                                        <TextBlock Text="ELBOW GEOMETRY" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <WrapPanel>
                                                    <RadioButton Content="Straight" GroupName="ElbowType" x:Name="rbElbowStr" IsChecked="True" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="45°" GroupName="ElbowType" x:Name="rbElbow45" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="90°" GroupName="ElbowType" x:Name="rbElbow90" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Free" GroupName="ElbowType" x:Name="rbElbowFree" Margin="2" FontSize="9"/>
                                                </WrapPanel>
                                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Elbow X" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldElbowX" Minimum="-20" Maximum="20" Value="-2" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldElbowX, StringFormat={}{0:F0}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Elbow Y" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldElbowY" Minimum="-30" Maximum="30" Value="-16" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldElbowY, StringFormat={}{0:F0}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Elbow dist" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldElbowDist" Minimum="2" Maximum="30" Value="8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldElbowDist, StringFormat={}{0:F0} mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- ARROW HEAD -->
                                        <TextBlock Text="ARROW HEAD" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Arrow style" FontSize="9" VerticalAlignment="Center"/>
                                                    <ComboBox Grid.Column="1" x:Name="cmbArrowStyle" FontSize="9" Height="22">
                                                        <ComboBoxItem Content="None" IsSelected="True"/>
                                                        <ComboBoxItem Content="Open"/>
                                                        <ComboBoxItem Content="Filled"/>
                                                        <ComboBoxItem Content="Dot"/>
                                                        <ComboBoxItem Content="Tick"/>
                                                    </ComboBox>
                                                </Grid>
                                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Arrow size" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldArrowSize" Minimum="1" Maximum="10" Value="4" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldArrowSize, StringFormat={}{0:F0}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Arrow color" FontSize="9" VerticalAlignment="Center"/>
                                                    <ComboBox Grid.Column="1" x:Name="cmbArrowColor" FontSize="9" Height="22">
                                                        <ComboBoxItem Content="Match scheme" IsSelected="True"/>
                                                        <ComboBoxItem Content="Black"/>
                                                        <ComboBoxItem Content="Blue"/>
                                                        <ComboBoxItem Content="Red"/>
                                                        <ComboBoxItem Content="Gray"/>
                                                    </ComboBox>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- ACTIONS -->
                                        <WrapPanel Margin="0,6,0,0">
                                            <Button Style="{StaticResource ActionBtn}" Content="Adjust elbows" Tag="TagStudio_AdjustElbows" Click="Cmd_Click" Width="90" Height="30"/>
                                            <Button Style="{StaticResource ActionBtn}" Content="Set arrows" Tag="TagStudio_SetArrows" Click="Cmd_Click" Width="90" Height="30"/>
                                            <Button Style="{StaticResource ActionBtn}" Content="API notes" Tag="TagStudio_APIGaps" Click="Cmd_Click" Width="90" Height="30"/>
                                        </WrapPanel>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ─── Style & Color Tab ─── -->
                            <TabItem Header="Style &amp; Color">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4">

                                        <!-- TEXT APPEARANCE -->
                                        <TextBlock Text="TEXT APPEARANCE" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,2,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Size (mm)" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldTextSize" Minimum="1.5" Maximum="5.0" Value="2.5" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldTextSize, StringFormat={}{0:F1} mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <TextBlock Text="Weight" FontSize="9" Margin="0,3,0,2"/>
                                                <WrapPanel>
                                                    <RadioButton Content="Normal" GroupName="TextWeight" x:Name="rbWeightNormal" IsChecked="True" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Bold" GroupName="TextWeight" x:Name="rbWeightBold" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Italic" GroupName="TextWeight" x:Name="rbWeightItalic" Margin="2" FontSize="9"/>
                                                </WrapPanel>
                                                <TextBlock Text="Text color" FontSize="9" Margin="0,3,0,2"/>
                                                <WrapPanel>
                                                    <RadioButton Content="Black" GroupName="TextColor" x:Name="rbColorBlack" IsChecked="True" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Red" GroupName="TextColor" x:Name="rbColorRed" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Blue" GroupName="TextColor" x:Name="rbColorBlue" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="White" GroupName="TextColor" x:Name="rbColorWhite" Margin="2" FontSize="9"/>
                                                </WrapPanel>
                                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Letter spacing" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldLetterSpacing" Minimum="0" Maximum="5" Value="0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldLetterSpacing, StringFormat={}{0:F0} pt}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- TAG BOX -->
                                        <TextBlock Text="TAG BOX" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <WrapPanel>
                                                    <RadioButton Content="Solid" GroupName="BoxStyle" x:Name="rbBoxSolid" IsChecked="True" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Dashed" GroupName="BoxStyle" x:Name="rbBoxDashed" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="Round" GroupName="BoxStyle" x:Name="rbBoxRound" Margin="2" FontSize="9"/>
                                                    <RadioButton Content="None" GroupName="BoxStyle" x:Name="rbBoxNone" Margin="2" FontSize="9"/>
                                                </WrapPanel>
                                                <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Fill opacity" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldBoxOpacity" Minimum="0" Maximum="100" Value="15" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldBoxOpacity, StringFormat={}{0:F0}%}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Border weight" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldBoxBorder" Minimum="0" Maximum="5" Value="1" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldBoxBorder, StringFormat={}{0:F0} pt}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Corner radius" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldBoxRadius" Minimum="0" Maximum="10" Value="3" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldBoxRadius, StringFormat={}{0:F0} px}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Padding" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldBoxPadding" Minimum="0" Maximum="10" Value="3" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldBoxPadding, StringFormat={}{0:F0} mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- WARNING DISPLAY -->
                                        <TextBlock Text="WARNING DISPLAY" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <TextBlock Text="Show warnings" FontSize="9" Margin="0,0,0,2"/>
