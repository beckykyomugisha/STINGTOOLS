<Page x:Class="StingTools.UI.StingDockPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="STING Tools"
      Background="#FAFAFA">

    <Page.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,0,3"/>
            <Setter Property="Foreground" Value="#6A1B9A"/>
        </Style>
        <Style x:Key="GroupBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="CatBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
        </Style>
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#F57C00"/>
        </Style>
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
        </Style>
        <Style x:Key="BlueBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
        </Style>
        <Style x:Key="PurpleBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#9C27B0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#7B1FA2"/>
        </Style>
        <Style x:Key="TealBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#009688"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#00796B"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#6A1B9A"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,3,0,1"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#6A1B9A" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="STING TAGS v9.6" FontWeight="Bold" FontSize="13" Foreground="White"/>
                    <TextBlock x:Name="txtStatus" Text="Always on top: ON" FontSize="9" Foreground="#CE93D8"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="txtSelCount" Text="sel 0" FontSize="9" Foreground="#CE93D8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="btnPin" Grid.Column="2" Content="Pin" Width="30" Height="20"
                        FontSize="9" Background="#7B1FA2" Foreground="White" BorderThickness="0"
                        ToolTip="Pin panel" Click="BtnPin_Click" Margin="0,0,2,0"/>
                <Button Grid.Column="3" Content="Pin" Width="30" Height="20"
                        FontSize="9" Background="#7B1FA2" Foreground="White" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Tab control -->
        <TabControl Grid.Row="1" x:Name="tabMain" SelectionChanged="TabMain_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Padding" Value="5,2"/>
                </Style>
            </TabControl.Resources>

            <!-- =============== SELECT TAB =============== -->
            <TabItem Header="SELECT">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>

                        <!-- AI SMART SELECT -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="⚡ AI SMART SELECT"/>
                        <Border Style="{StaticResource GroupBorder}" BorderBrush="#FF9800">
                            <WrapPanel>
                                <Button Style="{StaticResource OrangeBtn}" Content="[AI] Predict" Tag="AIPredictSelect" Click="Cmd_Click" ToolTip="AI predict selection"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Similar" Tag="AISimilarSelect" Click="Cmd_Click" ToolTip="Select similar elements"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Chain" Tag="AIChainSelect" Click="Cmd_Click" ToolTip="Select connected chain"/>
                                <Button Style="{StaticResource BlueBtn}" Content="Cluster" Tag="AIClusterSelect" Click="Cmd_Click" ToolTip="Select spatial clusters"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Pattern" Tag="AIPatternSelect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Boundary" Tag="AIBoundarySelect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Outliers" Tag="AIOutliersSelect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Dense" Tag="AIDenseSelect" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- CATEGORY -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CATEGORY"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Lgt" Tag="SelectLighting" Click="Cmd_Click" ToolTip="Lighting Fixtures"/>
                                <Button Style="{StaticResource CatBtn}" Content="Elc" Tag="SelectElectrical" Click="Cmd_Click" ToolTip="Electrical Equipment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Mch" Tag="SelectMechanical" Click="Cmd_Click" ToolTip="Mechanical Equipment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Plb" Tag="SelectPlumbing" Click="Cmd_Click" ToolTip="Plumbing Fixtures"/>
                                <Button Style="{StaticResource CatBtn}" Content="Air" Tag="SelectAirTerminals" Click="Cmd_Click" ToolTip="Air Terminals"/>
                                <Button Style="{StaticResource CatBtn}" Content="Fur" Tag="SelectFurniture" Click="Cmd_Click" ToolTip="Furniture"/>
                                <Button Style="{StaticResource CatBtn}" Content="Dr" Tag="SelectDoors" Click="Cmd_Click" ToolTip="Doors"/>
                                <Button Style="{StaticResource CatBtn}" Content="Win" Tag="SelectWindows" Click="Cmd_Click" ToolTip="Windows"/>
                                <Button Style="{StaticResource CatBtn}" Content="Rm" Tag="SelectRooms" Click="Cmd_Click" ToolTip="Rooms"/>
                                <Button Style="{StaticResource CatBtn}" Content="Spr" Tag="SelectSprinklers" Click="Cmd_Click" ToolTip="Sprinklers"/>
                                <Button Style="{StaticResource CatBtn}" Content="Pipe" Tag="SelectPipes" Click="Cmd_Click" ToolTip="Pipes"/>
                                <Button Style="{StaticResource CatBtn}" Content="Duct" Tag="SelectDucts" Click="Cmd_Click" ToolTip="Ducts"/>
                                <Button Style="{StaticResource CatBtn}" Content="Cnd" Tag="SelectConduits" Click="Cmd_Click" ToolTip="Conduits"/>
                                <Button Style="{StaticResource CatBtn}" Content="Cbl" Tag="SelectCableTrays" Click="Cmd_Click" ToolTip="Cable Trays"/>
                                <Button Style="{StaticResource CatBtn}" Content="ALL..." Tag="SelectAllTaggable" Click="Cmd_Click" ToolTip="ALL Taggable" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                                <Button Style="{StaticResource CatBtn}" Content="View" Tag="SelectView" Click="Cmd_Click" ToolTip="Select view elements"/>
                            </WrapPanel>
                        </Border>

                        <!-- SPATIAL -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SPATIAL"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Near" Tag="SelectNear" Click="Cmd_Click" ToolTip="Select nearby elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Room" Tag="SelectByRoom" Click="Cmd_Click" ToolTip="Select by room"/>
                                <Button Style="{StaticResource CatBtn}" Content="Level" Tag="SelectByLevel" Click="Cmd_Click" ToolTip="Select by level"/>
                                <Button Style="{StaticResource CatBtn}" Content="Quad" Tag="SelectQuad" Click="Cmd_Click" ToolTip="Select by quadrant"/>
                                <Button Style="{StaticResource CatBtn}" Content="Edge" Tag="SelectEdge" Click="Cmd_Click" ToolTip="Select edge elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Grid" Tag="SelectGrid" Click="Cmd_Click" ToolTip="Select by grid"/>
                                <Button Style="{StaticResource CatBtn}" Content="BBox" Tag="SelectBBox" Click="Cmd_Click" ToolTip="Select by bounding box"/>
                            </WrapPanel>
                        </Border>

                        <!-- STATE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="STATE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Untagged" Tag="SelectUntagged" Click="Cmd_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                                <Button Style="{StaticResource CatBtn}" Content="Tagged" Tag="SelectTagged" Click="Cmd_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                                <Button Style="{StaticResource CatBtn}" Content="EmptyMark" Tag="SelectEmptyMark" Click="Cmd_Click" Background="#FF9800" Foreground="White" FontWeight="Bold"/>
                                <Button Style="{StaticResource CatBtn}" Content="Visible" Tag="SelectVisible" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="[Pin]Pinned" Tag="SelectPinned" Click="Cmd_Click" Background="#2196F3" Foreground="White"/>
                                <Button Style="{StaticResource CatBtn}" Content="Unpinned" Tag="SelectUnpinned" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- VIEW - ISOLATE & HIDE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="VIEW — ISOLATE &amp; HIDE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionBtn}" Content="[Find] Isolate" Tag="ViewIsolate" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Hide] Hide" Tag="ViewHide" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Look] Reveal" Tag="ViewReveal" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="↻ Reset" Tag="ViewReset" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION OPS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION OPS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="All" Tag="SelectAll" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="⊕Clr" Tag="SelectClear" Click="Cmd_Click" ToolTip="Clear selection"/>
                                <Button Style="{StaticResource CatBtn}" Content="Deselect" Tag="Deselect" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="✕Del" Tag="DeleteSelected" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Invert" Tag="InvertSelection" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="+M1" Tag="AddToM1" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="-M1" Tag="RemoveFromM1" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="∩M1" Tag="IntersectM1" Click="Cmd_Click" ToolTip="Intersect with M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="→Tags" Tag="SelectTags" Click="Cmd_Click" ToolTip="Select tags of selection"/>
                                <Button Style="{StaticResource CatBtn}" Content="→Elem" Tag="SelectHostElements" Click="Cmd_Click" ToolTip="Select host elements"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION MEMORY -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION MEMORY"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="M1▼" Tag="SaveM1" Click="Cmd_Click" ToolTip="Save to M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="M1▲" Tag="LoadM1" Click="Cmd_Click" ToolTip="Load M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="M2▼" Tag="SaveM2" Click="Cmd_Click" ToolTip="Save to M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="M2▲" Tag="LoadM2" Click="Cmd_Click" ToolTip="Load M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="M3▼" Tag="SaveM3" Click="Cmd_Click" ToolTip="Save to M3"/>
                                <Button Style="{StaticResource CatBtn}" Content="M3▲" Tag="LoadM3" Click="Cmd_Click" ToolTip="Load M3"/>
                                <Button Style="{StaticResource CatBtn}" Content="1↔2" Tag="SwapM1M2" Click="Cmd_Click" ToolTip="Swap M1/M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="Info" Tag="SelectionInfo" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- PROJECT FILTER -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="PROJECT FILTER"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Workset..." Tag="FilterWorkset" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Phase..." Tag="FilterPhase" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="D.Option..." Tag="FilterDesignOption" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Group..." Tag="FilterGroup" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Assembly..." Tag="FilterAssembly" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Connected" Tag="FilterConnected" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- QUICK PARAM -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="QUICK PARAM"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Mark" Tag="QuickMark" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Type" Tag="QuickType" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="Family" Tag="QuickFamily" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="System" Tag="QuickSystem" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- BULK PARAMETER WRITE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="✏ BULK PARAMETER WRITE"/>
                        <Border Style="{StaticResource GroupBorder}" BorderBrush="#FF9800">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbBulkParam" IsEditable="True" FontSize="10" Height="24" ToolTip="Parameter name"/>
                                    <Button Grid.Column="1" Content="↻" Width="26" Height="24" FontSize="12" Click="BtnRefreshParams_Click" ToolTip="Refresh param list"/>
                                    <Button Grid.Column="2" Style="{StaticResource PurpleBtn}" Content="[Brain]" FontSize="9" Tag="BulkBrain" Click="Cmd_Click" ToolTip="AI suggest parameter"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtBulkValue" FontSize="10" Height="24" ToolTip="Value to write"/>
                                    <Button Grid.Column="1" Content="Preview" Style="{StaticResource ActionBtn}" Click="BtnBulkPreview_Click"/>
                                    <Button Grid.Column="2" Content="▶ Write" Style="{StaticResource GreenBtn}" Click="BtnBulkWrite_Click"/>
                                    <Button Grid.Column="3" Content="Clear" Style="{StaticResource RedBtn}" Click="BtnBulkClear_Click"/>
                                </Grid>
                                <TextBlock x:Name="txtBulkStatus" Text="Select elements, pick param, enter value" FontSize="9" Foreground="#888" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- PARAMETER LOOKUP -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="[Find] PARAMETER LOOKUP (885 params)"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Live param:" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox Grid.Column="1" x:Name="cmbLookupParam" IsEditable="True" FontSize="10" Height="24"/>
                                    <Button Grid.Column="2" Content="↻" Width="26" Height="24" FontSize="12" Tag="ParamLookupRefresh" Click="Cmd_Click"/>
                                </Grid>
                                <ComboBox x:Name="cmbLookupCategory" FontSize="10" Height="24" Margin="0,4,0,0" ToolTip="Filter by category">
                                    <ComboBoxItem Content="All Categories" IsSelected="True"/>
                                </ComboBox>
                                <TextBlock x:Name="txtParamInfo" Text="Type: —&#x0a;Group: —&#x0a;GUID: —" FontSize="9" Foreground="#888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- CONDITIONS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CONDITIONS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbCondParam" IsEditable="True" FontSize="10" Height="24"/>
                                    <ComboBox Grid.Column="1" x:Name="cmbCondOp" FontSize="10" Height="24" Width="70" Margin="2,0">
                                        <ComboBoxItem Content="contains" IsSelected="True"/>
                                        <ComboBoxItem Content="equals"/>
                                        <ComboBoxItem Content="starts"/>
                                        <ComboBoxItem Content="ends"/>
                                        <ComboBoxItem Content="&gt;"/>
                                        <ComboBoxItem Content="&lt;"/>
                                    </ComboBox>
                                    <TextBox Grid.Column="2" x:Name="txtCondValue" FontSize="10" Height="24"/>
                                    <Button Grid.Column="3" Content="⚙" Width="24" Height="24" FontSize="12"/>
                                </Grid>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Style="{StaticResource CatBtn}" Content="+Cond" Tag="CondAdd" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource CatBtn}" Content="-Cond" Tag="CondRemove" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Clear" Tag="CondClear" Click="Cmd_Click"/>
                                    <TextBlock x:Name="txtCondMatches" Text="0 matches" FontSize="9" Foreground="#888" VerticalAlignment="Center" Margin="4,0"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="Preview" Tag="CondPreview" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource GreenBtn}" Content="▶ Apply" Tag="CondApply" Click="Cmd_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =============== ORGANISE TAB =============== -->
            <TabItem Header="ORGANISE">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>

                        <!-- AI ORGANISE ENGINE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="[Brain] AI ORGANISE ENGINE"/>
                        <Border Style="{StaticResource GroupBorder}" BorderBrush="#9C27B0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Style="{StaticResource PurpleBtn}" Content="▶ SMART ORGANISE" Tag="SmartOrganise" Click="Cmd_Click" HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Column="1" x:Name="txtOrgScore" Text="-/8" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Style="{StaticResource CatBtn}" Content="Quick" Tag="OrgQuick" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Deep" Tag="OrgDeep" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Anneal" Tag="OrgAnneal" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource CatBtn}" Content="←Reset" Tag="OrgReset" Click="Cmd_Click"/>
                                    <Button Style="{StaticResource PurpleBtn}" Content="[Brain]Sp" Tag="OrgBrainSp" Click="Cmd_Click" FontSize="9"/>
                                </WrapPanel>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Style="{StaticResource ActionBtn}" Content="↻ Undo" Tag="OrgUndo" Click="Cmd_Click" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" x:Name="txtOrgUndo" Text="0/5" FontSize="10" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- TAG FAMILY -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tag family:" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox Grid.Column="1" x:Name="cmbTagFamily" IsEditable="True" FontSize="10" Height="24"/>
                            <Button Grid.Column="2" Content="↻" Width="26" Height="24" FontSize="12" Tag="TagFamilyRefresh" Click="Cmd_Click"/>
                        </Grid>
                        <TextBlock Text="Click ☰ to load by discipline" FontSize="9" Foreground="#888" Margin="0,1,0,4"/>

                        <!-- TAG OPERATIONS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="TAG OPERATIONS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionBtn}" Content="Tag Sel" Tag="TagSelected" Click="Cmd_Click" ToolTip="Tag selected"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Tag Cat" Tag="TagCat" Click="Cmd_Click" ToolTip="Tag by category"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Tag All" Tag="TagAll" Click="Cmd_Click" ToolTip="Tag all in view"/>
                                <Button Style="{StaticResource RedBtn}" Content="Del Tags" Tag="DeleteTags" Click="Cmd_Click"/>
                                <Button Style="{StaticResource OrangeBtn}" Content="Orphans" Tag="Orphans" Click="Cmd_Click" ToolTip="Find orphaned tags"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Num]Renumb" Tag="RenumberTags" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[List]Clone" Tag="CloneTags" Click="Cmd_Click" ToolTip="Clone tag layout"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Audit" Tag="AuditTags" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="AuditCSV" Tag="AuditTagsCSV" Click="Cmd_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="MultiView" Tag="MultiView" Click="Cmd_Click" ToolTip="Tag across views"/>
                                <Button Style="{StaticResource OrangeBtn}" Content="Clashing▶" Tag="ClashingDetect" Click="Cmd_Click" ToolTip="Detect clashing tags"/>
                            </WrapPanel>
                        </Border>

                        <!-- ORIENTATION & TEXT ALIGNMENT -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="ORIENTATION &amp; TEXT ALIGNMENT"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="⊕H↔V" Tag="ToggleTagOrientation" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="All H" Tag="AllH" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="All V" Tag="AllV" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="→FlipH" Tag="FlipTagsH" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="↑FlipV" Tag="FlipTagsV" Click="Cmd_Click"/>
                                <Button Style="{StaticResource PurpleBtn}" Content="[Brain]SmH/V" Tag="BrainSmHV" Click="Cmd_Click" FontSize="9"/>
                                <TextBlock Text="Text:" FontSize="10" VerticalAlignment="Center" Margin="4,0,2,0"/>
                                <Button Style="{StaticResource CatBtn}" Content="◁" Tag="AlignTextLeft" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="=C" Tag="AlignTextCenter" Click="Cmd_Click"/>
                                <Button Style="{StaticResource CatBtn}" Content="R▷" Tag="AlignTextRight" Click="Cmd_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- NUDGE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="NUDGE (↑↓←→ keys active when panel focused)"/>
