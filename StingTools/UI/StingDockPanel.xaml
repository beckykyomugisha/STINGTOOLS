                                                </WrapPanel>
                                                <WrapPanel>
                                                    <CheckBox x:Name="chkCobieExpectedLife" Content="ExpectedLife" IsChecked="True" Margin="3,1" FontSize="9"/>
                                                    <CheckBox x:Name="chkCobieMaintFreq" Content="MaintFreq" IsChecked="True" Margin="3,1" FontSize="9"/>
