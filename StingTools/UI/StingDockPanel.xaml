                                                    <RadioButton x:Name="rbSepDot" Content="Dot ." GroupName="SepStyle" Margin="2" FontSize="9"/>
                                                    <RadioButton x:Name="rbSepUnderscore" Content="Underscore _" GroupName="SepStyle" Margin="2" FontSize="9"/>
