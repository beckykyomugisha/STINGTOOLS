<Page x:Class="StingTools.UI.StingDockPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="STING Tools"
      Background="#FAFAFA">

    <Page.Resources>
        <!-- ── Shared styles ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <Style x:Key="GroupBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="CatBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="50"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
        </Style>

        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#F57C00"/>
        </Style>

        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
        </Style>

        <Style x:Key="BlueBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
        </Style>

        <Style x:Key="PurpleBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#9C27B0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#7B1FA2"/>
        </Style>

        <Style x:Key="TealBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#009688"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#00796B"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#6A1B9A" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="STING TOOLS v2.0" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <TextBlock x:Name="txtStatus" Text="Ready" FontSize="10" Foreground="#CE93D8"/>
                </StackPanel>
                <Button x:Name="btnPin" Grid.Column="1" Content="Pin" Width="30" Height="20"
                        FontSize="9" Background="#7B1FA2" Foreground="White" BorderThickness="0"
                        ToolTip="Pin panel to stay visible" Click="BtnPin_Click"/>
            </Grid>
        </Border>

        <!-- ── Tab control ── -->
        <TabControl Grid.Row="1" x:Name="tabMain" Height="Auto"
                    SelectionChanged="TabMain_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="10,4"/>
                </Style>
            </TabControl.Resources>

            <!-- ═══════════════ SELECT TAB ═══════════════ -->
            <TabItem Header="SELECT">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>

                        <!-- CATEGORY -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CATEGORY"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Lgt" Tag="SelectLighting" Click="Cmd_Click" ToolTip="Select Lighting Fixtures"/>
                                <Button Style="{StaticResource CatBtn}" Content="Elc" Tag="SelectElectrical" Click="Cmd_Click" ToolTip="Select Electrical Equipment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Mch" Tag="SelectMechanical" Click="Cmd_Click" ToolTip="Select Mechanical Equipment"/>
                                <Button Style="{StaticResource CatBtn}" Content="Plb" Tag="SelectPlumbing" Click="Cmd_Click" ToolTip="Select Plumbing Fixtures"/>
                                <Button Style="{StaticResource CatBtn}" Content="Air" Tag="SelectAirTerminals" Click="Cmd_Click" ToolTip="Select Air Terminals"/>
                                <Button Style="{StaticResource CatBtn}" Content="Fur" Tag="SelectFurniture" Click="Cmd_Click" ToolTip="Select Furniture"/>
                                <Button Style="{StaticResource CatBtn}" Content="Dr" Tag="SelectDoors" Click="Cmd_Click" ToolTip="Select Doors"/>
                                <Button Style="{StaticResource CatBtn}" Content="Win" Tag="SelectWindows" Click="Cmd_Click" ToolTip="Select Windows"/>
                                <Button Style="{StaticResource CatBtn}" Content="Rm" Tag="SelectRooms" Click="Cmd_Click" ToolTip="Select Rooms"/>
                                <Button Style="{StaticResource CatBtn}" Content="Spr" Tag="SelectSprinklers" Click="Cmd_Click" ToolTip="Select Sprinklers"/>
                                <Button Style="{StaticResource CatBtn}" Content="Pipe" Tag="SelectPipes" Click="Cmd_Click" ToolTip="Select Pipes"/>
                                <Button Style="{StaticResource CatBtn}" Content="Duct" Tag="SelectDucts" Click="Cmd_Click" ToolTip="Select Ducts"/>
                                <Button Style="{StaticResource CatBtn}" Content="Cnd" Tag="SelectConduits" Click="Cmd_Click" ToolTip="Select Conduits"/>
                                <Button Style="{StaticResource CatBtn}" Content="Cbl" Tag="SelectCableTrays" Click="Cmd_Click" ToolTip="Select Cable Trays"/>
                                <Button Style="{StaticResource CatBtn}" Content="ALL" Tag="SelectAllTaggable" Click="Cmd_Click" ToolTip="Select ALL Taggable" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                                <Button Style="{StaticResource CatBtn}" Content="View" Tag="SelectByLevel" Click="Cmd_Click" ToolTip="Select elements in active view level"/>
                            </WrapPanel>
                        </Border>

                        <!-- SPATIAL -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SPATIAL"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Near" Tag="SelectByRoom" Click="Cmd_Click" ToolTip="Select by Room"/>
                                <Button Style="{StaticResource CatBtn}" Content="Room" Tag="SelectByRoom" Click="Cmd_Click" ToolTip="Select by Room"/>
                                <Button Style="{StaticResource CatBtn}" Content="Level" Tag="SelectByLevel" Click="Cmd_Click" ToolTip="Select by Level"/>
                            </WrapPanel>
                        </Border>

                        <!-- STATE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="STATE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Untagged" Tag="SelectUntagged" Click="Cmd_Click" Background="#FF9800" Foreground="White" FontWeight="Bold" ToolTip="Select untagged elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Tagged" Tag="SelectTagged" Click="Cmd_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold" ToolTip="Select tagged elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="EmptyMark" Tag="SelectEmptyMark" Click="Cmd_Click" Background="#F44336" Foreground="White" FontWeight="Bold" ToolTip="Select empty Mark parameter"/>
                                <Button Style="{StaticResource CatBtn}" Content="Visible" Tag="SelectAllTaggable" Click="Cmd_Click" ToolTip="Select visible elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Pinned" Tag="SelectPinned" Click="Cmd_Click" Background="#2196F3" Foreground="White" ToolTip="Select pinned elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="Unpinned" Tag="SelectUnpinned" Click="Cmd_Click" ToolTip="Select unpinned elements"/>
                            </WrapPanel>
                        </Border>

                        <!-- VIEW — ISOLATE & HIDE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="VIEW — ISOLATE &amp; HIDE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionBtn}" Content="[Find] Isolate" Tag="ViewIsolate" Click="Cmd_Click" ToolTip="Isolate selected in view"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Hide] Hide" Tag="ViewHide" Click="Cmd_Click" ToolTip="Hide selected in view"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Look] Reveal" Tag="ViewReveal" Click="Cmd_Click" ToolTip="Reveal hidden elements"/>
                                <Button Style="{StaticResource ActionBtn}" Content="↺ Reset" Tag="ViewReset" Click="Cmd_Click" ToolTip="Reset temporary hide/isolate"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION OPS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION OPS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="All" Tag="SelectAll" Click="Cmd_Click" ToolTip="Select all visible"/>
                                <Button Style="{StaticResource CatBtn}" Content="⊘Clr" Tag="SelectClear" Click="Cmd_Click" ToolTip="Clear selection"/>
                                <Button Style="{StaticResource CatBtn}" Content="Deselect" Tag="Deselect" Click="Cmd_Click" ToolTip="Deselect"/>
                                <Button Style="{StaticResource CatBtn}" Content="✕Del" Tag="DeleteSelected" Click="Cmd_Click" ToolTip="Delete selected"/>
                                <Button Style="{StaticResource CatBtn}" Content="Invert" Tag="InvertSelection" Click="Cmd_Click" ToolTip="Invert selection"/>
                                <Button Style="{StaticResource CatBtn}" Content="+M1" Tag="AddToM1" Click="Cmd_Click" ToolTip="Add to selection memory M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="−M1" Tag="RemoveFromM1" Click="Cmd_Click" ToolTip="Remove from M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="∩M1" Tag="IntersectM1" Click="Cmd_Click" ToolTip="Intersect with M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="→Tags" Tag="SelectTags" Click="Cmd_Click" ToolTip="Select tags of selected elements"/>
                                <Button Style="{StaticResource CatBtn}" Content="→Elem" Tag="SelectHostElements" Click="Cmd_Click" ToolTip="Select host elements of tags"/>
                            </WrapPanel>
                        </Border>

                        <!-- SELECTION MEMORY -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SELECTION MEMORY"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="M1▼" Tag="SaveM1" Click="Cmd_Click" ToolTip="Save current to M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="M1▲" Tag="LoadM1" Click="Cmd_Click" ToolTip="Load M1"/>
                                <Button Style="{StaticResource CatBtn}" Content="M2▼" Tag="SaveM2" Click="Cmd_Click" ToolTip="Save current to M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="M2▲" Tag="LoadM2" Click="Cmd_Click" ToolTip="Load M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="M3▼" Tag="SaveM3" Click="Cmd_Click" ToolTip="Save current to M3"/>
                                <Button Style="{StaticResource CatBtn}" Content="M3▲" Tag="LoadM3" Click="Cmd_Click" ToolTip="Load M3"/>
                                <Button Style="{StaticResource CatBtn}" Content="1↔2" Tag="SwapM1M2" Click="Cmd_Click" ToolTip="Swap M1 and M2"/>
                                <Button Style="{StaticResource CatBtn}" Content="Info" Tag="SelectionInfo" Click="Cmd_Click" ToolTip="Show selection info"/>
                            </WrapPanel>
                        </Border>

                        <!-- PROJECT FILTER -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="PROJECT FILTER"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Workset..." Tag="FilterWorkset" Click="Cmd_Click" ToolTip="Filter by workset"/>
                                <Button Style="{StaticResource CatBtn}" Content="Phase..." Tag="FilterPhase" Click="Cmd_Click" ToolTip="Filter by phase"/>
                                <Button Style="{StaticResource CatBtn}" Content="D.Option..." Tag="FilterDesignOption" Click="Cmd_Click" ToolTip="Filter by design option"/>
                                <Button Style="{StaticResource CatBtn}" Content="Group..." Tag="FilterGroup" Click="Cmd_Click" ToolTip="Filter by group"/>
                                <Button Style="{StaticResource CatBtn}" Content="Assembly..." Tag="FilterAssembly" Click="Cmd_Click" ToolTip="Filter by assembly"/>
                                <Button Style="{StaticResource CatBtn}" Content="Connected" Tag="FilterConnected" Click="Cmd_Click" ToolTip="Filter connected elements"/>
                            </WrapPanel>
                        </Border>

                        <!-- QUICK PARAM -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="QUICK PARAM"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="Mark" Tag="QuickMark" Click="Cmd_Click" ToolTip="Quick-set Mark parameter"/>
                                <Button Style="{StaticResource CatBtn}" Content="Type" Tag="QuickType" Click="Cmd_Click" ToolTip="Quick-filter by type"/>
                                <Button Style="{StaticResource CatBtn}" Content="Family" Tag="QuickFamily" Click="Cmd_Click" ToolTip="Quick-filter by family"/>
                                <Button Style="{StaticResource CatBtn}" Content="System" Tag="QuickSystem" Click="Cmd_Click" ToolTip="Quick-filter by system"/>
                            </WrapPanel>
                        </Border>

                        <!-- BULK PARAMETER WRITE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="⚡ BULK PARAMETER WRITE"/>
                        <Border Style="{StaticResource GroupBorder}" BorderBrush="#FF9800">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbBulkParam" IsEditable="True" FontSize="10" Height="24" ToolTip="Parameter name"/>
                                    <Button Grid.Column="1" Content="↺" Width="24" Height="24" Click="BtnRefreshParams_Click" ToolTip="Refresh parameter list"/>
                                    <Button Grid.Column="2" Content="[Brain]" Width="40" Height="24" Style="{StaticResource PurpleBtn}" FontSize="9" Tag="FamilyStagePopulate" Click="Cmd_Click" ToolTip="Auto-populate all tokens from category/spatial data"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtBulkValue" FontSize="10" Height="24" ToolTip="Value to write"/>
                                    <Button Grid.Column="1" Content="Preview" Style="{StaticResource ActionBtn}" Click="BtnBulkPreview_Click" ToolTip="Preview changes"/>
                                    <Button Grid.Column="2" Content="▶ Write" Style="{StaticResource GreenBtn}" Click="BtnBulkWrite_Click" ToolTip="Write value to selected elements"/>
                                    <Button Grid.Column="3" Content="Clear" Style="{StaticResource RedBtn}" Click="BtnBulkClear_Click" ToolTip="Clear parameter on selected"/>
                                </Grid>
                                <TextBlock x:Name="txtBulkStatus" Text="Select elements, pick param, enter value" FontSize="9" Foreground="#888" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- PARAMETER LOOKUP -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="[Find] PARAMETER LOOKUP"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Live param:" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox Grid.Column="1" x:Name="cmbLookupParam" IsEditable="True" FontSize="10" Height="24"/>
                                    <Button Grid.Column="2" Content="▼" Width="20" Height="24" Tag="RefreshParamList" Click="Cmd_Click" ToolTip="Refresh parameter list"/>
                                    <Button Grid.Column="3" Content="⊙" Width="20" Height="24" Tag="SelectionInfo" Click="Cmd_Click" ToolTip="Show selection info"/>
                                </Grid>
                                <TextBox x:Name="txtLookupFilter" FontSize="10" Height="24" Margin="0,4,0,0" ToolTip="Search/filter"/>
                                <TextBlock x:Name="txtParamInfo" Text="Type: —&#x0a;Group: —&#x0a;GUID: —" FontSize="9" Foreground="#888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ ORGANISE TAB ═══════════════ -->
            <TabItem Header="ORGANISE">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                    <StackPanel>

                        <!-- TAG OPERATIONS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="TAG OPERATIONS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionBtn}" Content="Tag Sel" Tag="TagSelected" Click="Cmd_Click" ToolTip="Tag selected elements"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Tag Cat" Tag="AutoTag" Click="Cmd_Click" ToolTip="Tag by category in view"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Tag All" Tag="BatchTag" Click="Cmd_Click" ToolTip="Batch tag entire project"/>
                                <Button Style="{StaticResource RedBtn}" Content="Del Tags" Tag="DeleteTags" Click="Cmd_Click" ToolTip="Delete all tags from selection"/>
                                <Button Style="{StaticResource OrangeBtn}" Content="Orphans" Tag="FindDuplicates" Click="Cmd_Click" ToolTip="Find orphaned/duplicate tags"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[Num]Renum" Tag="RenumberTags" Click="Cmd_Click" ToolTip="Renumber tags sequentially"/>
                                <Button Style="{StaticResource ActionBtn}" Content="[List]Clone" Tag="CopyTags" Click="Cmd_Click" ToolTip="Copy tags from first to all"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Audit" Tag="ValidateTags" Click="Cmd_Click" ToolTip="Validate tag completeness"/>
                                <Button Style="{StaticResource ActionBtn}" Content="AuditCSV" Tag="AuditTagsCSV" Click="Cmd_Click" ToolTip="Export tag audit to CSV"/>
                                <Button Style="{StaticResource ActionBtn}" Content="MultiView" Tag="BatchTag" Click="Cmd_Click" ToolTip="Tag across multiple views"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Clashing▶" Tag="FixDuplicates" Click="Cmd_Click" ToolTip="Fix duplicate/clashing tags"/>
                                <Button Style="{StaticResource GreenBtn}" Content="☞New" Tag="TagNewOnly" Click="Cmd_Click" ToolTip="Tag new/untagged elements only"/>
                                <Button Style="{StaticResource ActionBtn}" Content="↔Swap" Tag="SwapTags" Click="Cmd_Click" ToolTip="Swap tags between 2 elements"/>
                                <Button Style="{StaticResource ActionBtn}" Content="ReTag" Tag="ReTag" Click="Cmd_Click" ToolTip="Force re-derive tags on selection"/>
                            </WrapPanel>
                        </Border>

                        <!-- ORIENTATION & TEXT ALIGNMENT -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="⟳ ORIENTATION &amp; TEXT ALIGNMENT"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <WrapPanel>
                                <Button Style="{StaticResource CatBtn}" Content="⊘H↔V" Tag="ToggleTagOrientation" Click="Cmd_Click" ToolTip="Toggle horizontal/vertical"/>
                                <Button Style="{StaticResource CatBtn}" Content="All H" Tag="AlignTagsH" Click="Cmd_Click" ToolTip="All horizontal"/>
                                <Button Style="{StaticResource CatBtn}" Content="All V" Tag="AlignTagsV" Click="Cmd_Click" ToolTip="All vertical"/>
                                <Button Style="{StaticResource CatBtn}" Content="→FlipH" Tag="FlipTagsH" Click="Cmd_Click" ToolTip="Flip horizontal"/>
                                <Button Style="{StaticResource CatBtn}" Content="↑FlipV" Tag="FlipTagsV" Click="Cmd_Click" ToolTip="Flip vertical"/>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Text:" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Style="{StaticResource CatBtn}" Content="◀" Tag="AlignTextLeft" Click="Cmd_Click" ToolTip="Align text left"/>
                                <Button Style="{StaticResource CatBtn}" Content="≡C" Tag="AlignTextCenter" Click="Cmd_Click" ToolTip="Align text center"/>
                                <Button Style="{StaticResource CatBtn}" Content="R▶" Tag="AlignTextRight" Click="Cmd_Click" ToolTip="Align text right"/>
                            </StackPanel>
                        </Border>

                        <!-- ALIGN & DISTRIBUTE -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="⊞ ALIGN &amp; DISTRIBUTE"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <StackPanel>
                                <WrapPanel>
                                    <Button Style="{StaticResource CatBtn}" Content="↰L" Tag="AlignLeft" Click="Cmd_Click" ToolTip="Align left"/>
                                    <Button Style="{StaticResource CatBtn}" Content="R↱" Tag="AlignRight" Click="Cmd_Click" ToolTip="Align right"/>
                                    <Button Style="{StaticResource CatBtn}" Content="△T" Tag="AlignTop" Click="Cmd_Click" ToolTip="Align top"/>
                                    <Button Style="{StaticResource CatBtn}" Content="B▽" Tag="AlignBottom" Click="Cmd_Click" ToolTip="Align bottom"/>
                                    <Button Style="{StaticResource CatBtn}" Content="→CH" Tag="AlignCenterH" Click="Cmd_Click" ToolTip="Center horizontal"/>
                                    <Button Style="{StaticResource CatBtn}" Content="|CV" Tag="AlignCenterV" Click="Cmd_Click" ToolTip="Center vertical"/>
                                    <Button Style="{StaticResource CatBtn}" Content="→H" Tag="DistributeH" Click="Cmd_Click" ToolTip="Distribute horizontal"/>
                                    <Button Style="{StaticResource CatBtn}" Content="↕V" Tag="DistributeV" Click="Cmd_Click" ToolTip="Distribute vertical"/>
                                    <Button Style="{StaticResource CatBtn}" Content="tH" Tag="AlignTagsH" Click="Cmd_Click" ToolTip="Align tags horizontal"/>
                                    <Button Style="{StaticResource CatBtn}" Content="tV" Tag="AlignTagsV" Click="Cmd_Click" ToolTip="Align tags vertical"/>
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Style="{StaticResource CatBtn}" Content="Grid" Tag="ArrangeGrid" Click="Cmd_Click" ToolTip="Grid arrange"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Circle" Tag="ArrangeCircle" Click="Cmd_Click" ToolTip="Circle arrange"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Stack" Tag="ArrangeStack" Click="Cmd_Click" ToolTip="Stack arrange"/>
                                    <Button Style="{StaticResource CatBtn}" Content="StackH" Tag="ArrangeStackH" Click="Cmd_Click" ToolTip="Stack horizontal"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Mirror" Tag="ArrangeMirror" Click="Cmd_Click" ToolTip="Mirror arrange"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Radial" Tag="ArrangeRadial" Click="Cmd_Click" ToolTip="Radial arrange"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- LEADERS -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="⟋ LEADERS"/>
                        <Border Style="{StaticResource GroupBorder}">
                            <StackPanel>
                                <TextBlock Text="ADD / REMOVE" FontSize="9" Foreground="#888"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource GreenBtn}" Content="+Leader" Tag="AddLeaders" Click="Cmd_Click" ToolTip="Add leaders"/>
                                    <Button Style="{StaticResource RedBtn}" Content="−Leader" Tag="RemoveLeaders" Click="Cmd_Click" ToolTip="Remove leaders"/>
                                    <Button Style="{StaticResource BlueBtn}" Content="+Multi" Tag="ToggleLeaders" Click="Cmd_Click" ToolTip="Toggle multi-leader"/>
                                    <Button Style="{StaticResource ActionBtn}" Content="Combine" Tag="ToggleLeaders" Click="Cmd_Click" ToolTip="Combine leaders"/>
                                </WrapPanel>
                                <TextBlock Text="ELBOW — click to switch style" FontSize="9" Foreground="#888" Margin="0,4,0,0"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource CatBtn}" Content="⊾90°" Tag="SnapElbow90" Click="Cmd_Click" ToolTip="Snap elbow 90 degrees"/>
                                    <Button Style="{StaticResource CatBtn}" Content="∠45°" Tag="SnapElbow45" Click="Cmd_Click" ToolTip="Snap elbow 45 degrees"/>
                                    <Button Style="{StaticResource CatBtn}" Content="→Str" Tag="SnapElbowStraight" Click="Cmd_Click" ToolTip="Straight elbow"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Flip" Tag="FlipTags" Click="Cmd_Click" ToolTip="Flip leader side"/>
                                    <Button Style="{StaticResource CatBtn}" Content="+Add" Tag="AddLeaders" Click="Cmd_Click" ToolTip="Add elbow point"/>
                                    <Button Style="{StaticResource CatBtn}" Content="→Straight" Tag="SnapElbowStraight" Click="Cmd_Click" ToolTip="Make straight"/>
                                </WrapPanel>
                                <TextBlock Text="SNAP TAG POSITION" FontSize="9" Foreground="#888" Margin="0,4,0,0"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource CatBtn}" Content="Tag→45°" Tag="SnapElbow45" Click="Cmd_Click" ToolTip="Snap tag at 45 degrees"/>
                                    <Button Style="{StaticResource CatBtn}" Content="Tag→90°" Tag="SnapElbow90" Click="Cmd_Click" ToolTip="Snap tag at 90 degrees"/>
                                    <Button Style="{StaticResource CatBtn}" Content="📌Pin" Tag="PinTags" Click="Cmd_Click" ToolTip="Pin/unpin selected tags"/>
                                    <Button Style="{StaticResource CatBtn}" Content="↺Reset" Tag="ResetTagPositions" Click="Cmd_Click" ToolTip="Reset tag positions to element centers"/>
                                </WrapPanel>
                                <TextBlock Text="LENGTH" FontSize="9" Foreground="#888" Margin="0,4,0,0"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource CatBtn}" Content="0.25ft" Tag="LeaderLength025" Click="Cmd_Click" ToolTip="Set leader 0.25ft"/>
