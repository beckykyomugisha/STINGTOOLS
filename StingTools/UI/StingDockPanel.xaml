                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4">

                                        <!-- SCALE-AWARE PLACEMENT -->
                                        <TextBlock Text="SCALE-AWARE PLACEMENT" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,2,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <TextBlock Text="Scale tier rules (auto-detected from view)" FontSize="9" Margin="0,0,0,4"/>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="1:1 – 1:50" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale50" Minimum="0.5" Maximum="10" Value="2" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale50, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="1:50 – 1:100" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale100" Minimum="1" Maximum="15" Value="5" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale100, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="1:100 – 1:200" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale200" Minimum="2" Maximum="20" Value="8" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale200, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="1:200 – 1:500" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale500" Minimum="5" Maximum="30" Value="12" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale500, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="1:500+" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldScale1000" Minimum="10" Maximum="50" Value="20" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldScale1000, StringFormat={}{0:F1}mm}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Offset cap (ft)" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldOffsetCap" Minimum="5" Maximum="50" Value="30" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldOffsetCap, StringFormat={}{0:F0} ft}" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- PER-CATEGORY SCALE MULTIPLIERS -->
                                        <TextBlock Text="PER-CATEGORY SCALE MULTIPLIERS" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
                                        <Border Style="{StaticResource GroupBorder}">
                                            <StackPanel>
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Ducts" FontSize="9" VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="sldMultDucts" Minimum="0.5" Maximum="3.0" Value="1.0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=sldMultDucts, StringFormat={}{0:F1}x}" FontSize="9" VerticalAlignment="Center"/>
