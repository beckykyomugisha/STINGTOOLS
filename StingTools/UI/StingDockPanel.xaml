                                            </StackPanel>
                                        </Border>

                                        <!-- TOKEN PRE-POPULATION ORDER -->
                                        <TextBlock Text="TOKEN PRE-POPULATION ORDER" FontWeight="Bold" FontSize="10" Foreground="#5D4037" Margin="0,6,0,4"/>
