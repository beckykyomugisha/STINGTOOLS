# Cloudflare Pages / Netlify redirects
# Format: <from> <to> <status>
# 301 = permanent, 302 = temporary

# Legacy URLs
/docs           https://docs.planscape.build/    301
/docs/*         https://docs.planscape.build/:splat 301

# Note: Cloudflare Pages auto-canonicalises /pricing → /pricing.html.
# Don't add explicit /pricing → /pricing.html rules here — they create a redirect loop.

# App routes — proxy to the API for signup / login
/signup         https://api.planscape.build/auth/signup 302
/login          https://api.planscape.build/auth/login  302
/app            https://app.planscape.build/             302
/app/*          https://app.planscape.build/:splat       302

# API
/api/*          https://api.planscape.build/:splat       200

# Old WordPress-style paths (just in case)
/?p=*           /blog/                          301
/category/*     /blog/                          301
