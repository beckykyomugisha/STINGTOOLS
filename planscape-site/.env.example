# planscape-site environment variables
#
# Copy to `.env.local` for local dev or `.env.production` for deployed
# builds. Variables prefixed with NEXT_PUBLIC_ are inlined into the
# client bundle, so only put values that are safe to ship to browsers.

# Mapbox public token — required to render the live "Made for Africa's
# AEC sector" project map (components/AfricaProjectMap.tsx). Without it
# the section renders a no-token fallback. Get a free public token at
# https://account.mapbox.com/access-tokens/.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Planscape API origin — used by /viewer.html share links and any
# client-side fetches. For local dev: http://localhost:5000
# For staging:  https://api-staging.planscape.app
# For prod:     https://api.planscape.app
NEXT_PUBLIC_PLANSCAPE_API=
