<?xml version="1.0" encoding="UTF-8"?>
<!--
  EXAMPLE — not a project-ready file.

  Demonstrates a populated project overlay for StingZoneCodes on the
  Riverside Acute Hospital ACU block.

  The zone codes here are clinical / functional zones at the campus
  level. Fire-compartmentation, acoustic, and pressure zones are
  modelled as separate IfcZones with the same StingZoneCodes value
  but different Pset_StingSpatialCodes.ZoneCategory.
-->
<StingPropertyEnumeration xmlns="https://stingtools.io/schema/ifc/enums/v1" version="1.0.0" schema_version="1">

  <Identity>
    <Name>StingZoneCodes</Name>
    <Definition>Project overlay — clinical / functional zones for the Riverside Acute Hospital campus. Each zone semantic is disambiguated via Pset_StingSpatialCodes.ZoneCategory (one of: Fire / Acoustic / HVAC / Clinical / Pressure / Security / Radiation / MRI / Building).</Definition>
    <IfdGuid>uuid:a1d15c11-9001-4001-9000-000000000003</IfdGuid>
  </Identity>

  <Governance>
    <Scope>project_template</Scope>
    <Origin>project</Origin>
    <SinceVersion>5.0.0</SinceVersion>
    <Maintainer>Riverside Hospital Project — Information Manager</Maintainer>
    <StandardsBasis>Riverside Hospital BEP §4.4 (Zone strategy); STING tag grammar v5.0; HTM 03-01 (pressure zones); BS 9999 (fire compartments); cross-bound to IfcZone via Pset_StingSpatialCodes</StandardsBasis>
  </Governance>

  <IfcMapping>
    <PrimaryType>IfcLabel</PrimaryType>
    <UseAsEnumeratedValue>true</UseAsEnumeratedValue>
    <ApplicableIfcVersions>IFC4 IFC4X3 IFC2X3</ApplicableIfcVersions>
  </IfcMapping>

  <Values>
