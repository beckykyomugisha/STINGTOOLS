<Project Sdk="Microsoft.NET.Sdk">
  <!--
    Revit API CI Stubs — RevitAPI.dll
    Provides minimal type definitions for Autodesk.Revit.DB.*,
    Autodesk.Revit.ApplicationServices.*, and Autodesk.Revit.Attributes.*
    so that StingTools.csproj can compile on Linux/CI without a Revit install.
    These stubs are NOT used at runtime — they exist only for the compiler.
  -->
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <AssemblyName>RevitAPI</AssemblyName>
    <RootNamespace>Autodesk.Revit</RootNamespace>
    <OutputType>Library</OutputType>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- Suppress warnings about missing XML docs, CS1591, etc. -->
    <NoWarn>1591;1998;CS0108;CS0114;CS0612;CS0618</NoWarn>
  </PropertyGroup>
</Project>
